<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= stream.title %> | CoWatch</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
  <script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
  <style>
    * {
      box-sizing: border-box;
    }

    html,
    body {
      margin: 0;
      min-height: 100%;
      background: #050505;
      color: #fff;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      overflow: hidden;
    }

    .watch-shell {
      width: 100vw;
      height: 100dvh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #000;
      position: relative;
    }

    .watch-player {
      width: 100%;
      height: 100%;
      background: #000;
      display: block;
      object-fit: contain;
    }

    .watch-topbar {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      z-index: 5;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      padding: 1rem;
      background: linear-gradient(180deg, rgba(0,0,0,0.78), rgba(0,0,0,0));
      pointer-events: none;
    }

    .watch-title {
      min-width: 0;
      display: flex;
      align-items: center;
      gap: 0.6rem;
      font-weight: 700;
      text-shadow: 0 1px 12px rgba(0,0,0,0.7);
    }

    .watch-title span {
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .status-pill {
      flex: 0 0 auto;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.35rem 0.7rem;
      border-radius: 999px;
      background: rgba(15, 23, 42, 0.78);
      border: 1px solid rgba(255,255,255,0.12);
      color: #cbd5e1;
      font-size: 0.82rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .status-pill.live {
      color: #86efac;
      border-color: rgba(134,239,172,0.35);
      background: rgba(20,83,45,0.35);
    }

    .watch-overlay {
      position: absolute;
      inset: 0;
      z-index: 4;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 1.5rem;
      background: #070707;
    }

    .watch-message {
      width: min(460px, 100%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.9rem;
      color: #cbd5e1;
    }

    .watch-message i {
      color: #82A3A1;
      font-size: 4rem;
    }

    .watch-message h1 {
      margin: 0;
      font-size: clamp(1.5rem, 4vw, 2.25rem);
      color: #fff;
      letter-spacing: 0;
    }

    .watch-message p {
      margin: 0;
      line-height: 1.6;
    }

    .watch-action {
      margin-top: 0.4rem;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      border: 0;
      border-radius: 999px;
      padding: 0.75rem 1.2rem;
      background: #82A3A1;
      color: #fff;
      font-weight: 800;
      cursor: pointer;
    }

    @media (max-width: 640px) {
      .watch-topbar {
        padding: 0.8rem;
      }

      .watch-title {
        font-size: 0.95rem;
      }

      .status-pill {
        font-size: 0.72rem;
      }
    }
  </style>
</head>
<body>
  <main class="watch-shell">
    <video id="watch-video" class="watch-player" controls playsinline></video>

    <div class="watch-topbar">
      <div class="watch-title">
        <i class="ti ti-movie"></i>
        <span><%= stream.title %></span>
      </div>
      <div id="status-pill" class="status-pill">
        Offline
      </div>
    </div>

    <div id="watch-overlay" class="watch-overlay">
      <div class="watch-message">
        <i class="ti ti-broadcast-off"></i>
        <h1 id="overlay-title">Stream is offline</h1>
        <p id="overlay-copy">The host has not opened the movie room yet. This page will start checking automatically.</p>
        <button id="manual-play-btn" class="watch-action" style="display: none;" type="button">
          <i class="ti ti-player-play"></i> Play Movie
        </button>
      </div>
    </div>
  </main>

  <script>
    const streamKey = "<%= stream.streamKey %>";
    const video = document.getElementById('watch-video');
    const overlay = document.getElementById('watch-overlay');
    const overlayTitle = document.getElementById('overlay-title');
    const overlayCopy = document.getElementById('overlay-copy');
    const manualPlayBtn = document.getElementById('manual-play-btn');
    const statusPill = document.getElementById('status-pill');

    let hls = null;
    let currentUrl = null;
    let playRequested = false;
    let lastAttachAt = 0;

    function withCacheBust(url) {
      const separator = url.includes('?') ? '&' : '?';
      return `${url}${separator}v=${Date.now()}`;
    }

    function seekToLiveEdge() {
      try {
        const ranges = video.seekable;
        if (ranges && ranges.length > 0) {
          video.currentTime = Math.max(ranges.end(ranges.length - 1) - 1.5, 0);
        }
      } catch (_) {}
    }

    function setOffline(message) {
      statusPill.className = 'status-pill';
      statusPill.textContent = 'Offline';
      overlay.style.display = 'flex';
      overlayTitle.textContent = 'Stream is offline';
      overlayCopy.textContent = message || 'The host has not opened the movie room yet. This page will start checking automatically.';
      manualPlayBtn.style.display = 'none';
      currentUrl = null;
      lastAttachAt = 0;
      if (hls) {
        hls.destroy();
        hls = null;
      }
      video.removeAttribute('src');
      video.load();
    }

    function showLiveReady() {
      statusPill.className = 'status-pill live';
      statusPill.innerHTML = '<i class="ti ti-point-filled"></i> Live';
      overlay.style.display = 'none';
    }

    function showPlayPrompt() {
      statusPill.className = 'status-pill live';
      statusPill.innerHTML = '<i class="ti ti-point-filled"></i> Live';
      overlay.style.display = 'flex';
      overlayTitle.textContent = 'Movie is ready';
      overlayCopy.textContent = 'Press play to start watching.';
      manualPlayBtn.style.display = 'inline-flex';
    }

    function attemptPlay() {
      playRequested = true;
      seekToLiveEdge();
      video.play().then(showLiveReady).catch(showPlayPrompt);
    }

    function attachHls(url) {
      const shouldReload = currentUrl !== url || !hls || (Date.now() - lastAttachAt) > 30000;
      if (!shouldReload) {
        if (hls) hls.startLoad(-1);
        if (!video.paused) seekToLiveEdge();
        return;
      }
      currentUrl = url;
      lastAttachAt = Date.now();
      const freshUrl = withCacheBust(url);

      if (hls) {
        hls.destroy();
        hls = null;
      }

      if (video.canPlayType('application/vnd.apple.mpegurl')) {
        video.src = freshUrl;
        video.addEventListener('loadedmetadata', seekToLiveEdge, { once: true });
        attemptPlay();
        return;
      }

      if (!window.Hls || !Hls.isSupported()) {
        overlay.style.display = 'flex';
        overlayTitle.textContent = 'Playback unsupported';
        overlayCopy.textContent = 'This browser cannot play HLS streams.';
        manualPlayBtn.style.display = 'none';
        return;
      }

      hls = new Hls({
        lowLatencyMode: false,
        liveSyncDurationCount: 2,
        liveMaxLatencyDurationCount: 5,
        maxLiveSyncPlaybackRate: 1.5,
        maxBufferLength: 20,
        backBufferLength: 10,
        manifestLoadingMaxRetry: 6,
        levelLoadingMaxRetry: 6,
        fragLoadingMaxRetry: 6,
      });
      hls.loadSource(freshUrl);
      hls.attachMedia(video);
      hls.on(Hls.Events.MANIFEST_PARSED, () => {
        hls.startLoad(-1);
        attemptPlay();
      });
      hls.on(Hls.Events.LEVEL_UPDATED, () => {
        if (!video.paused) seekToLiveEdge();
      });
      hls.on(Hls.Events.ERROR, (_, data) => {
        if (!data) return;
        if (data.type === Hls.ErrorTypes.NETWORK_ERROR) {
          hls.startLoad(-1);
          return;
        }
        if (!data.fatal) return;
        setOffline('Playback stalled. Waiting for the host feed to recover.');
      });
    }

    async function checkStatus() {
      try {
        const res = await fetch(`/api/stream/${encodeURIComponent(streamKey)}/playback/status`, { cache: 'no-store' });
        const data = await res.json();
        if (!res.ok || !data.success) throw new Error(data.error || 'Unable to check stream status.');

        if (data.data.canPlay && data.data.hlsUrl) {
          attachHls(data.data.hlsUrl);
        } else if (!data.data.isLive) {
          setOffline('The host has not opened the movie room yet. This page will start checking automatically.');
        } else {
          setOffline('The host is live, but the video feed is still warming up.');
        }
      } catch (_) {
        setOffline('Connection lost while checking the movie room. Retrying automatically.');
      }
    }

    manualPlayBtn.addEventListener('click', attemptPlay);
    video.addEventListener('playing', showLiveReady);
    video.addEventListener('waiting', () => {
      if (playRequested) {
        statusPill.className = 'status-pill';
        statusPill.textContent = 'Buffering';
      }
    });

    checkStatus();
    setInterval(checkStatus, 5000);
  </script>
</body>
</html>
