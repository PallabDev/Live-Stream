<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title><%= stream.title %> | CoWatch Player</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="icon" type="image/png" href="/favicon.png">
<link
  rel="stylesheet"
  href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
/>
<script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
<script src="https://cdn.tailwindcss.com"></script>
<script>
tailwind.config = {
  theme: {
    extend: {
      colors: {
        accent: '#82A3A1',
        'accent-dark': '#465362',
        secondary: '#9FC490',
        'control-bg': 'rgba(18, 22, 26, 0.95)',
        'glass-bg': 'rgba(70, 83, 98, 0.4)',
        'glass-border': 'rgba(130, 163, 161, 0.25)',
      },
      animation: {
        'spin-slow': 'spin 1s linear infinite',
        'pulse-slow': 'pulse 2s ease-in-out infinite',
      },
      backdropBlur: {
        'glass': '10px',
      },
    }
  }
}
</script>
<style>
:root {
  --progress-bg: #2a323b;
  --progress-fill: #82A3A1;
  --value: 100%;
}

/* Make page exactly viewport size, no scroll */
html, body {
  margin: 0;
  padding: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
  background: #000000;
}

/* Custom scrollbar for settings */
.sh-settings-list::-webkit-scrollbar {
  width: 6px;
}
.sh-settings-list::-webkit-scrollbar-track {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 3px;
}
.sh-settings-list::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 3px;
}
.sh-settings-list::-webkit-scrollbar-thumb:hover {
  background: rgba(255, 255, 255, 0.3);
}

/* === VERTICAL VOLUME SLIDER === */
.sh-volume-slider {
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Base input reset */
.sh-volume-range {
  -webkit-appearance: none;
  appearance: none;
  writing-mode: vertical-lr; direction: rtl;
  width: 12px;                   /* thickness of the track */
  height: 100%;
  padding: 0;
  background: transparent;
  cursor: pointer;
}

/* WebKit track */
.sh-volume-range::-webkit-slider-runnable-track {
  width: 12px;
  height: 100%;
  background: #1e1b4b;
  border-radius: 9999px;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

/* WebKit thumb */
.sh-volume-range::-webkit-slider-thumb {
  -webkit-appearance: none;
  appearance: none;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: #ffffff;
  border: 1px solid #111;
  box-shadow: 0 2px 5px rgba(0, 0, 0, 0.4);
  margin-top: -3px; /* center thumb on track */
}

/* Firefox track */
.sh-volume-range::-moz-range-track {
  width: 12px;
  height: 100%;
  background: #1e1b4b;
  border-radius: 9999px;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

/* Firefox thumb */
.sh-volume-range::-moz-range-thumb {
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: #ffffff;
  border: 1px solid #111;
  box-shadow: 0 2px 5px rgba(0, 0, 0, 0.4);
}

/* Hide ugly focus ring */
.sh-volume-range:focus {
  outline: none;
}

/* Progress bar gradient */
.sh-progress-bar {
  background: linear-gradient(90deg, #6366f1, #4f46e5);
}

/* Player layout centering and aspect ratio constraint */
.sh-player {
  width: 100%;
  max-width: 100%;
  max-height: 100dvh;
  aspect-ratio: 16/9;
  background: #000;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4px 20px rgba(0,0,0,0.8);
  transition: all 0.3s ease;
}

@media (min-width: 1200px) {
  .sh-player {
    max-width: 1200px;
    border-radius: 12px;
  }
}

/* Fullscreen adjustments override */
:fullscreen .sh-player,
:-webkit-full-screen .sh-player,
:-moz-full-screen .sh-player {
  border-radius: 0 !important;
  width: 100vw !important;
  height: 100vh !important;
  max-width: none !important;
  max-height: none !important;
  aspect-ratio: auto !important;
}

#sh-controls {
  padding-bottom: calc(env(safe-area-inset-bottom) + 1.25rem) !important;
}

/* Responsive adjustments for controls */
@media (max-width: 600px) {
  #sh-controls {
    padding: 0.75rem !important;
    padding-bottom: calc(env(safe-area-inset-bottom) + 0.75rem) !important;
    gap: 0.5rem !important;
  }
  .sh-play-btn {
    width: 2.25rem !important;
    height: 2.25rem !important;
  }
  .sh-btn {
    width: 2rem !important;
    height: 2rem !important;
  }
  #sh-current-time, #sh-duration {
    font-size: 0.75rem !important;
    min-width: 36px !important;
  }
}
</style>
</head>
<body class="bg-[#000000] m-0 p-0 font-['Inter',system-ui,sans-serif] text-white">
  <!-- Full-screen container -->
  <div class="w-screen h-[100dvh] flex items-center justify-center bg-black relative overflow-hidden">
    <!-- Player container -->
    <div
      class="sh-player"
      id="sh-player"
    >
      <video
        class="w-full h-full object-contain bg-black block"
        id="sh-video"
        preload="auto"
        playsinline
        style="image-rendering: -webkit-optimize-contrast; image-rendering: crisp-edges;"
      ></video>



      <!-- Offline Screen Overlay -->
      <div
        id="offline-screen"
        class="fixed inset-0 bg-[#0f172a] z-50 flex flex-col justify-center items-center text-center p-6"
        style="display: flex;"
      >
        <div class="text-indigo-500 text-6xl mb-4 animate-pulse">
          <i class="fa-solid fa-satellite-dish"></i>
        </div>
        <h3 class="text-2xl font-bold text-white mb-2">Stream is Offline</h3>
        <p class="text-slate-400 text-sm max-w-sm mb-6">
          The broadcaster is not streaming live right now. The feed will automatically play once they start broadcasting.
        </p>
        <button
          class="px-6 py-2.5 rounded-full bg-indigo-600 hover:bg-indigo-500 font-semibold text-sm transition-all hover:scale-105"
          onclick="checkStreamStatus()"
        >
          <i class="fa-solid fa-arrows-rotate mr-1.5"></i> Check Again
        </button>
      </div>

      <!-- Loading Spinner -->
      <div class="absolute inset-0 flex items-center justify-center z-[5] pointer-events-none">
        <div
          class="w-10 h-10 sm:w-[60px] sm:h-[60px] border-4 border-solid border-white/10 border-t-accent rounded-full hidden animate-spin pointer-events-auto"
          id="sh-loading"
        ></div>
      </div>

      <!-- Controls -->
      <div
        class="absolute left-0 right-0 bottom-0 p-4 sm:p-6 bg-gradient-to-t from-black/95 via-black/70 to-transparent flex flex-col gap-3 transition-all duration-150 z-10"
        id="sh-controls"
      >
        <!-- Row 1: Progress & Time -->
        <div class="flex items-center w-full gap-3 min-w-0">
          <span
            class="text-xs sm:text-sm font-medium text-[#aaaaaa] min-w-[42px] sm:min-w-[50px] font-mono tabular-nums"
            id="sh-current-time"
          >
            00:00
          </span>

          <div
            class="sh-progress relative flex-1 h-1.5 sm:h-2 rounded-full bg-[#3a3a3a] cursor-pointer overflow-hidden transition-all duration-150 hover:h-2 sm:hover:h-2.5"
            id="sh-progress"
          >
            <div
              class="sh-progress-buffer absolute top-0 left-0 bottom-0 w-0 rounded-full bg-white/20"
              id="sh-progress-buffer"
            ></div>
            <div
              class="sh-progress-bar absolute top-0 left-0 bottom-0 w-0 rounded-full"
              id="sh-progress-bar"
            ></div>
            <div
              class="sh-progress-handle absolute top-1/2 -translate-y-1/2 w-0 h-0 rounded-full bg-white shadow-none transition-all duration-150 pointer-events-none"
              id="sh-progress-handle"
            ></div>
          </div>

          <span
            class="text-xs sm:text-sm font-medium text-[#aaaaaa] min-w-[42px] sm:min-w-[50px] font-mono tabular-nums"
            id="sh-duration"
          >
            00:00
          </span>
        </div>

        <!-- Row 2: Control Buttons -->
        <div class="flex items-center justify-between w-full">
          <!-- Play / Pause (Left) -->
          <button
            class="sh-play-btn w-9 h-9 sm:w-11 sm:h-11 rounded-full bg-accent text-white flex items-center justify-center text-lg transition-all duration-150 shadow-[0_4px_12px_rgba(99,102,241,0.4)] hover:bg-accent-dark hover:scale-105 hover:shadow-[0_6px_16px_rgba(99,102,241,0.5)]"
            id="sh-play-btn"
            aria-label="Play/Pause"
          >
            <i class="fas fa-play" id="sh-play-icon"></i>
          </button>

          <!-- Right Action Controls -->
          <div class="sh-controls-right flex items-center gap-1.5 sm:gap-2">
            <!-- Volume Button -->
            <button
              class="sh-btn w-8 h-8 sm:w-10 sm:h-10 bg-transparent text-[#aaaaaa] flex items-center justify-center text-lg p-2 rounded-lg transition-all duration-150 hover:text-white hover:bg-white/10 min-w-[32px]"
              id="sh-volume-btn"
              title="Mute/Unmute"
            >
              <i class="fas fa-volume-up" id="sh-volume-icon"></i>
            </button>



            <!-- Fullscreen -->
            <button
              class="sh-btn sh-full-btn w-8 h-8 sm:w-10 sm:h-10 rounded-lg bg-white/10 flex items-center justify-center text-lg transition-all duration-150 hover:bg-white/20 hover:scale-105"
              id="sh-full-btn"
              title="Fullscreen"
            >
              <i class="fas fa-expand" id="sh-fullscreen-icon"></i>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

<script>
(function () {
  // DOM Elements
  const video = document.getElementById('sh-video');
  const player = document.getElementById('sh-player');
  const playBtn = document.getElementById('sh-play-btn');
  const playIcon = document.getElementById('sh-play-icon');
  const currentTimeEl = document.getElementById('sh-current-time');
  const durationEl = document.getElementById('sh-duration');
  const progress = document.getElementById('sh-progress');
  const progressBar = document.getElementById('sh-progress-bar');
  const progressBuffer = document.getElementById('sh-progress-buffer');
  const progressHandle = document.getElementById('sh-progress-handle');
  const volumeBtn = document.getElementById('sh-volume-btn');
  const volumeIcon = document.getElementById('sh-volume-icon');

  const fullBtn = document.getElementById('sh-full-btn');
  const fullscreenIcon = document.getElementById('sh-fullscreen-icon');
  const loadingSpinner = document.getElementById('sh-loading');
  const controls = document.getElementById('sh-controls');
  const offlineScreen = document.getElementById('offline-screen');

  const streamKey = "<%= stream.streamKey %>";
  let viewerId = null;
  let pcInstance = null;
  let statusSocket = null;
  let playbackStarted = false;
  let iceCandidateQueue = [];

  let scrubbing = false;
  let controlsTimeout = null;

  function showOffline() {
    offlineScreen.style.display = 'flex';
    hideLoading();
    playbackStarted = false;
    if (pcInstance) {
      pcInstance.close();
      pcInstance = null;
    }
    video.srcObject = null;
  }

  function hideOffline() {
    offlineScreen.style.display = 'none';
  }

  function connectViewerSocket() {
    const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
    const viewerWsUrl = `${protocol}//${window.location.host}/api/stream/${streamKey}/viewer`;
    
    console.log('[Viewer] Connecting signaling WebSocket to:', viewerWsUrl);
    statusSocket = new WebSocket(viewerWsUrl);

    statusSocket.onmessage = async (event) => {
      try {
        const msg = JSON.parse(event.data);
        const { event: signalEvent, viewerId: id, sdp, candidate, status } = msg;

        if (signalEvent === 'status') {
          console.log('[Viewer] Stream status updated:', status);
          if (status === 'live') {
            viewerId = id;
            hideOffline();
            if (!pcInstance || pcInstance.connectionState !== 'connected') {
              showLoading();
              await initWebRTC();
            } else {
              // We are already connected. Let the broadcaster know we are ready just in case
              if (statusSocket && statusSocket.readyState === WebSocket.OPEN) {
                statusSocket.send(JSON.stringify({ event: "viewer-ready" }));
              }
            }
          } else if (status === 'capacity_reached') {
            const subtitle = document.querySelector('#offline-screen p');
            if (subtitle) subtitle.textContent = msg.message || 'Stream has reached the maximum capacity of 10 viewers.';
            const title = document.querySelector('#offline-screen h3');
            if (title) title.textContent = 'Room Full (10 Viewers Max)';
            showOffline();
          } else {
            showOffline();
          }
        } else if (signalEvent === 'offer') {
          console.log('[Viewer] Received SDP Offer from broadcaster');
          if (pcInstance) {
            await pcInstance.setRemoteDescription(new RTCSessionDescription(sdp));

            // Drain queued ICE candidates that arrived before the remote offer was set
            while (iceCandidateQueue.length > 0) {
              const cand = iceCandidateQueue.shift();
              try {
                await pcInstance.addIceCandidate(new RTCIceCandidate(cand));
              } catch (e) {
                console.warn('[Viewer WebRTC] Error adding queued ICE candidate:', e);
              }
            }

            let answer = await pcInstance.createAnswer();
            const modifiedAnswerSdp = preferHighFidelityAudioAndVideo(answer.sdp);
            answer = new RTCSessionDescription({
              type: answer.type,
              sdp: modifiedAnswerSdp
            });
            await pcInstance.setLocalDescription(answer);

            statusSocket.send(JSON.stringify({
              event: "answer",
              sdp: pcInstance.localDescription
            }));
          }
        } else if (signalEvent === 'candidate') {
          console.log('[Viewer] Received ICE Candidate from broadcaster');
          if (pcInstance && candidate) {
            if (!pcInstance.remoteDescription || !pcInstance.remoteDescription.type) {
              console.log('[Viewer WebRTC] Queuing ICE candidate until SDP offer is applied');
              iceCandidateQueue.push(candidate);
            } else {
              try {
                await pcInstance.addIceCandidate(new RTCIceCandidate(candidate));
              } catch (err) {
                console.warn('[Viewer WebRTC] Error adding ICE candidate:', err);
              }
            }
          }
        }
      } catch (err) {
        console.error('[Viewer WS Message Exception]:', err);
      }
    };

    statusSocket.onclose = () => {
      console.log('[Viewer] Signaling WebSocket closed. Reconnecting in 3s...');
      statusSocket = null;
      // Do not call showOffline() here so active WebRTC stream is not interrupted by temporary signal drops.
      setTimeout(connectViewerSocket, 3000);
    };

    statusSocket.onerror = (err) => {
      console.error('[Viewer] Signaling WebSocket error:', err);
      console.warn('[Viewer] Connection to ' + viewerWsUrl + ' failed. Note: If you are testing over a local network using HTTPS with a self-signed certificate, mobile browsers (like iOS Safari) block WebSockets (wss://) silently. Consider testing with a valid secure tunnel like ngrok or HTTP.');
      showOffline();
    };
  }

  window.checkStreamStatus = function () {
    if (!statusSocket || statusSocket.readyState !== WebSocket.OPEN) {
      connectViewerSocket();
    } else {
      statusSocket.send(JSON.stringify({ event: "viewer-ready" }));
    }
  };

  function preferHighFidelityAudioAndVideo(sdp) {
    let lines = sdp.split('\r\n');
    let opusPt = null;

    for (let line of lines) {
      if (line.toLowerCase().includes('opus/48000')) {
        const match = line.match(/a=rtpmap:(\d+)\s+opus\/48000/i);
        if (match) {
          opusPt = match[1];
          break;
        }
      }
    }

    let modifiedLines = [];
    let fmtpFound = false;

    for (let i = 0; i < lines.length; i++) {
      let line = lines[i];

      if (opusPt && line.startsWith(`a=fmtp:${opusPt}`)) {
        fmtpFound = true;
        line = `a=fmtp:${opusPt} stereo=1;sprop-stereo=1;maxaveragebitrate=256000;maxplaybackrate=48000;usedtx=0`;
      }

      modifiedLines.push(line);
    }

    if (opusPt && !fmtpFound) {
      for (let i = 0; i < modifiedLines.length; i++) {
        if (modifiedLines[i].startsWith(`a=rtpmap:${opusPt}`)) {
          modifiedLines.splice(i + 1, 0, `a=fmtp:${opusPt} stereo=1;sprop-stereo=1;maxaveragebitrate=256000;maxplaybackrate=48000;usedtx=0`);
          break;
        }
      }
    }

    return modifiedLines.join('\r\n');
  }

  async function initWebRTC() {
    if (typeof RTCPeerConnection === 'undefined') {
      alert("WebRTC streaming requires a secure context (HTTPS). Please open this site over HTTPS.");
      hideLoading();
      return;
    }

    if (pcInstance) {
      try { pcInstance.close(); } catch (_) {}
      pcInstance = null;
    }

    console.log('[Viewer SFU] Initializing WHEP MediaMTX subscriber for key:', streamKey);
    const turnHost = window.location.hostname;
    const config = {
      iceServers: [
        { urls: "stun:stun.l.google.com:19302" },
        { urls: "stun:stun1.l.google.com:19302" },
        { 
            urls: [`turn:${turnHost}:3478`, `turn:${turnHost}:3478?transport=tcp`], 
            username: "guest", 
            credential: "somepassword" 
        }
      ]
    };

    pcInstance = new RTCPeerConnection(config);

    // Request audio and video transceivers from MediaMTX SFU
    pcInstance.addTransceiver('video', { direction: 'recvonly' });
    pcInstance.addTransceiver('audio', { direction: 'recvonly' });

    pcInstance.ontrack = (event) => {
      console.log('[Viewer SFU] MediaMTX track received:', event.track.kind);

      if (event.receiver) {
        try {
          if ('playoutDelayHint' in event.receiver) {
            event.receiver.playoutDelayHint = 0; // Zero playout delay for immediate smooth 30 FPS playback
          }
          if ('jitterBufferTarget' in event.receiver) {
            event.receiver.jitterBufferTarget = 0;
          }
        } catch (e) {
          console.warn('[Viewer SFU] Receiver delay hint error:', e);
        }
      }

      if (event.streams && event.streams[0]) {
        if (video.srcObject !== event.streams[0]) {
          video.srcObject = event.streams[0];
          console.log('[Viewer SFU] Attached MediaMTX stream to video player');
        }
      } else {
        if (!video.srcObject) {
          const newStream = new MediaStream();
          newStream.addTrack(event.track);
          video.srcObject = newStream;
        } else {
          video.srcObject.addTrack(event.track);
        }
      }

      video.play().then(() => {
        hideLoading();
        hideOffline();
        playbackStarted = true;
        updatePlayIcon();
      }).catch(err => {
        console.warn('[Viewer SFU] Autoplay prevented by browser policy:', err);
        hideLoading();
        hideOffline();
        updatePlayIcon();
      });
    };

    try {
      let offer = await pcInstance.createOffer();
      await pcInstance.setLocalDescription(offer);

      // Wait for STUN/TURN ICE candidate gathering to complete (max 800ms)
      if (pcInstance.iceGatheringState !== 'complete') {
        await new Promise(resolve => {
          const checkState = () => {
            if (pcInstance && pcInstance.iceGatheringState === 'complete') {
              pcInstance.removeEventListener('icegatheringstatechange', checkState);
              resolve();
            }
          };
          pcInstance.addEventListener('icegatheringstatechange', checkState);
          setTimeout(resolve, 800);
        });
      }

      console.log('[Viewer SFU] Sending WHEP offer to MediaMTX SFU proxy...');
      const res = await fetch(`/api/sfu/whep/${streamKey}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/sdp' },
        body: pcInstance.localDescription ? pcInstance.localDescription.sdp : offer.sdp
      });

      if (!res.ok) {
        throw new Error(`MediaMTX WHEP HTTP error ${res.status}`);
      }

      const answerSdp = await res.text();
      await pcInstance.setRemoteDescription(new RTCSessionDescription({
        type: 'answer',
        sdp: answerSdp
      }));

      console.log('[Viewer SFU] Successfully connected to MediaMTX SFU WHEP stream!');
    } catch (err) {
      console.error('[Viewer SFU] WHEP connection error:', err);
      showOffline();
    }
  }

  function formatTime(sec) {
    if (!sec || !isFinite(sec)) return '00:00';
    const s = Math.floor(sec % 60);
    const m = Math.floor(sec / 60);
    return String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');
  }

  function showLoading() {
    loadingSpinner.style.display = 'block';
  }
  function hideLoading() {
    loadingSpinner.style.display = 'none';
  }

  // Play / pause
  function updatePlayIcon() {
    if (video.paused) {
      playIcon.className = 'fas fa-play';
      playBtn.setAttribute('aria-label', 'Play');
    } else {
      playIcon.className = 'fas fa-pause';
      playBtn.setAttribute('aria-label', 'Pause');
    }
  }

  playBtn.addEventListener('click', () => {
    if (video.paused) {
      video.muted = false; // Always unmute on explicit user play intent
      video.play().catch(e => console.warn("Play error:", e));
      if (volumeIcon) volumeIcon.className = 'fas fa-volume-up';
    } else {
      video.pause();
    }
    resetControlsTimer();
  });

  video.addEventListener('play', updatePlayIcon);
  video.addEventListener('pause', updatePlayIcon);

  // Time + progress & zero-latency catchup
  video.addEventListener('timeupdate', () => {
    const ct = video.currentTime || 0;
    const dur = video.duration || 0;
    currentTimeEl.textContent = formatTime(ct);

    if (dur > 0) {
      const percent = (ct / dur) * 100;
      progressBar.style.width = percent + '%';
      progressHandle.style.left = percent + '%';
    }
  });

  video.addEventListener('loadedmetadata', () => {
    durationEl.textContent = formatTime(video.duration);
  });

  video.addEventListener('waiting', showLoading);
  video.addEventListener('playing', hideLoading);

  // Buffer progress
  function updateBufferProgress() {
    if (video.buffered && video.buffered.length > 0 && video.duration > 0) {
      const bufferedEnd = video.buffered.end(video.buffered.length - 1);
      const percent = (bufferedEnd / video.duration) * 100;
      progressBuffer.style.width = percent + '%';
    }
  }
  video.addEventListener('progress', updateBufferProgress);

  // Hover handle
  progress.addEventListener('mouseenter', () => {
    progressHandle.style.width = '14px';
    progressHandle.style.height = '14px';
    progressHandle.style.boxShadow = '0 0 0 3px rgba(0, 0, 0, 0.5)';
  });
  progress.addEventListener('mouseleave', () => {
    progressHandle.style.width = '0';
    progressHandle.style.height = '0';
    progressHandle.style.boxShadow = 'none';
  });

  // Seek
  function seekByClientX(clientX) {
    const rect = progress.getBoundingClientRect();
    const ratio =
      Math.min(Math.max(0, clientX - rect.left), rect.width) / rect.width;
    if (video.duration) {
      video.currentTime = ratio * video.duration;
    }
  }

  progress.addEventListener('mousedown', (e) => {
    scrubbing = true;
    seekByClientX(e.clientX);
    resetControlsTimer();
  });

  window.addEventListener('mousemove', (e) => {
    if (scrubbing) {
      seekByClientX(e.clientX);
      resetControlsTimer();
    }
  });

  window.addEventListener('mouseup', () => {
    scrubbing = false;
    resetControlsTimer();
  });

  progress.addEventListener('click', (e) => {
    seekByClientX(e.clientX);
    resetControlsTimer();
  });

  // Volume Mute/Unmute
  volumeBtn.addEventListener('click', () => {
    video.muted = !video.muted;
    if (video.muted) {
      volumeIcon.className = 'fas fa-volume-mute';
    } else {
      volumeIcon.className = 'fas fa-volume-up';
    }
    resetControlsTimer();
  });



  // Fullscreen (works inside iframe; fullscreen is for player element)
  function toggleFullscreen() {
    if (
      document.fullscreenElement ||
      document.webkitFullscreenElement ||
      document.mozFullScreenElement ||
      document.msFullscreenElement
    ) {
      exitFullscreen();
    } else {
      enterFullscreen();
    }
  }

  function enterFullscreen() {
    const element = player;

    if (element.requestFullscreen) {
      element.requestFullscreen();
    } else if (element.mozRequestFullScreen) {
      element.mozRequestFullScreen();
    } else if (element.webkitRequestFullscreen) {
      element.webkitRequestFullscreen(Element.ALLOW_KEYBOARD_INPUT);
    } else if (element.msRequestFullscreen) {
      element.msRequestFullscreen();
    }

    if (isMobile() && screen.orientation && screen.orientation.lock) {
      screen.orientation.lock('landscape').catch(() => {});
    }

    isFullscreen = true;
    fullscreenIcon.className = 'fas fa-compress';
    resetControlsTimer();
  }

  function exitFullscreen() {
    if (document.exitFullscreen) {
      document.exitFullscreen();
    } else if (document.mozCancelFullScreen) {
      document.mozCancelFullScreen();
    } else if (document.webkitExitFullscreen) {
      document.webkitExitFullscreen();
    } else if (document.msExitFullscreen) {
      document.msExitFullscreen();
    }

    if (screen.orientation && screen.orientation.unlock) {
      screen.orientation.unlock();
    }

    isFullscreen = false;
    fullscreenIcon.className = 'fas fa-expand';
    resetControlsTimer();
  }

  fullBtn.addEventListener('click', toggleFullscreen);

  // Fullscreen events
  document.addEventListener('fullscreenchange', handleFullscreenChange);
  document.addEventListener('webkitfullscreenchange', handleFullscreenChange);
  document.addEventListener('mozfullscreenchange', handleFullscreenChange);
  document.addEventListener('MSFullscreenChange', handleFullscreenChange);

  function handleFullscreenChange() {
    isFullscreen = !!(
      document.fullscreenElement ||
      document.webkitFullscreenElement ||
      document.mozFullScreenElement ||
      document.msFullscreenElement
    );

    if (isFullscreen) {
      fullscreenIcon.className = 'fas fa-compress';
      if (isMobile() && screen.orientation && screen.orientation.lock) {
        screen.orientation.lock('landscape').catch(() => {});
      }
    } else {
      fullscreenIcon.className = 'fas fa-expand';
      if (screen.orientation && screen.orientation.unlock) {
        screen.orientation.unlock();
      }
    }
    resetControlsTimer();
  }

  // Auto-hide controls
  function resetControlsTimer() {
    clearTimeout(controlsTimeout);
    controls.style.opacity = '1';
    controls.style.transform = 'translateY(0)';
    controls.style.pointerEvents = 'auto';
    controlsHidden = false;

    if (!video.paused) {
      controlsTimeout = setTimeout(() => {
        if (!scrubbing) {
          controls.style.opacity = '0';
          controls.style.transform = 'translateY(10px)';
          controls.style.pointerEvents = 'none';
          controlsHidden = true;
        }
      }, 3000);
    }
  }

  player.addEventListener('mousemove', () => {
    resetControlsTimer();
  });

  // Tap or click anywhere outside buttons to toggle controls
  player.addEventListener('pointerdown', (e) => {
    if (controls.contains(e.target)) {
      return;
    }
    if (controlsHidden) {
      resetControlsTimer();
    } else {
      clearTimeout(controlsTimeout);
      controls.style.opacity = '0';
      controls.style.transform = 'translateY(10px)';
      controls.style.pointerEvents = 'none';
      controlsHidden = true;
    }
  });

  player.addEventListener('dblclick', (e) => {
    if (controls.contains(e.target)) return;
    toggleFullscreen();
  });

  window.addEventListener('keydown', (e) => {
    const active = document.activeElement;
    if (active && (active.tagName === 'INPUT' || active.tagName === 'TEXTAREA' || active.isContentEditable)) return;
    if (e.key === ' ' || e.key === 'k') {
      e.preventDefault();
      if (video.paused) video.play(); else video.pause();
    } else if (e.key === 'f' || e.key === 'F') {
      e.preventDefault();
      toggleFullscreen();
    } else if (e.key === 'm' || e.key === 'M') {
      e.preventDefault();
      volumeBtn.click();
    }
  });

  const controlElements = [
    playBtn,
    progress,
    volumeBtn,
    fullBtn,
  ];

  controlElements.forEach((el) => {
    el.addEventListener('mouseenter', () => {
      clearTimeout(controlsTimeout);
      controls.style.opacity = '1';
      controls.style.transform = 'translateY(0)';
      controls.style.pointerEvents = 'auto';
      controlsHidden = false;
    });

    el.addEventListener('mouseleave', () => {
      if (!video.paused) {
        controlsTimeout = setTimeout(() => {
          if (!video.paused && !scrubbing) {
            controls.style.opacity = '0';
            controls.style.transform = 'translateY(10px)';
            controls.style.pointerEvents = 'none';
            controlsHidden = true;
          }
        }, 1000);
      }
    });
  });

  // Keyboard shortcuts
  document.addEventListener('keydown', (e) => {
    if (e.target.matches('input, textarea')) return;

    if (e.code === 'Space') {
      e.preventDefault();
      if (video.paused) video.play();
      else video.pause();
      resetControlsTimer();
    }

    if (e.code === 'KeyF') {
      e.preventDefault();
      toggleFullscreen();
    }

    if (e.code === 'Escape') {
      if (isFullscreen) {
        e.preventDefault();
        exitFullscreen();

      }
    }

    if (e.code === 'KeyM') {
      e.preventDefault();
      video.muted = !video.muted;
      resetControlsTimer();
    }
  });

  function isMobile() {
    return /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(
      navigator.userAgent
    );
  }

  // Init
  connectViewerSocket();
  resetControlsTimer();

  window.onbeforeunload = () => {
    if (statusSocket) {
      statusSocket.onclose = null;
      statusSocket.close();
      statusSocket = null;
    }
    if (pcInstance) {
      pcInstance.close();
      pcInstance = null;
    }
  };
})();
</script>
</body>
</html>
