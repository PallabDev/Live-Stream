<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= stream.title %> | CoWatch Player</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            accent: '#82A3A1',
            'accent-dark': '#465362',
            secondary: '#9FC490',
            'control-bg': 'rgba(18, 22, 26, 0.95)',
          }
        }
      }
    }
  </script>
  <style>
    html, body {
      margin: 0;
      padding: 0;
      width: 100%;
      height: 100%;
      overflow: hidden;
      background: #000000;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    .sh-player {
      width: 100%;
      height: 100dvh;
      background: #000;
      position: relative;
      overflow: hidden;
    }

    .sh-progress-bar {
      background: linear-gradient(90deg, #6366f1, #4f46e5);
    }
  </style>
</head>
<body class="bg-black m-0 p-0 text-white">
  <!-- Full-screen Player Container -->
  <div class="w-screen h-[100dvh] flex items-center justify-center bg-black relative overflow-hidden">
    <div class="sh-player" id="sh-player">
      <video
        class="w-full h-full object-contain bg-black block cursor-pointer"
        id="sh-video"
        preload="auto"
        playsinline
        style="image-rendering: -webkit-optimize-contrast; image-rendering: crisp-edges;"
      ></video>

      <!-- Loading Spinner -->
      <div class="absolute inset-0 flex items-center justify-center z-[5] pointer-events-none" id="sh-loading-wrap" style="display: none;">
        <div class="w-10 h-10 sm:w-[60px] sm:h-[60px] border-4 border-solid border-white/10 border-t-accent rounded-full animate-spin pointer-events-auto"></div>
      </div>

      <!-- Controls Overlay (Commit 94733b7 Style) -->
      <div
        class="absolute left-0 right-0 bottom-0 p-4 sm:p-6 bg-gradient-to-t from-black/95 via-black/70 to-transparent flex flex-col gap-3 transition-opacity duration-200 z-10"
        id="sh-controls"
      >
        <!-- Row 1: Progress & Time -->
        <div class="flex items-center w-full gap-3 min-w-0">
          <span
            class="text-xs sm:text-sm font-medium text-[#aaaaaa] min-w-[42px] sm:min-w-[50px] font-mono tabular-nums"
            id="sh-current-time"
          >
            00:00
          </span>

          <div
            class="sh-progress relative flex-1 h-1.5 sm:h-2 rounded-full bg-[#3a3a3a] cursor-pointer overflow-hidden transition-all duration-150 hover:h-2.5"
            id="sh-progress"
          >
            <div
              class="sh-progress-buffer absolute top-0 left-0 bottom-0 w-0 rounded-full bg-white/20"
              id="sh-progress-buffer"
            ></div>
            <div
              class="sh-progress-bar absolute top-0 left-0 bottom-0 w-0 rounded-full"
              id="sh-progress-bar"
            ></div>
            <div
              class="sh-progress-handle absolute top-1/2 -translate-y-1/2 w-0 h-0 rounded-full bg-white shadow-none transition-all duration-150 pointer-events-none"
              id="sh-progress-handle"
            ></div>
          </div>

          <span
            class="text-xs sm:text-sm font-medium text-[#aaaaaa] min-w-[42px] sm:min-w-[50px] font-mono tabular-nums"
            id="sh-duration"
          >
            LIVE
          </span>
        </div>

        <!-- Row 2: Control Buttons -->
        <div class="flex items-center justify-between w-full">
          <!-- Play / Pause (Left) -->
          <button
            class="sh-play-btn w-9 h-9 sm:w-11 sm:h-11 rounded-full bg-accent text-white flex items-center justify-center text-lg transition-all duration-150 shadow-[0_4px_12px_rgba(99,102,241,0.4)] hover:bg-accent-dark hover:scale-105"
            id="sh-play-btn"
            aria-label="Play/Pause"
            type="button"
          >
            <i class="fas fa-play" id="sh-play-icon"></i>
          </button>

          <!-- Right Action Controls -->
          <div class="sh-controls-right flex items-center gap-1.5 sm:gap-2">
            <!-- Volume Button -->
            <button
              class="sh-btn w-8 h-8 sm:w-10 sm:h-10 bg-transparent text-[#aaaaaa] flex items-center justify-center text-lg p-2 rounded-lg transition-all duration-150 hover:text-white hover:bg-white/10"
              id="sh-volume-btn"
              title="Mute/Unmute"
              type="button"
            >
              <i class="fas fa-volume-up" id="sh-volume-icon"></i>
            </button>

            <!-- Fullscreen -->
            <button
              class="sh-btn sh-full-btn w-8 h-8 sm:w-10 sm:h-10 rounded-lg bg-white/10 flex items-center justify-center text-lg transition-all duration-150 hover:bg-white/20 hover:scale-105"
              id="sh-full-btn"
              title="Fullscreen"
              type="button"
            >
              <i class="fas fa-expand" id="sh-fullscreen-icon"></i>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    (function () {
      const streamKey = "<%= stream.streamKey %>";
      const video = document.getElementById('sh-video');
      const player = document.getElementById('sh-player');
      const playBtn = document.getElementById('sh-play-btn');
      const playIcon = document.getElementById('sh-play-icon');
      const currentTimeEl = document.getElementById('sh-current-time');
      const durationEl = document.getElementById('sh-duration');
      const progress = document.getElementById('sh-progress');
      const progressBar = document.getElementById('sh-progress-bar');
      const progressBuffer = document.getElementById('sh-progress-buffer');
      const volumeBtn = document.getElementById('sh-volume-btn');
      const volumeIcon = document.getElementById('sh-volume-icon');
      const fullBtn = document.getElementById('sh-full-btn');
      const fullscreenIcon = document.getElementById('sh-fullscreen-icon');
      const loadingWrap = document.getElementById('sh-loading-wrap');
      const controls = document.getElementById('sh-controls');

      let hls = null;
      let currentUrl = null;
      let scrubbing = false;
      let controlsTimeout = null;

      function formatTime(seconds) {
        if (isNaN(seconds) || seconds < 0) return '00:00';
        const h = Math.floor(seconds / 3600);
        const m = Math.floor((seconds % 3600) / 60);
        const s = Math.floor(seconds % 60);
        if (h > 0) {
          return `${h.toString().padStart(2, '0')}:${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
        }
        return `${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
      }

      function jumpToLiveEdge() {
        try {
          if (hls && hls.liveSyncPosition) {
            video.currentTime = hls.liveSyncPosition;
            return;
          }
          const b = video.buffered;
          if (b && b.length > 0) {
            const start = b.start(0);
            const end = b.end(b.length - 1);
            if (video.currentTime < start || video.currentTime === 0) {
              video.currentTime = Math.max(end - 1.5, start);
            }
          }
        } catch (_) {}
      }

      // Existing Play Button: One-click Play & Unmute Function
      function playAndUnmute() {
        video.muted = false;
        volumeIcon.className = 'fas fa-volume-up';
        jumpToLiveEdge();
        video.play().then(() => {
          playIcon.className = 'fas fa-pause';
        }).catch((err) => {
          console.warn("Playback error, retrying muted:", err);
          video.muted = true;
          video.play().catch(() => {});
        });
      }

      function togglePlay() {
        if (video.paused) {
          playAndUnmute();
        } else {
          video.pause();
        }
      }

      playBtn.addEventListener('click', togglePlay);
      video.addEventListener('click', (e) => {
        if (e.target === video) togglePlay();
      });

      video.addEventListener('play', () => {
        playIcon.className = 'fas fa-pause';
        resetControlsTimer();
      });

      video.addEventListener('pause', () => {
        playIcon.className = 'fas fa-play';
        resetControlsTimer();
      });

      video.addEventListener('timeupdate', () => {
        if (!video.duration || !isFinite(video.duration)) {
          currentTimeEl.textContent = formatTime(video.currentTime);
          durationEl.textContent = 'LIVE';
          progressBar.style.width = '100%';
          return;
        }
        currentTimeEl.textContent = formatTime(video.currentTime);
        durationEl.textContent = formatTime(video.duration);
        const percent = (video.currentTime / video.duration) * 100;
        progressBar.style.width = percent + '%';
      });

      video.addEventListener('progress', () => {
        if (video.buffered && video.buffered.length > 0) {
          const bufferedEnd = video.buffered.end(video.buffered.length - 1);
          if (video.duration && isFinite(video.duration)) {
            const percent = (bufferedEnd / video.duration) * 100;
            progressBuffer.style.width = percent + '%';
          } else {
            progressBuffer.style.width = '100%';
          }
        }
      });

      video.addEventListener('waiting', () => {
        loadingWrap.style.display = 'flex';
      });

      video.addEventListener('playing', () => {
        loadingWrap.style.display = 'none';
      });

      // Volume control
      volumeBtn.addEventListener('click', () => {
        video.muted = !video.muted;
        volumeIcon.className = video.muted ? 'fas fa-volume-mute' : 'fas fa-volume-up';
        resetControlsTimer();
      });

      // Seek
      function seekByClientX(clientX) {
        const rect = progress.getBoundingClientRect();
        const ratio = Math.min(Math.max(0, clientX - rect.left), rect.width) / rect.width;
        if (video.duration && isFinite(video.duration)) {
          video.currentTime = ratio * video.duration;
        } else if (video.seekable && video.seekable.length > 0) {
          const start = video.seekable.start(0);
          const end = video.seekable.end(video.seekable.length - 1);
          video.currentTime = start + ratio * (end - start);
        }
      }

      progress.addEventListener('mousedown', (e) => {
        scrubbing = true;
        seekByClientX(e.clientX);
        resetControlsTimer();
      });

      window.addEventListener('mousemove', (e) => {
        if (scrubbing) {
          seekByClientX(e.clientX);
          resetControlsTimer();
        }
      });

      window.addEventListener('mouseup', () => {
        scrubbing = false;
        resetControlsTimer();
      });

      progress.addEventListener('click', (e) => {
        seekByClientX(e.clientX);
        resetControlsTimer();
      });

      // Fullscreen
      function toggleFullscreen() {
        if (document.fullscreenElement || document.webkitFullscreenElement) {
          if (document.exitFullscreen) document.exitFullscreen();
          else if (document.webkitExitFullscreen) document.webkitExitFullscreen();
          fullscreenIcon.className = 'fas fa-expand';
        } else {
          if (player.requestFullscreen) player.requestFullscreen();
          else if (player.webkitRequestFullscreen) player.webkitRequestFullscreen();
          fullscreenIcon.className = 'fas fa-compress';
        }
        resetControlsTimer();
      }

      fullBtn.addEventListener('click', toggleFullscreen);

      // Auto-hide controls
      function resetControlsTimer() {
        clearTimeout(controlsTimeout);
        controls.style.opacity = '1';
        controls.style.pointerEvents = 'auto';

        if (!video.paused) {
          controlsTimeout = setTimeout(() => {
            if (!scrubbing && !video.paused) {
              controls.style.opacity = '0';
              controls.style.pointerEvents = 'none';
            }
          }, 3000);
        }
      }

      player.addEventListener('mousemove', resetControlsTimer);

      // Keyboard shortcuts
      window.addEventListener('keydown', (e) => {
        const active = document.activeElement;
        if (active && (active.tagName === 'INPUT' || active.tagName === 'TEXTAREA' || active.isContentEditable)) return;

        if (e.key === ' ' || e.key === 'k' || e.key === 'K') {
          e.preventDefault();
          togglePlay();
        } else if (e.key === 'f' || e.key === 'F') {
          e.preventDefault();
          toggleFullscreen();
        } else if (e.key === 'm' || e.key === 'M') {
          e.preventDefault();
          volumeBtn.click();
        }
      });

      function attachHls(url) {
        if (currentUrl === url && hls) {
          return;
        }

        currentUrl = url;

        if (hls) {
          hls.destroy();
          hls = null;
        }

        if (video.canPlayType('application/vnd.apple.mpegurl')) {
          video.src = url;
          video.addEventListener('loadedmetadata', jumpToLiveEdge, { once: true });
          return;
        }

        if (!window.Hls || !Hls.isSupported()) return;

        hls = new Hls({
          enableWorker: true,
          lowLatencyMode: false,
          liveSyncDurationCount: 3,
          liveMaxLatencyDurationCount: 6,
          maxBufferLength: 30,
          maxMaxBufferLength: 60,
          manifestLoadingMaxRetry: 10,
          levelLoadingMaxRetry: 10,
          fragLoadingMaxRetry: 10,
        });
        hls.loadSource(url);
        hls.attachMedia(video);

        hls.on(Hls.Events.FRAG_BUFFERED, () => {
          if (video.currentTime === 0 && video.buffered.length > 0) {
            jumpToLiveEdge();
          }
        });

        hls.on(Hls.Events.ERROR, (_, data) => {
          if (!data) return;
          if (data.fatal) {
            switch (data.type) {
              case Hls.ErrorTypes.NETWORK_ERROR:
                hls.startLoad(-1);
                break;
              case Hls.ErrorTypes.MEDIA_ERROR:
                hls.recoverMediaError();
                break;
              default:
                break;
            }
          }
        });
      }

      async function checkStatus() {
        try {
          const res = await fetch(`/api/stream/${encodeURIComponent(streamKey)}/playback/status`, { cache: 'no-store' });
          const data = await res.json();
          if (res.ok && data.success && data.data.canPlay && data.data.hlsUrl) {
            attachHls(data.data.hlsUrl);
          }
        } catch (_) {}
      }

      checkStatus();
      setInterval(checkStatus, 4000);
      resetControlsTimer();
    })();
  </script>
</body>
</html>
