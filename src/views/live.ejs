<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title><%= stream.title %> | CoWatch Player</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<link
  rel="stylesheet"
  href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
/>
<script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
<script src="https://cdn.tailwindcss.com"></script>
<script>
tailwind.config = {
  theme: {
    extend: {
      colors: {
        accent: '#6366f1', /* High-Voltage Indigo to match CoWatch brand */
        'accent-dark': '#4f46e5',
        'control-bg': 'rgba(15, 23, 42, 0.95)',
        'glass-bg': 'rgba(30, 41, 59, 0.7)',
        'glass-border': 'rgba(255, 255, 255, 0.08)',
      },
      animation: {
        'spin-slow': 'spin 1s linear infinite',
        'pulse-slow': 'pulse 2s ease-in-out infinite',
      },
      backdropBlur: {
        'glass': '10px',
      },
    }
  }
}
</script>
<style>
:root {
  --progress-bg: #3a3a3a;
  --progress-fill: #6366f1;
  --value: 100%;
}

/* Make page exactly viewport size, no scroll */
html, body {
  margin: 0;
  padding: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
  background: #000000;
}

/* Custom scrollbar for settings */
.sh-settings-list::-webkit-scrollbar {
  width: 6px;
}
.sh-settings-list::-webkit-scrollbar-track {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 3px;
}
.sh-settings-list::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 3px;
}
.sh-settings-list::-webkit-scrollbar-thumb:hover {
  background: rgba(255, 255, 255, 0.3);
}

/* === VERTICAL VOLUME SLIDER === */
.sh-volume-slider {
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Base input reset */
.sh-volume-range {
  -webkit-appearance: none;
  appearance: none;
  writing-mode: bt-lr;           /* vertical */
  -webkit-appearance: slider-vertical;
  width: 12px;                   /* thickness of the track */
  height: 100%;
  padding: 0;
  background: transparent;
  cursor: pointer;
}

/* WebKit track */
.sh-volume-range::-webkit-slider-runnable-track {
  width: 12px;
  height: 100%;
  background: #1e1b4b;
  border-radius: 9999px;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

/* WebKit thumb */
.sh-volume-range::-webkit-slider-thumb {
  -webkit-appearance: none;
  appearance: none;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: #ffffff;
  border: 1px solid #111;
  box-shadow: 0 2px 5px rgba(0, 0, 0, 0.4);
  margin-top: -3px; /* center thumb on track */
}

/* Firefox track */
.sh-volume-range::-moz-range-track {
  width: 12px;
  height: 100%;
  background: #1e1b4b;
  border-radius: 9999px;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

/* Firefox thumb */
.sh-volume-range::-moz-range-thumb {
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: #ffffff;
  border: 1px solid #111;
  box-shadow: 0 2px 5px rgba(0, 0, 0, 0.4);
}

/* Hide ugly focus ring */
.sh-volume-range:focus {
  outline: none;
}

/* Progress bar gradient */
.sh-progress-bar {
  background: linear-gradient(90deg, #6366f1, #4f46e5);
}

/* Player layout centering and aspect ratio constraint */
.sh-player {
  width: 100%;
  max-width: 100%;
  max-height: 100dvh;
  aspect-ratio: 16/9;
  background: #000;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4px 20px rgba(0,0,0,0.8);
  transition: all 0.3s ease;
}

@media (min-width: 1200px) {
  .sh-player {
    max-width: 1200px;
    border-radius: 12px;
  }
}

/* Fullscreen adjustments override */
:fullscreen .sh-player,
:-webkit-full-screen .sh-player,
:-moz-full-screen .sh-player {
  border-radius: 0 !important;
  width: 100vw !important;
  height: 100vh !important;
  max-width: none !important;
  max-height: none !important;
  aspect-ratio: auto !important;
}

#sh-controls {
  padding-bottom: calc(env(safe-area-inset-bottom) + 1.25rem) !important;
}

/* Responsive adjustments for controls */
@media (max-width: 600px) {
  #sh-controls {
    padding: 0.75rem !important;
    padding-bottom: calc(env(safe-area-inset-bottom) + 0.75rem) !important;
    gap: 0.5rem !important;
  }
  .sh-play-btn {
    width: 2.25rem !important;
    height: 2.25rem !important;
  }
  .sh-btn {
    width: 2rem !important;
    height: 2rem !important;
  }
  #sh-current-time, #sh-duration {
    font-size: 0.75rem !important;
    min-width: 36px !important;
  }
}
</style>
</head>
<body class="bg-[#000000] m-0 p-0 font-['Inter',system-ui,sans-serif] text-white">
  <!-- Full-screen container -->
  <div class="w-screen h-[100dvh] flex items-center justify-center bg-black relative overflow-hidden">
    <!-- Player container -->
    <div
      class="sh-player"
      id="sh-player"
    >
      <video
        class="w-full h-full object-contain bg-black block"
        id="sh-video"
        preload="auto"
        playsinline
      ></video>

      <!-- Offline Screen Overlay -->
      <div
        id="offline-screen"
        class="fixed inset-0 bg-[#0f172a] z-50 flex flex-col justify-center items-center text-center p-6"
        style="display: flex;"
      >
        <div class="text-indigo-500 text-6xl mb-4 animate-pulse">
          <i class="fa-solid fa-satellite-dish"></i>
        </div>
        <h3 class="text-2xl font-bold text-white mb-2">Stream is Offline</h3>
        <p class="text-slate-400 text-sm max-w-sm mb-6">
          The broadcaster is not streaming live right now. The feed will automatically play once they start broadcasting.
        </p>
        <button
          class="px-6 py-2.5 rounded-full bg-indigo-600 hover:bg-indigo-500 font-semibold text-sm transition-all hover:scale-105"
          onclick="checkStreamStatus()"
        >
          <i class="fa-solid fa-arrows-rotate mr-1.5"></i> Check Again
        </button>
      </div>

      <!-- Loading Spinner -->
      <div class="absolute inset-0 flex items-center justify-center z-[5] pointer-events-none">
        <div
          class="w-10 h-10 sm:w-[60px] sm:h-[60px] border-4 border-solid border-white/10 border-t-accent rounded-full hidden animate-spin pointer-events-auto"
          id="sh-loading"
        ></div>
      </div>

      <!-- Controls -->
      <div
        class="absolute left-0 right-0 bottom-0 p-4 sm:p-6 bg-gradient-to-t from-black/95 via-black/70 to-transparent flex flex-col gap-3 transition-all duration-150 z-10"
        id="sh-controls"
      >
        <!-- Row 1: Progress & Time -->
        <div class="flex items-center w-full gap-3 min-w-0">
          <span
            class="text-xs sm:text-sm font-medium text-[#aaaaaa] min-w-[42px] sm:min-w-[50px] font-mono tabular-nums"
            id="sh-current-time"
          >
            00:00
          </span>

          <div
            class="sh-progress relative flex-1 h-1.5 sm:h-2 rounded-full bg-[#3a3a3a] cursor-pointer overflow-hidden transition-all duration-150 hover:h-2 sm:hover:h-2.5"
            id="sh-progress"
          >
            <div
              class="sh-progress-buffer absolute top-0 left-0 bottom-0 w-0 rounded-full bg-white/20"
              id="sh-progress-buffer"
            ></div>
            <div
              class="sh-progress-bar absolute top-0 left-0 bottom-0 w-0 rounded-full"
              id="sh-progress-bar"
            ></div>
            <div
              class="sh-progress-handle absolute top-1/2 -translate-y-1/2 w-0 h-0 rounded-full bg-white shadow-none transition-all duration-150 pointer-events-none"
              id="sh-progress-handle"
            ></div>
          </div>

          <span
            class="text-xs sm:text-sm font-medium text-[#aaaaaa] min-w-[42px] sm:min-w-[50px] font-mono tabular-nums"
            id="sh-duration"
          >
            00:00
          </span>
        </div>

        <!-- Row 2: Control Buttons -->
        <div class="flex items-center justify-between w-full">
          <!-- Play / Pause (Left) -->
          <button
            class="sh-play-btn w-9 h-9 sm:w-11 sm:h-11 rounded-full bg-accent text-white flex items-center justify-center text-lg transition-all duration-150 shadow-[0_4px_12px_rgba(99,102,241,0.4)] hover:bg-accent-dark hover:scale-105 hover:shadow-[0_6px_16px_rgba(99,102,241,0.5)]"
            id="sh-play-btn"
            aria-label="Play/Pause"
          >
            <i class="fas fa-play" id="sh-play-icon"></i>
          </button>

          <!-- Right Action Controls -->
          <div class="sh-controls-right flex items-center gap-1.5 sm:gap-2">
            <!-- Volume -->
            <div class="sh-volume-wrap relative flex items-center" id="sh-volume-wrap">
              <button
                class="sh-btn w-8 h-8 sm:w-10 sm:h-10 bg-transparent text-[#aaaaaa] flex items-center justify-center text-lg p-2 rounded-lg transition-all duration-150 hover:text-white hover:bg-white/10 min-w-[32px]"
                id="sh-volume-btn"
                title="Volume"
              >
                <i class="fas fa-volume-up" id="sh-volume-icon"></i>
              </button>
              <div
                class="sh-volume-popup absolute left-1/2 bottom-11 -translate-x-1/2 w-16 sm:w-20 p-3 bg-control-bg backdrop-blur-glass rounded-xl border border-glass-border shadow-[0_4px_20px_rgba(0,0,0,0.8)] opacity-0 pointer-events-none transition-opacity duration-150 flex justify-center z-[100]"
              >
                <div class="sh-volume-slider w-[10px] h-24 sm:h-28 flex justify-center">
                  <input
                    type="range"
                    min="0"
                    max="1"
                    step="0.05"
                    value="1"
                    id="sh-volume-range"
                    class="sh-volume-range"
                  />
                </div>
              </div>
            </div>



            <!-- Fullscreen -->
            <button
              class="sh-btn sh-full-btn w-8 h-8 sm:w-10 sm:h-10 rounded-lg bg-white/10 flex items-center justify-center text-lg transition-all duration-150 hover:bg-white/20 hover:scale-105"
              id="sh-full-btn"
              title="Fullscreen"
            >
              <i class="fas fa-expand" id="sh-fullscreen-icon"></i>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

<script>
(function () {
  // DOM Elements
  const video = document.getElementById('sh-video');
  const player = document.getElementById('sh-player');
  const playBtn = document.getElementById('sh-play-btn');
  const playIcon = document.getElementById('sh-play-icon');
  const currentTimeEl = document.getElementById('sh-current-time');
  const durationEl = document.getElementById('sh-duration');
  const progress = document.getElementById('sh-progress');
  const progressBar = document.getElementById('sh-progress-bar');
  const progressBuffer = document.getElementById('sh-progress-buffer');
  const progressHandle = document.getElementById('sh-progress-handle');
  const volumeWrap = document.getElementById('sh-volume-wrap');
  const volumeBtn = document.getElementById('sh-volume-btn');
  const volumeIcon = document.getElementById('sh-volume-icon');
  const volumeRange = document.getElementById('sh-volume-range');

  const fullBtn = document.getElementById('sh-full-btn');
  const fullscreenIcon = document.getElementById('sh-fullscreen-icon');
  const loadingSpinner = document.getElementById('sh-loading');
  const controls = document.getElementById('sh-controls');
  const offlineScreen = document.getElementById('offline-screen');

  const playlistUrl = "/media/<%= stream.streamKey %>/index.m3u8?_t=" + Date.now();
  const primaryVariantPlaylistUrl = "/media/<%= stream.streamKey %>/index.m3u8";
  const STABLE_LIVE_SEGMENT_LAG = 4;
  const MIN_STARTUP_SEGMENTS = 3;
  const MIN_PLAY_BUFFER_SECONDS = 6;
  const RESUME_PLAY_BUFFER_SECONDS = 4;
  let hlsInstance = null;
  let levels = [];
  let isFullscreen = false;
  let controlsTimeout = null;
  let scrubbing = false;
  let controlsHidden = false;
  let checkInterval = null;
  let segmentDebugInterval = null;
  let waitingForStartupBuffer = false;
  let playbackStarted = false;
  let waitingForPlayBuffer = false;

  let statusSocket = null;
  let bufferCheckInterval = null;

  function startBufferCheck() {
    if (bufferCheckInterval) return;
    console.log('[Live] Starting buffer checker...');
    bufferCheckInterval = setInterval(async () => {
      if (hlsInstance) {
        stopBufferCheck();
        return;
      }
      await initHLSWhenBufferReady();
    }, 2000);
  }

  function stopBufferCheck() {
    if (bufferCheckInterval) {
      console.log('[Live] Stopping buffer checker.');
      clearInterval(bufferCheckInterval);
      bufferCheckInterval = null;
    }
  }

  function connectStatusSocket() {
    const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
    const statusWsUrl = `${protocol}//${window.location.host}/api/stream/<%= stream.streamKey %>/status`;
    
    console.log('[Live] Connecting status WebSocket to:', statusWsUrl);
    statusSocket = new WebSocket(statusWsUrl);

    statusSocket.onmessage = (event) => {
      try {
        const msg = JSON.parse(event.data);
        if (msg.event === 'status') {
          console.log('[Live] Stream status event:', msg.status);
          if (msg.status === 'live') {
            if (offlineScreen.style.display !== 'none') {
              offlineScreen.style.display = 'none';
            }
            if (!hlsInstance) {
              startBufferCheck();
            } else if (playbackStarted && !waitingForPlayBuffer) {
              video.play().catch(e => console.log("Auto play prevented", e));
            }
          } else {
            stopBufferCheck();
            showOffline();
          }
        }
      } catch (err) {
        console.error('[Live] Error parsing status message:', err);
      }
    };

    statusSocket.onclose = () => {
      console.log('[Live] Status WebSocket closed. Reconnecting in 3s...');
      statusSocket = null;
      setTimeout(connectStatusSocket, 3000);
    };

    statusSocket.onerror = (err) => {
      console.error('[Live] Status WebSocket error:', err);
    };
  }

  async function getAvailableSegmentCount() {
    const url = primaryVariantPlaylistUrl + '?_cb=' + Date.now();
    const res = await fetch(url, { cache: 'no-store' });
    if (!res.ok) return 0;

    const playlist = await res.text();
    const matches = playlist.match(/^#EXTINF:/gm);
    return matches ? matches.length : 0;
  }

  function getSegmentNumberFromUrl(url) {
    const match = String(url || '').match(/file(\d+)\.ts/);
    return match ? parseInt(match[1], 10) : null;
  }

  function getBufferAheadSeconds() {
    if (!video.buffered || video.buffered.length === 0) return 0;

    const currentTime = video.currentTime || 0;
    for (let i = 0; i < video.buffered.length; i++) {
      const start = video.buffered.start(i);
      const end = video.buffered.end(i);
      if (currentTime >= start && currentTime <= end) {
        return Math.max(0, end - currentTime);
      }
    }

    return 0;
  }

  function maybeStartPlayback(reason) {
    if (!hlsInstance || playbackStarted) return;

    const bufferAhead = getBufferAheadSeconds();
    if (bufferAhead < MIN_PLAY_BUFFER_SECONDS) {
      waitingForPlayBuffer = true;
      showLoading();
      video.pause();
      console.log('[CoWatch Debug] waiting-for-play-buffer', {
        reason,
        bufferAheadSec: Number(bufferAhead.toFixed(2)),
        requiredSec: MIN_PLAY_BUFFER_SECONDS,
      });
      return;
    }

    waitingForPlayBuffer = false;
    playbackStarted = true;
    hideLoading();
    console.log('[CoWatch Debug] starting-playback', {
      reason,
      bufferAheadSec: Number(bufferAhead.toFixed(2)),
    });
    video.play().catch(e => console.log("Play interrupted", e));
  }

  function maybeResumeAfterStall(reason) {
    if (!playbackStarted || !video.paused) return;

    const bufferAhead = getBufferAheadSeconds();
    if (bufferAhead < RESUME_PLAY_BUFFER_SECONDS) {
      showLoading();
      console.log('[CoWatch Debug] waiting-for-resume-buffer', {
        reason,
        bufferAheadSec: Number(bufferAhead.toFixed(2)),
        requiredSec: RESUME_PLAY_BUFFER_SECONDS,
      });
      return;
    }

    hideLoading();
    console.log('[CoWatch Debug] resuming-playback', {
      reason,
      bufferAheadSec: Number(bufferAhead.toFixed(2)),
    });
    video.play().catch(e => console.log("Resume interrupted", e));
  }

  function getActiveLevelIndex() {
    if (!hlsInstance) return 0;
    if (hlsInstance.currentLevel >= 0) return hlsInstance.currentLevel;
    if (hlsInstance.loadLevel >= 0) return hlsInstance.loadLevel;
    if (hlsInstance.nextLoadLevel >= 0) return hlsInstance.nextLoadLevel;
    return 0;
  }

  function getVariantPlaylistUrl(levelIndex) {
    return "/media/<%= stream.streamKey %>/" + levelIndex + "/index.m3u8";
  }

  async function getPlaylistStats(levelIndex) {
    const url = getVariantPlaylistUrl(levelIndex) + '?_cb=' + Date.now();
    const res = await fetch(url, { cache: 'no-store' });
    if (!res.ok) {
      return { level: levelIndex, ok: false, status: res.status };
    }

    const playlist = await res.text();
    const sequenceMatch = playlist.match(/^#EXT-X-MEDIA-SEQUENCE:(\d+)/m);
    const segmentNumbers = Array.from(playlist.matchAll(/file(\d+)\.ts/g))
      .map((match) => parseInt(match[1], 10))
      .filter((num) => Number.isFinite(num));

    return {
      level: levelIndex,
      ok: true,
      mediaSequence: sequenceMatch ? parseInt(sequenceMatch[1], 10) : null,
      publishedCount: segmentNumbers.length,
      publishedFirst: segmentNumbers.length ? segmentNumbers[0] : null,
      publishedLast: segmentNumbers.length ? segmentNumbers[segmentNumbers.length - 1] : null,
    };
  }

  function startSegmentDebug() {
    stopSegmentDebug();

    segmentDebugInterval = setInterval(async () => {
      if (!hlsInstance) return;

      try {
        const levelIndex = getActiveLevelIndex();
        const stats = await getPlaylistStats(levelIndex);
        const currentFrag = hlsInstance.streamController
          ? hlsInstance.streamController.fragCurrent
          : null;
        const playingSegment = currentFrag
          ? (currentFrag.sn ?? getSegmentNumberFromUrl(currentFrag.url))
          : null;

        console.log('[CoWatch Debug] segment-state', {
          level: levelIndex,
          playing: playingSegment,
          bufferAheadSec: Number(getBufferAheadSeconds().toFixed(2)),
          videoTimeSec: Number((video.currentTime || 0).toFixed(2)),
          publishedFirst: stats.publishedFirst,
          publishedLast: stats.publishedLast,
          publishedCount: stats.publishedCount,
          mediaSequence: stats.mediaSequence,
          playlistOk: stats.ok,
          playlistStatus: stats.status || 200,
        });
      } catch (err) {
        console.warn('[CoWatch Debug] segment-state failed', err);
      }
    }, 2000);
  }

  function stopSegmentDebug() {
    if (segmentDebugInterval) {
      clearInterval(segmentDebugInterval);
      segmentDebugInterval = null;
    }
  }

  async function initHLSWhenBufferReady() {
    if (waitingForStartupBuffer) return;

    waitingForStartupBuffer = true;
    showLoading();

    try {
      const segmentCount = await getAvailableSegmentCount();
      if (!hlsInstance && segmentCount >= MIN_STARTUP_SEGMENTS) {
        initHLS();
      }
    } catch (e) {
      console.warn('Waiting for live buffer before playback:', e);
    } finally {
      waitingForStartupBuffer = false;
    }
  }

  function showOffline() {
    offlineScreen.style.display = 'flex';
    stopSegmentDebug();
    playbackStarted = false;
    waitingForPlayBuffer = false;
    if (hlsInstance) {
      hlsInstance.destroy();
      hlsInstance = null;
    }
  }

  // HLS init
  function initHLS() {
    showLoading();
    if (Hls.isSupported()) {
      hlsInstance = new Hls({
        enableWorker: true,
        lowLatencyMode: true,
        startLevel: 0,
        initialLiveManifestSize: 2,
        capLevelToPlayerSize: true,
        testBandwidth: true,
        autoStartLoad: true,
        startFragPrefetch: true,

        // Low latency buffer settings
        backBufferLength: 10,
        maxBufferLength: 6,
        maxMaxBufferLength: 10,
        maxBufferSize: 15 * 1000 * 1000, // 15MB max buffer
        maxStarvationDelay: 1,

        fragLoadingTimeOut: 4000,
        manifestLoadingTimeOut: 4000,
        levelLoadingTimeOut: 4000,

        liveSyncDurationCount: 2, // Stay 4 seconds behind live edge
        liveMaxLatencyDurationCount: 4, // Allow max 8 seconds latency before seeking
        liveDurationInfinity: true,
        highBufferWatchdogPeriod: 2,

        // Cache-bust every playlist fetch so the browser never replays stale segments
        xhrSetup: function (xhr, url) {
          if (url.indexOf('.m3u8') !== -1) {
            var sep = url.indexOf('?') !== -1 ? '&' : '?';
            xhr.open('GET', url + sep + '_cb=' + Date.now(), true);
          }
        },
      });

      hlsInstance.loadSource(playlistUrl);
      hlsInstance.attachMedia(video);

      hlsInstance.on(Hls.Events.MANIFEST_PARSED, function (event, data) {
        levels = data.levels || [];
        stopBufferCheck();
        startSegmentDebug();
        waitingForPlayBuffer = true;
        showLoading();
        console.log('[CoWatch Debug] manifest-ready-waiting-for-buffer', {
          levels: levels.length,
          requiredBufferSec: MIN_PLAY_BUFFER_SECONDS,
        });
      });

      hlsInstance.on(Hls.Events.FRAG_CHANGED, function (event, data) {
        const frag = data.frag || {};
        console.log('[CoWatch Debug] now-playing-segment', {
          level: frag.level,
          sn: frag.sn,
          segmentFromUrl: getSegmentNumberFromUrl(frag.url),
          durationSec: frag.duration,
          url: frag.url,
          bufferAheadSec: Number(getBufferAheadSeconds().toFixed(2)),
        });
      });

      hlsInstance.on(Hls.Events.FRAG_BUFFERED, function (event, data) {
        const frag = data.frag || {};
        console.log('[CoWatch Debug] buffered-segment', {
          level: frag.level,
          sn: frag.sn,
          segmentFromUrl: getSegmentNumberFromUrl(frag.url),
          durationSec: frag.duration,
          bufferAheadSec: Number(getBufferAheadSeconds().toFixed(2)),
        });
        updateBufferProgress();
        maybeStartPlayback('frag-buffered');
        maybeResumeAfterStall('frag-buffered');
      });

      hlsInstance.on(Hls.Events.ERROR, function (event, data) {
        if (data.fatal) {
          switch (data.type) {
            case Hls.ErrorTypes.NETWORK_ERROR:
              // On a deleted segment, jump to live edge instead of retrying stale media.
              if (data.response && data.response.code === 404) {
                console.warn('Segment 404 - jumping to live edge to resync.');
                hlsInstance.stopLoad();
                hlsInstance.startLoad(-1); // -1 = live edge
              } else {
                console.error('Network error, trying to recover...');
                hlsInstance.nextLoadLevel = 0;
                hlsInstance.startLoad();
              }
              break;
            case Hls.ErrorTypes.MEDIA_ERROR:
              console.error('Media error, recovering...');
              hlsInstance.recoverMediaError();
              break;
            default:
              console.error('Fatal HLS error, cannot recover');
              hlsInstance.destroy();
              hlsInstance = null;
              showOffline();
              break;
          }
        } else if (data.details === Hls.ErrorDetails.FRAG_LOAD_ERROR ||
                   data.details === Hls.ErrorDetails.FRAG_LOAD_TIMEOUT ||
                   data.details === Hls.ErrorDetails.BUFFER_STALLED_ERROR ||
                   data.details === Hls.ErrorDetails.BUFFER_NUDGE_ON_STALL) {
          hlsInstance.currentLevel = -1;
          hlsInstance.nextLoadLevel = 0;
          // Non-fatal 404: still resync to live edge
          if (data.response && data.response.code === 404) {
            console.warn('Non-fatal segment 404 - resyncing to live edge.');
            hlsInstance.stopLoad();
            hlsInstance.startLoad(-1);
          }
        }
      });
    } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
      video.src = playlistUrl;
      video.addEventListener('loadedmetadata', () => {
        hideLoading();
        video.play().catch(e => console.log("Native play prevented", e));
      });
    } else {
      console.warn('HLS not supported in this browser');
      hideLoading();
    }
  }

  function formatTime(sec) {
    if (!sec || !isFinite(sec)) return '00:00';
    const s = Math.floor(sec % 60);
    const m = Math.floor(sec / 60);
    return String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');
  }

  function showLoading() {
    loadingSpinner.style.display = 'block';
  }
  function hideLoading() {
    loadingSpinner.style.display = 'none';
  }

  // Play / pause
  function updatePlayIcon() {
    if (video.paused) {
      playIcon.className = 'fas fa-play';
      playBtn.setAttribute('aria-label', 'Play');
    } else {
      playIcon.className = 'fas fa-pause';
      playBtn.setAttribute('aria-label', 'Pause');
    }
  }

  playBtn.addEventListener('click', () => {
    if (video.paused) {
      video.play();
    } else {
      video.pause();
    }
    resetControlsTimer();
  });

  video.addEventListener('play', updatePlayIcon);
  video.addEventListener('pause', updatePlayIcon);
  video.addEventListener('play', () => {
    if (hlsInstance && !playbackStarted) {
      video.pause();
      maybeStartPlayback('premature-play-event');
    }
  });

  // Time + progress
  video.addEventListener('timeupdate', () => {
    const ct = video.currentTime || 0;
    const dur = video.duration || 0;
    currentTimeEl.textContent = formatTime(ct);

    if (dur > 0) {
      const percent = (ct / dur) * 100;
      progressBar.style.width = percent + '%';
      progressHandle.style.left = percent + '%';
    }
  });

  video.addEventListener('loadedmetadata', () => {
    durationEl.textContent = formatTime(video.duration);
  });

  video.addEventListener('waiting', showLoading);
  video.addEventListener('playing', hideLoading);

  // Buffer progress
  function updateBufferProgress() {
    if (video.buffered && video.buffered.length > 0 && video.duration > 0) {
      const bufferedEnd = video.buffered.end(video.buffered.length - 1);
      const percent = (bufferedEnd / video.duration) * 100;
      progressBuffer.style.width = percent + '%';
    }
  }
  video.addEventListener('progress', updateBufferProgress);

  // Hover handle
  progress.addEventListener('mouseenter', () => {
    progressHandle.style.width = '14px';
    progressHandle.style.height = '14px';
    progressHandle.style.boxShadow = '0 0 0 3px rgba(0, 0, 0, 0.5)';
  });
  progress.addEventListener('mouseleave', () => {
    progressHandle.style.width = '0';
    progressHandle.style.height = '0';
    progressHandle.style.boxShadow = 'none';
  });

  // Seek
  function seekByClientX(clientX) {
    const rect = progress.getBoundingClientRect();
    const ratio =
      Math.min(Math.max(0, clientX - rect.left), rect.width) / rect.width;
    if (video.duration) {
      video.currentTime = ratio * video.duration;
    }
  }

  progress.addEventListener('mousedown', (e) => {
    scrubbing = true;
    seekByClientX(e.clientX);
    resetControlsTimer();
  });

  window.addEventListener('mousemove', (e) => {
    if (scrubbing) {
      seekByClientX(e.clientX);
      resetControlsTimer();
    }
  });

  window.addEventListener('mouseup', () => {
    scrubbing = false;
    resetControlsTimer();
  });

  progress.addEventListener('click', (e) => {
    seekByClientX(e.clientX);
    resetControlsTimer();
  });

  // Volume
  volumeBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    volumeWrap.classList.toggle('open');
    const popup = volumeWrap.querySelector('.sh-volume-popup');
    if (popup) {
      popup.style.opacity = volumeWrap.classList.contains('open') ? '1' : '0';
      popup.style.pointerEvents = volumeWrap.classList.contains('open')
        ? 'auto'
        : 'none';
    }
    resetControlsTimer();
  });

  volumeWrap.addEventListener('click', (e) => e.stopPropagation());

  document.addEventListener('click', () => {
    volumeWrap.classList.remove('open');
    const popup = volumeWrap.querySelector('.sh-volume-popup');
    if (popup) {
      popup.style.opacity = '0';
      popup.style.pointerEvents = 'none';
    }

  });

  volumeRange.addEventListener('input', function () {
    let v = parseFloat(this.value);
    video.volume = v;
    video.muted = v === 0;

    if (v === 0) {
      volumeIcon.className = 'fas fa-volume-mute';
    } else if (v < 0.5) {
      volumeIcon.className = 'fas fa-volume-down';
    } else {
      volumeIcon.className = 'fas fa-volume-up';
    }
    resetControlsTimer();
  });

  // Double click volume icon = mute
  volumeBtn.addEventListener('dblclick', () => {
    video.muted = !video.muted;
    if (video.muted) {
      volumeRange.value = 0;
      volumeIcon.className = 'fas fa-volume-mute';
    } else {
      volumeRange.value = video.volume;
      if (video.volume === 0) {
        volumeIcon.className = 'fas fa-volume-mute';
      } else if (video.volume < 0.5) {
        volumeIcon.className = 'fas fa-volume-down';
      } else {
        volumeIcon.className = 'fas fa-volume-up';
      }
    }
    resetControlsTimer();
  });



  // Fullscreen (works inside iframe; fullscreen is for player element)
  function toggleFullscreen() {
    if (
      document.fullscreenElement ||
      document.webkitFullscreenElement ||
      document.mozFullScreenElement ||
      document.msFullscreenElement
    ) {
      exitFullscreen();
    } else {
      enterFullscreen();
    }
  }

  function enterFullscreen() {
    const element = player;

    if (element.requestFullscreen) {
      element.requestFullscreen();
    } else if (element.mozRequestFullScreen) {
      element.mozRequestFullScreen();
    } else if (element.webkitRequestFullscreen) {
      element.webkitRequestFullscreen(Element.ALLOW_KEYBOARD_INPUT);
    } else if (element.msRequestFullscreen) {
      element.msRequestFullscreen();
    }

    if (isMobile() && screen.orientation && screen.orientation.lock) {
      screen.orientation.lock('landscape').catch(() => {});
    }

    isFullscreen = true;
    fullscreenIcon.className = 'fas fa-compress';
    resetControlsTimer();
  }

  function exitFullscreen() {
    if (document.exitFullscreen) {
      document.exitFullscreen();
    } else if (document.mozCancelFullScreen) {
      document.mozCancelFullScreen();
    } else if (document.webkitExitFullscreen) {
      document.webkitExitFullscreen();
    } else if (document.msExitFullscreen) {
      document.msExitFullscreen();
    }

    if (screen.orientation && screen.orientation.unlock) {
      screen.orientation.unlock();
    }

    isFullscreen = false;
    fullscreenIcon.className = 'fas fa-expand';
    resetControlsTimer();
  }

  fullBtn.addEventListener('click', toggleFullscreen);

  // Fullscreen events
  document.addEventListener('fullscreenchange', handleFullscreenChange);
  document.addEventListener('webkitfullscreenchange', handleFullscreenChange);
  document.addEventListener('mozfullscreenchange', handleFullscreenChange);
  document.addEventListener('MSFullscreenChange', handleFullscreenChange);

  function handleFullscreenChange() {
    isFullscreen = !!(
      document.fullscreenElement ||
      document.webkitFullscreenElement ||
      document.mozFullScreenElement ||
      document.msFullscreenElement
    );

    if (isFullscreen) {
      fullscreenIcon.className = 'fas fa-compress';
      if (isMobile() && screen.orientation && screen.orientation.lock) {
        screen.orientation.lock('landscape').catch(() => {});
      }
    } else {
      fullscreenIcon.className = 'fas fa-expand';
      if (screen.orientation && screen.orientation.unlock) {
        screen.orientation.unlock();
      }
    }
    resetControlsTimer();
  }

  // Auto-hide controls
  function resetControlsTimer() {
    clearTimeout(controlsTimeout);
    controls.style.opacity = '1';
    controls.style.transform = 'translateY(0)';
    controls.style.pointerEvents = 'auto';
    controlsHidden = false;

    if (!video.paused) {
      controlsTimeout = setTimeout(() => {
        if (!scrubbing) {
          controls.style.opacity = '0';
          controls.style.transform = 'translateY(10px)';
          controls.style.pointerEvents = 'none';
          controlsHidden = true;
        }
      }, 3000);
    }
  }

  player.addEventListener('mousemove', () => {
    resetControlsTimer();
  });

  // Tap or click anywhere outside buttons to toggle controls
  player.addEventListener('pointerdown', (e) => {
    if (controls.contains(e.target)) {
      return;
    }
    if (controlsHidden) {
      resetControlsTimer();
    } else {
      clearTimeout(controlsTimeout);
      controls.style.opacity = '0';
      controls.style.transform = 'translateY(10px)';
      controls.style.pointerEvents = 'none';
      controlsHidden = true;
    }
  });

  const controlElements = [
    playBtn,
    progress,
    volumeBtn,
    volumeWrap,
    fullBtn,
  ];

  controlElements.forEach((el) => {
    el.addEventListener('mouseenter', () => {
      clearTimeout(controlsTimeout);
      controls.style.opacity = '1';
      controls.style.transform = 'translateY(0)';
      controls.style.pointerEvents = 'auto';
      controlsHidden = false;
    });

    el.addEventListener('mouseleave', () => {
      if (!video.paused) {
        controlsTimeout = setTimeout(() => {
          if (!video.paused && !scrubbing) {
            controls.style.opacity = '0';
            controls.style.transform = 'translateY(10px)';
            controls.style.pointerEvents = 'none';
            controlsHidden = true;
          }
        }, 1000);
      }
    });
  });

  // Keyboard shortcuts
  document.addEventListener('keydown', (e) => {
    if (e.target.matches('input, textarea')) return;

    if (e.code === 'Space') {
      e.preventDefault();
      if (video.paused) video.play();
      else video.pause();
      resetControlsTimer();
    }

    if (e.code === 'KeyF') {
      e.preventDefault();
      toggleFullscreen();
    }

    if (e.code === 'Escape') {
      if (isFullscreen) {
        e.preventDefault();
        exitFullscreen();

      }
    }

    if (e.code === 'KeyM') {
      e.preventDefault();
      video.muted = !video.muted;
      resetControlsTimer();
    }
  });

  function isMobile() {
    return /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(
      navigator.userAgent
    );
  }

  // Init
  connectStatusSocket();
  resetControlsTimer();

  window.onbeforeunload = () => {
    stopBufferCheck();
    if (statusSocket) {
      statusSocket.onclose = null;
      statusSocket.close();
    }
    if (hlsInstance) hlsInstance.destroy();
  };
})();
</script>
</body>
</html>
