<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= stream.title %> | WebRTC SFU Live Player</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" type="image/png" href="/favicon.png">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <!-- Import Mediasoup Client JS Library for WebRTC SFU Player -->
    <script src="https://cdn.jsdelivr.net/npm/mediasoup-client@3/dist/mediasoup-client.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        html, body {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            background: #000000;
            font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial;
        }

        .animated-pulse {
            animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: .5; }
        }
    </style>
</head>
<body class="bg-black text-white flex flex-col justify-between h-screen w-screen overflow-hidden select-none">

    <!-- Top Header Bar -->
    <header class="absolute top-0 left-0 right-0 z-30 flex items-center justify-between p-4 bg-gradient-to-b from-black/80 to-transparent">
        <div class="flex items-center space-x-3">
            <span id="live-indicator" class="flex items-center space-x-2 px-3 py-1 bg-red-600/80 rounded-full text-xs font-bold uppercase tracking-wider animated-pulse">
                <span class="w-2 h-2 bg-white rounded-circle"></span>
                <span>● LIVE SFU</span>
            </span>
            <h1 class="text-lg font-semibold text-white truncate max-w-md"><%= stream.title %></h1>
        </div>

        <div class="flex items-center space-x-4">
            <div class="flex items-center space-x-2 text-xs text-gray-300 bg-black/40 px-3 py-1.5 rounded-lg border border-white/10">
                <i class="fa-solid fa-users text-blue-400"></i>
                <span>Room Capacity: <strong id="room-limit-text">0 / 5 Max</strong></span>
            </div>
            <div class="flex items-center space-x-2 text-xs text-gray-300 bg-black/40 px-3 py-1.5 rounded-lg border border-white/10">
                <i class="fa-solid fa-bolt text-yellow-400"></i>
                <span>WebRTC SFU (&lt; 0.1s Latency)</span>
            </div>
        </div>
    </header>

    <!-- Main Video Player Stage -->
    <main class="relative w-full h-full flex items-center justify-center bg-black">
        <!-- Unmute Tap Overlay (For Autoplay Audio Policy) -->
        <div id="unmute-overlay" onclick="unmuteStream()" class="absolute inset-0 z-20 flex flex-col items-center justify-center bg-black/60 backdrop-blur-sm cursor-pointer transition-opacity duration-300">
            <div class="w-20 h-20 bg-blue-600 hover:bg-blue-500 rounded-full flex items-center justify-center shadow-2xl mb-4 transform hover:scale-105 transition-all">
                <i class="fa-solid fa-volume-high text-3xl text-white ms-1"></i>
            </div>
            <p class="text-white text-lg font-medium">Click Anywhere to Unmute Sound</p>
            <p class="text-gray-400 text-xs mt-1">High Fidelity WebRTC SFU Audio Stream</p>
        </div>

        <!-- Room Full Overlay Modal (Exceeds 5 users) -->
        <div id="room-full-overlay" class="hidden absolute inset-0 z-40 flex flex-col items-center justify-center bg-black/90 backdrop-blur-md p-6 text-center">
            <div class="w-16 h-16 bg-red-500/20 text-red-500 rounded-full flex items-center justify-center text-3xl mb-4 border border-red-500/40">
                <i class="fa-solid fa-door-closed"></i>
            </div>
            <h2 class="text-2xl font-bold text-white mb-2">Stream Room Full</h2>
            <p class="text-gray-300 max-w-md text-sm mb-6">
                This WebRTC stream has reached its maximum capacity of <strong>5 concurrent viewers</strong> for ultra-high quality delivery. Please wait until a viewer leaves.
            </p>
            <button onclick="window.location.reload()" class="px-6 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium rounded-lg text-sm transition-all shadow-lg">
                <i class="fa-solid fa-rotate-right me-2"></i> Try Rejoining Room
            </button>
        </div>

        <!-- Waiting / Offline Overlay -->
        <div id="offline-overlay" class="hidden absolute inset-0 z-10 flex flex-col items-center justify-center bg-black p-6 text-center">
            <div class="w-16 h-16 bg-gray-800 text-gray-400 rounded-full flex items-center justify-center text-2xl mb-4">
                <i class="fa-solid fa-video-slash"></i>
            </div>
            <h2 class="text-xl font-semibold text-white mb-1">Broadcaster is Offline</h2>
            <p class="text-gray-400 text-xs">Waiting for the broadcaster to start WebRTC stream...</p>
        </div>

        <!-- High Quality Video Element -->
        <video id="remoteVideo" class="w-full h-full object-contain" autoplay playsinline muted></video>
    </main>

    <!-- Mediasoup SFU WebRTC Consumer JavaScript -->
    <script>
        const streamKey = "<%= stream.streamKey %>";
        const viewerId = `viewer_${Math.random().toString(36).substring(2, 9)}`;

        let sfuSocket = null;
        let device = null;
        let recvTransport = null;
        let remoteStream = new MediaStream();

        const remoteVideo = document.getElementById("remoteVideo");
        const unmuteOverlay = document.getElementById("unmute-overlay");
        const roomFullOverlay = document.getElementById("room-full-overlay");
        const offlineOverlay = document.getElementById("offline-overlay");
        const roomLimitText = document.getElementById("room-limit-text");

        /**
         * Unmute player sound on user gesture
         */
        function unmuteStream() {
            remoteVideo.muted = false;
            unmuteOverlay.classList.add("opacity-0", "pointer-events-none");
            setTimeout(() => unmuteOverlay.classList.add("hidden"), 300);
        }

        /**
         * Connect to Mediasoup SFU WebRTC Session
         */
        async function connectMediasoupSFU() {
            console.log(`[Mediasoup Player] Connecting to SFU WebSocket for stream: ${streamKey}`);

            const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
            const wsUrl = `${protocol}//${window.location.host}/api/sfu/ws?streamKey=${encodeURIComponent(streamKey)}&role=viewer&viewerId=${viewerId}`;

            sfuSocket = new WebSocket(wsUrl);

            sfuSocket.onopen = () => {
                console.log("[Mediasoup Player] WebSocket connected! Requesting Router Capabilities...");
                sfuSocket.send(JSON.stringify({ action: "getRouterRtpCapabilities" }));
            };

            sfuSocket.onmessage = async (event) => {
                try {
                    const msg = JSON.parse(event.data);

                    switch (msg.action) {
                        case "routerRtpCapabilities": {
                            // 1. Load Mediasoup Device with Router Capabilities
                            device = new mediasoupClient.Device();
                            await device.load({ routerRtpCapabilities: msg.rtpCapabilities });

                            // 2. Request WebRTC Consumer Transport
                            sfuSocket.send(JSON.stringify({
                                action: "createWebRtcTransport",
                                isBroadcaster: false,
                                viewerId
                            }));
                            break;
                        }

                        case "webRtcTransportCreated": {
                            // 3. Create Receive Transport on Mediasoup Device
                            const { id, iceParameters, iceCandidates, dtlsParameters } = msg.data;
                            recvTransport = device.createRecvTransport({ id, iceParameters, iceCandidates, dtlsParameters });

                            recvTransport.on("connect", ({ dtlsParameters }, callback, errback) => {
                                sfuSocket.send(JSON.stringify({
                                    action: "connectTransport",
                                    transportId: recvTransport.id,
                                    dtlsParameters
                                }));
                                callback();
                            });

                            // 4. Request Audio & Video Consumers from Mediasoup SFU
                            sfuSocket.send(JSON.stringify({
                                action: "consume",
                                viewerId,
                                transportId: recvTransport.id,
                                rtpCapabilities: device.rtpCapabilities
                            }));
                            break;
                        }

                        case "consumed": {
                            // 5. Attach Incoming Audio & Video Tracks to Video Element
                            const consumers = msg.consumers;
                            if (!consumers || consumers.length === 0) {
                                console.warn("[Mediasoup Player] Broadcaster has not published tracks yet.");
                                offlineOverlay.classList.remove("hidden");
                                return;
                            }

                            offlineOverlay.classList.add("hidden");
                            remoteStream = new MediaStream();

                            for (const c of consumers) {
                                const consumer = await recvTransport.consume({
                                    id: c.id,
                                    producerId: c.producerId,
                                    kind: c.kind,
                                    rtpParameters: c.rtpParameters
                                });
                                remoteStream.addTrack(consumer.track);
                            }

                            remoteVideo.srcObject = remoteStream;
                            remoteVideo.play().catch(e => console.warn("Player play error:", e));
                            console.log("[Mediasoup Player] Successfully playing real-time WebRTC SFU Stream (< 0.1s latency)!");
                            break;
                        }

                        case "error": {
                            console.error("[Mediasoup Player Error]:", msg.message);
                            if (msg.message && msg.message.includes("Room limit reached")) {
                                roomFullOverlay.classList.remove("hidden");
                            }
                            break;
                        }
                    }
                } catch (err) {
                    console.error("[Mediasoup Player Exception]:", err);
                }
            };

            sfuSocket.onclose = () => {
                console.log("[Mediasoup Player] WebSocket connection closed.");
            };
        }

        // Initialize Player on DOM Load
        document.addEventListener("DOMContentLoaded", connectMediasoupSFU);
    </script>
</body>
</html>
