<%- include('header') %>

<!-- Self-Hosted Mediasoup Client JS Library -->
<script src="/js/mediasoup-client.min.js"></script>

<!-- Server-passed variables for JS -->
<div id="studio-config" data-stream-key="<%= stream.streamKey %>" data-is-live="<%= stream.isLive %>" style="display: none;"></div>

<div class="studio-container" style="max-width: 1280px; margin: 2rem auto; padding: 0 1.5rem;">
    <div style="display: grid; grid-template-columns: 1fr 340px; gap: 1.5rem;" class="studio-grid">
        
        <!-- Left Column: Main Stream Stage & Controls -->
        <div style="display: flex; flex-direction: column; gap: 1rem;">
            <div class="glass-panel" style="padding: 0; overflow: hidden; display: flex; flex-direction: column;">
                
                <!-- Stage Header -->
                <div style="padding: 1rem 1.5rem; background: rgba(0, 0, 0, 0.4); border-bottom: 1px solid var(--panel-border); display: flex; justify-content: space-between; align-items: center;">
                    <div style="display: flex; align-items: center; gap: 0.75rem;">
                        <span id="live-badge" class="badge" style="background: rgba(255,255,255,0.1); color: var(--text-muted); font-weight: 700; text-transform: uppercase; padding: 0.4rem 0.8rem; letter-spacing: 1px; border-radius: 6px;">
                            Offline
                        </span>
                        <span id="duration-badge" style="display: none; background: rgba(0, 0, 0, 0.6); border: 1px solid var(--panel-border); color: #fff; padding: 0.3rem 0.6rem; border-radius: 6px; font-family: monospace; font-size: 0.9rem;">
                            00:00:00
                        </span>
                    </div>

                    <div id="network-quality-badge" style="display: flex; align-items: center; gap: 0.5rem; background: rgba(0, 0, 0, 0.4); border: 1px solid var(--panel-border); padding: 0.4rem 0.8rem; border-radius: 20px; font-size: 0.85rem; color: var(--text-muted);">
                        <i id="network-quality-icon" class="ti ti-wifi-off"></i>
                        <span id="network-quality-text">Standby</span>
                    </div>
                </div>

                <!-- Video Stage Canvas / Player -->
                <div style="position: relative; width: 100%; min-height: 480px; max-height: 600px; background: #000; display: flex; align-items: center; justify-content: center;">
                    
                    <!-- Media Selection Placeholder -->
                    <div id="preview-placeholder" style="text-align: center; padding: 3rem 1.5rem;">
                        <div style="width: 70px; height: 70px; background: rgba(130, 163, 161, 0.15); color: var(--primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.25rem; font-size: 2rem;">
                            <i class="ti ti-video-plus"></i>
                        </div>
                        <h3 style="color: #fff; font-size: 1.5rem; margin-bottom: 0.5rem;">No Active Media Selected</h3>
                        <p style="color: var(--text-muted); font-size: 0.95rem; max-width: 420px; margin: 0 auto 1.75rem; line-height: 1.5;">
                            Select a local video file or share your screen to begin streaming via WebRTC SFU.
                        </p>
                        
                        <div style="display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap;">
                            <label class="btn btn-primary" style="display: inline-flex; align-items: center; gap: 0.5rem; cursor: pointer; padding: 0.75rem 1.5rem;">
                                <i class="ti ti-movie" style="font-size: 1.2rem;"></i> Choose Video File
                                <input type="file" id="movie-file-input" accept="video/*" style="display: none;">
                            </label>
                            
                            <button id="screenshare-btn" onclick="startScreenShare()" class="btn btn-secondary" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1.5rem;">
                                <i class="ti ti-screen-share" style="font-size: 1.2rem;"></i> Share Screen
                            </button>
                        </div>
                    </div>

                    <!-- Broadcaster Video Preview Player -->
                    <video id="preview-player" style="display: none; width: 100%; height: 100%; object-fit: contain;" playsinline muted></video>
                    
                    <!-- Hidden Audio Player -->
                    <audio id="audio-player" style="display: none;"></audio>
                </div>

                <!-- Footer Control Bar -->
                <div style="padding: 1.25rem 1.5rem; background: rgba(0, 0, 0, 0.4); border-top: 1px solid var(--panel-border); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
                    <div style="display: flex; align-items: center; gap: 1.25rem;">
                        <button id="go-live-btn" onclick="toggleLiveState()" class="btn" style="padding: 0.75rem 1.75rem; font-size: 1.05rem; font-weight: 700; display: inline-flex; align-items: center; gap: 0.5rem; border-radius: 10px; background: #ef4444; color: #fff; border: none; cursor: pointer; transition: all 0.2s ease;">
                            <i class="ti ti-broadcast" style="font-size: 1.3rem;"></i>
                            <span>Go Live</span>
                        </button>

                        <div style="width: 1px; height: 30px; background: var(--panel-border);"></div>
                        <span id="active-source-text" style="color: var(--text-muted); font-size: 0.9rem; font-family: monospace;">Source: None</span>
                    </div>

                    <div style="display: flex; align-items: center; gap: 1.5rem; color: var(--text-muted); font-size: 0.9rem;">
                        <div>
                            <i class="ti ti-users" style="color: var(--primary); margin-right: 0.25rem;"></i>
                            Viewers: <strong id="viewers-count" style="color: #fff; font-family: monospace;">0 / 5 Max</strong>
                        </div>
                        <div>
                            <i class="ti ti-activity" style="color: var(--secondary); margin-right: 0.25rem;"></i>
                            Bitrate: <strong id="upload-speed-val" style="color: #fff; font-family: monospace;">0</strong> Kbps
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Stream Configuration & Room Limits -->
        <div style="display: flex; flex-direction: column; gap: 1rem;">
            <div class="glass-panel" style="padding: 1.5rem;">
                <h3 style="font-size: 1.2rem; color: #fff; margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.5rem;">
                    <i class="ti ti-settings" style="color: var(--primary);"></i> Stream Information
                </h3>

                <div style="margin-bottom: 1.25rem;">
                    <label style="display: block; font-size: 0.8rem; color: var(--text-muted); text-transform: uppercase; margin-bottom: 0.4rem; font-weight: 600;">Stream Key</label>
                    <div style="display: flex; gap: 0.5rem;">
                        <input type="text" id="stream-key-input" class="form-control" value="<%= stream.streamKey %>" readonly style="font-family: monospace; color: #ffffff !important; background: rgba(0, 0, 0, 0.6) !important; border: 1px solid var(--panel-border);">
                        <button class="btn btn-secondary" id="copy-key-btn" title="Copy Stream Key">
                            <i class="ti ti-copy"></i>
                        </button>
                    </div>
                </div>

                <div style="margin-bottom: 1.5rem;">
                    <label style="display: block; font-size: 0.8rem; color: var(--text-muted); text-transform: uppercase; margin-bottom: 0.4rem; font-weight: 600;">Direct Viewer Link</label>
                    <div style="display: flex; gap: 0.5rem;">
                        <input type="text" id="viewer-link-input" class="form-control" value="<%= stream.streamKey %>" readonly style="font-family: monospace; color: #ffffff !important; background: rgba(0, 0, 0, 0.6) !important; border: 1px solid var(--panel-border);">
                        <button class="btn btn-secondary" id="copy-link-btn" title="Copy Link">
                            <i class="ti ti-copy"></i>
                        </button>
                    </div>
                </div>

                <div style="padding: 1rem; background: rgba(245, 158, 11, 0.1); border: 1px solid rgba(245, 158, 11, 0.25); border-radius: var(--radius-md);">
                    <div style="display: flex; align-items: center; gap: 0.5rem; color: #f59e0b; font-weight: 600; font-size: 0.9rem; margin-bottom: 0.4rem;">
                        <i class="ti ti-info-circle"></i> Room Limit Notice
                    </div>
                    <p style="color: var(--text-muted); font-size: 0.85rem; margin: 0; line-height: 1.4;">
                        Mediasoup SFU limits this stream to a maximum of <strong>5 concurrent viewers</strong> for ultra-high quality, sub-second WebRTC delivery.
                    </p>
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    @media (max-width: 992px) {
        .studio-grid {
            grid-template-columns: 1fr !important;
        }
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        // Read configuration from server-rendered dataset
        const studioConfig = document.getElementById("studio-config");
        const streamKey = studioConfig ? studioConfig.dataset.streamKey : "";

        // Populate full direct viewer link in input box
        const viewerLinkInput = document.getElementById("viewer-link-input");
        if (viewerLinkInput && streamKey) {
            viewerLinkInput.value = `${window.location.origin}/live/${streamKey}`;
        }
        // Copy Helper Event Listeners
        document.getElementById("copy-key-btn")?.addEventListener("click", () => {
            const val = document.getElementById("stream-key-input")?.value;
            if (val) navigator.clipboard.writeText(val);
        });
        document.getElementById("copy-link-btn")?.addEventListener("click", () => {
            const link = `${window.location.origin}/live/${streamKey}`;
            navigator.clipboard.writeText(link);
        });

        // UI State Variables
        let isLive = false;
        let isStreaming = false;
        let currentSourceType = null; // 'file' or 'screen'

        // Media Stream & Player References
        let mediaStream = null;
        let durationInterval = null;
        let statsInterval = null;
        let streamStartTime = null;

        // Mediasoup SFU WebRTC Client Variables
        let sfuSocket = null;
        let device = null;
        let sendTransport = null;
        let videoProducer = null;
        let audioProducer = null;

        const movieFileInput = document.getElementById("movie-file-input");
        const previewPlayer = document.getElementById("preview-player");
        const audioPlayer = document.getElementById("audio-player");
        const previewPlaceholder = document.getElementById("preview-placeholder");

        /**
         * Handle Video File Selection
         */
        movieFileInput.addEventListener("change", (e) => {
            const file = e.target.files[0];
            if (!file) return;

            if (isLive) stopMediasoupBroadcaster();
            stopMediaTracks();

            const fileUrl = URL.createObjectURL(file);
            previewPlayer.srcObject = null;
            previewPlayer.src = fileUrl;
            previewPlayer.load();

            audioPlayer.src = fileUrl;
            audioPlayer.load();

            previewPlayer.onplay = () => {
                audioPlayer.currentTime = previewPlayer.currentTime;
                audioPlayer.play().catch(() => {});
            };
            previewPlayer.onpause = () => audioPlayer.pause();
            previewPlayer.onseeked = () => audioPlayer.currentTime = previewPlayer.currentTime;

            currentSourceType = 'file';
            document.getElementById("active-source-text").textContent = `Movie File: ${file.name}`;
            previewPlayer.style.display = "block";
            previewPlaceholder.style.display = "none";
            updateUI();
        });

        /**
         * Handle Screen Sharing Capture
         */
        window.startScreenShare = async function() {
            try {
                if (isLive) stopMediasoupBroadcaster();
                stopMediaTracks();

                const stream = await navigator.mediaDevices.getDisplayMedia({
                    video: { width: { ideal: 1920 }, height: { ideal: 1080 }, frameRate: { ideal: 60 } },
                    audio: true
                });

                mediaStream = stream;
                previewPlayer.src = "";
                previewPlayer.srcObject = stream;
                previewPlayer.play().catch(() => {});

                currentSourceType = 'screen';
                document.getElementById("active-source-text").textContent = "Source: Screen Share";
                previewPlayer.style.display = "block";
                previewPlaceholder.style.display = "none";
                updateUI();
            } catch (err) {
                console.error("[Screen Share Error]:", err);
            }
        };

        /**
         * Stop all active media tracks
         */
        function stopMediaTracks() {
            if (mediaStream) {
                mediaStream.getTracks().forEach(track => track.stop());
                mediaStream = null;
            }
        }

        /**
         * Toggle Live State (Go Live / Stop Live)
         */
        window.toggleLiveState = function() {
            if (isLive) {
                stopMediasoupBroadcaster();
            } else {
                startMediasoupBroadcaster();
            }
        };

        /**
         * Start Mediasoup SFU WebRTC Broadcaster
         */
        async function startMediasoupBroadcaster() {
            if (isLive) return;

            // Prepare MediaStream from active player or screen capture
            if (currentSourceType === 'file') {
                if (previewPlayer.captureStream) {
                    mediaStream = previewPlayer.captureStream();
                } else if (previewPlayer.mozCaptureStream) {
                    mediaStream = previewPlayer.mozCaptureStream();
                }
                previewPlayer.play().catch(() => {});
            }

            if (!mediaStream || mediaStream.getTracks().length === 0) {
                alert("Please select a video file or share your screen first!");
                return;
            }

            console.log(`[Mediasoup Broadcaster] Connecting to SFU WebSocket for stream: ${streamKey}`);

            const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
            const wsUrl = `${protocol}//${window.location.host}/api/sfu/ws?streamKey=${encodeURIComponent(streamKey)}&role=broadcaster`;

            sfuSocket = new WebSocket(wsUrl);

            sfuSocket.onopen = () => {
                console.log("[Mediasoup Broadcaster] WebSocket connected! Requesting Router Capabilities...");
                sfuSocket.send(JSON.stringify({ action: "getRouterRtpCapabilities" }));
            };

            sfuSocket.onmessage = async (event) => {
                try {
                    const msg = JSON.parse(event.data);

                    switch (msg.action) {
                        case "routerRtpCapabilities": {
                            // 1. Load Mediasoup Device with Router Capabilities
                            const clientLib = window.mediasoupClient || window.MediasoupClient || window.mediasoup;
                            if (!clientLib) {
                                alert("Mediasoup client library failed to initialize! Please refresh the page.");
                                return;
                            }
                            device = new clientLib.Device();
                            await device.load({ routerRtpCapabilities: msg.rtpCapabilities });

                            // 2. Request WebRTC Producer Transport
                            sfuSocket.send(JSON.stringify({ action: "createWebRtcTransport", isBroadcaster: true }));
                            break;
                        }

                        case "webRtcTransportCreated": {
                            // 3. Create Send Transport on Mediasoup Device
                            const { id, iceParameters, iceCandidates, dtlsParameters } = msg.data;
                            sendTransport = device.createSendTransport({ id, iceParameters, iceCandidates, dtlsParameters });

                            sendTransport.on("connect", ({ dtlsParameters }, callback, errback) => {
                                sfuSocket.send(JSON.stringify({
                                    action: "connectTransport",
                                    transportId: sendTransport.id,
                                    dtlsParameters
                                }));
                                callback();
                            });

                            sendTransport.on("produce", ({ kind, rtpParameters }, callback, errback) => {
                                sfuSocket.send(JSON.stringify({
                                    action: "produce",
                                    transportId: sendTransport.id,
                                    kind,
                                    rtpParameters
                                }));

                                const onProduced = (ev) => {
                                    const res = JSON.parse(ev.data);
                                    if (res.action === "produced" && res.kind === kind) {
                                        sfuSocket.removeEventListener("message", onProduced);
                                        callback({ id: res.id });
                                    }
                                };
                                sfuSocket.addEventListener("message", onProduced);
                            });

                            // 4. Produce Video & Audio Tracks to Mediasoup SFU
                            const videoTrack = mediaStream.getVideoTracks()[0];
                            const audioTrack = mediaStream.getAudioTracks()[0];

                            if (videoTrack) {
                                videoProducer = await sendTransport.produce({
                                    track: videoTrack,
                                    encodings: [{ maxBitrate: 6000000 }], // 6.0 Mbps High Bitrate
                                    codecOptions: { videoGoogleStartBitrate: 5000 }
                                });
                            }

                            if (audioTrack) {
                                audioProducer = await sendTransport.produce({ track: audioTrack });
                            }

                            isLive = true;
                            isStreaming = true;
                            streamStartTime = Date.now();
                            startDurationTimer();
                            startStatsMonitoring();
                            updateUI();
                            console.log("[Mediasoup Broadcaster] Successfully producing WebRTC SFU stream!");
                            break;
                        }

                        case "error": {
                            alert("SFU Error: " + msg.message);
                            stopMediasoupBroadcaster();
                            break;
                        }
                    }
                } catch (err) {
                    console.error("[Mediasoup Broadcaster Message Exception]:", err);
                }
            };

            sfuSocket.onclose = () => {
                console.log("[Mediasoup Broadcaster] WebSocket closed.");
                stopMediasoupBroadcaster();
            };
        }

        /**
         * Stop Mediasoup SFU Broadcaster Session
         */
        function stopMediasoupBroadcaster() {
            isLive = false;
            isStreaming = false;

            if (videoProducer) { try { videoProducer.close(); } catch (_) {} videoProducer = null; }
            if (audioProducer) { try { audioProducer.close(); } catch (_) {} audioProducer = null; }
            if (sendTransport) { try { sendTransport.close(); } catch (_) {} sendTransport = null; }
            if (sfuSocket) { try { sfuSocket.close(); } catch (_) {} sfuSocket = null; }

            if (durationInterval) { clearInterval(durationInterval); durationInterval = null; }
            if (statsInterval) { clearInterval(statsInterval); statsInterval = null; }

            updateUI();
        }

        /**
         * Start Duration Timer
         */
        function startDurationTimer() {
            const badge = document.getElementById("duration-badge");
            badge.style.display = "inline-flex";

            durationInterval = setInterval(() => {
                const elapsedSec = Math.floor((Date.now() - streamStartTime) / 1000);
                const hrs = String(Math.floor(elapsedSec / 3600)).padStart(2, '0');
                const mins = String(Math.floor((elapsedSec % 3600) / 60)).padStart(2, '0');
                const secs = String(elapsedSec % 60).padStart(2, '0');
                badge.textContent = `${hrs}:${mins}:${secs}`;
            }, 1000);
        }

        /**
         * Monitor Bitrate Stats
         */
        function startStatsMonitoring() {
            let lastBytes = 0;
            let lastTime = Date.now();

            statsInterval = setInterval(async () => {
                if (!sendTransport) return;
                try {
                    const stats = await sendTransport.getStats();
                    let currentBytes = 0;
                    stats.forEach(report => {
                        if (report.type === 'outbound-rtp') {
                            currentBytes += (report.bytesSent || 0);
                        }
                    });

                    const now = Date.now();
                    const deltaSec = (now - lastTime) / 1000;
                    if (deltaSec > 0 && currentBytes >= lastBytes) {
                        const kbps = Math.round(((currentBytes - lastBytes) * 8) / 1024 / deltaSec);
                        document.getElementById("upload-speed-val").textContent = kbps;
                    }
                    lastBytes = currentBytes;
                    lastTime = now;
                } catch (_) {}
            }, 1000);
        }

        /**
         * Update UI Elements
         */
        function updateUI() {
            const liveBadge = document.getElementById("live-badge");
            const goLiveBtn = document.getElementById("go-live-btn");
            const qualityBadge = document.getElementById("network-quality-badge");
            const qualityIcon = document.getElementById("network-quality-icon");
            const qualityText = document.getElementById("network-quality-text");

            if (isLive) {
                liveBadge.style.background = "#ef4444";
                liveBadge.style.color = "#fff";
                liveBadge.textContent = "● LIVE (SFU)";

                goLiveBtn.style.background = "#ef4444";
                goLiveBtn.querySelector("span").textContent = "Stop Stream";

                qualityBadge.style.borderColor = "#10b981";
                qualityBadge.style.color = "#10b981";
                qualityIcon.className = "ti ti-wifi";
                qualityText.textContent = "WebRTC SFU Active";
            } else {
                liveBadge.style.background = "rgba(255,255,255,0.1)";
                liveBadge.style.color = "var(--text-muted)";
                liveBadge.textContent = "Offline";

                goLiveBtn.style.background = "#10b981";
                goLiveBtn.querySelector("span").textContent = "Go Live (WebRTC SFU)";

                qualityBadge.style.borderColor = "var(--panel-border)";
                qualityBadge.style.color = "var(--text-muted)";
                qualityIcon.className = "ti ti-wifi-off";
                qualityText.textContent = "Standby";

                document.getElementById("duration-badge").style.display = "none";
                document.getElementById("upload-speed-val").textContent = "0";
            }
        }
    });
</script>

<%- include('footer') %>
