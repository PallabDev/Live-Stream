<%- include('header') %>

<script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>

<div id="studio-config" data-stream-key="<%= stream.streamKey %>" style="display: none;"></div>

<div class="stream-grid">
  <section class="glass-panel" style="padding: 0; overflow: hidden;">
    <div style="padding: 1rem 1.25rem; border-bottom: 1px solid var(--panel-border); display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap;">
      <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
        <span id="obs-status-badge" class="badge badge-primary">
          <i class="ti ti-antenna-bars-off"></i> Waiting for OBS
        </span>
        <span id="public-status-badge" class="badge badge-primary">
          Public Offline
        </span>
      </div>
      <div style="display: flex; align-items: center; gap: 0.75rem; color: var(--text-muted); font-size: 0.9rem;">
        <i class="ti ti-activity"></i>
        <span>FFmpeg speed: <strong id="pipeline-speed" style="color: #fff; font-family: monospace;">N/A</strong></span>
      </div>
    </div>

    <div class="video-container" style="border-radius: 0; border-left: 0; border-right: 0;">
      <video id="preview-video" class="video-element" controls playsinline muted></video>
      <div id="preview-empty" style="position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 2rem; background: #050505;">
        <i class="ti ti-broadcast" style="font-size: 4rem; color: var(--primary); margin-bottom: 1rem;"></i>
        <h2 style="font-size: 1.5rem; margin-bottom: 0.5rem;">OBS Preview</h2>
        <p id="preview-message" style="color: var(--text-muted); max-width: 520px;">Start streaming from OBS. The preview appears here before viewers can watch.</p>
      </div>
    </div>

    <div style="padding: 1.25rem; display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap; background: rgba(0,0,0,0.22);">
      <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
        <button id="start-preview-btn" class="btn btn-secondary" type="button">
          <i class="ti ti-refresh"></i> Start Preview
        </button>
        <button id="go-live-btn" class="btn btn-primary" type="button" disabled>
          <i class="ti ti-player-play"></i> Go Live
        </button>
        <a id="viewer-link-btn" class="btn btn-secondary" href="/live/<%= stream.streamKey %>" target="_blank" rel="noreferrer">
          <i class="ti ti-external-link"></i> Viewer Link
        </a>
      </div>
      <span id="last-error" style="color: var(--warning); font-size: 0.9rem;"></span>
    </div>
  </section>

  <aside style="display: flex; flex-direction: column; gap: 1rem;">
    <section class="glass-panel">
      <div class="card-header">
        <h3 class="card-title"><i class="ti ti-router" style="color: var(--primary);"></i> OBS Ingest</h3>
      </div>

      <div class="form-group">
        <label class="form-label">RTMP Server</label>
        <div style="display: flex; gap: 0.5rem;">
          <input id="rtmp-server" class="form-input" readonly value="Loading...">
          <button class="btn btn-secondary btn-sm" type="button" onclick="copyField('rtmp-server')" title="Copy RTMP server">
            <i class="ti ti-copy"></i>
          </button>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Stream Key</label>
        <div style="display: flex; gap: 0.5rem;">
          <input id="stream-key" class="form-input" readonly value="<%= stream.streamKey %>">
          <button class="btn btn-secondary btn-sm" type="button" onclick="copyField('stream-key')" title="Copy stream key">
            <i class="ti ti-copy"></i>
          </button>
        </div>
      </div>

      <div style="display: grid; gap: 0.65rem; color: var(--text-muted); font-size: 0.9rem;">
        <div style="display: flex; justify-content: space-between; gap: 1rem;">
          <span>Encoder</span>
          <strong style="color: #fff;">H.264</strong>
        </div>
        <div style="display: flex; justify-content: space-between; gap: 1rem;">
          <span>Audio</span>
          <strong style="color: #fff;">AAC 48 kHz</strong>
        </div>
        <div style="display: flex; justify-content: space-between; gap: 1rem;">
          <span>Keyframe</span>
          <strong style="color: #fff;">2 seconds</strong>
        </div>
        <div style="display: flex; justify-content: space-between; gap: 1rem;">
          <span>Bitrate</span>
          <strong style="color: #fff;">1200-1800 Kbps</strong>
        </div>
      </div>
    </section>

    <section class="glass-panel">
      <div class="card-header">
        <h3 class="card-title"><i class="ti ti-stack-2" style="color: var(--secondary);"></i> Output Ladder</h3>
      </div>
      <div style="display: grid; gap: 0.75rem;">
        <div class="obs-ladder-row">
          <span>720p</span>
          <strong>1.8 Mbps</strong>
        </div>
        <div class="obs-ladder-row">
          <span>480p</span>
          <strong>800 Kbps</strong>
        </div>
      </div>
    </section>
  </aside>
</div>

<style>
  .obs-ladder-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    color: var(--text-muted);
  }

  .obs-ladder-row:last-child {
    border-bottom: 0;
  }

  .obs-ladder-row strong {
    color: #fff;
    font-family: monospace;
    font-size: 0.9rem;
  }
</style>

<script>
  const configEl = document.getElementById('studio-config');
  const streamKey = configEl ? configEl.dataset.streamKey : '';
  const previewVideo = document.getElementById('preview-video');
  const previewEmpty = document.getElementById('preview-empty');
  const previewMessage = document.getElementById('preview-message');
  const obsBadge = document.getElementById('obs-status-badge');
  const publicBadge = document.getElementById('public-status-badge');
  const speedEl = document.getElementById('pipeline-speed');
  const errorEl = document.getElementById('last-error');
  const goLiveBtn = document.getElementById('go-live-btn');
  const startPreviewBtn = document.getElementById('start-preview-btn');
  const rtmpServerInput = document.getElementById('rtmp-server');

  let hls = null;
  let previewAttached = false;
  let previewUrl = null;

  window.copyField = function(id) {
    const el = document.getElementById(id);
    if (!el) return;
    navigator.clipboard.writeText(el.value).then(() => {
      if (window.showToast) window.showToast('Copied to clipboard.', 'success');
    }).catch(() => {
      if (window.showToast) window.showToast('Copy failed.', 'error');
    });
  };

  async function loadIngestDetails() {
    const res = await fetch(`/api/stream/${encodeURIComponent(streamKey)}/ingest`);
    const data = await res.json();
    if (!res.ok || !data.success) throw new Error(data.error || 'Failed to load ingest details.');
    rtmpServerInput.value = data.data.ingest.rtmpServer;
  }

  async function startPreviewPipeline() {
    startPreviewBtn.disabled = true;
    startPreviewBtn.innerHTML = '<i class="ti ti-loader-2"></i> Starting';
    try {
      const res = await fetch(`/api/stream/${encodeURIComponent(streamKey)}/transcoder/start`, { method: 'POST' });
      const data = await res.json();
      if (!res.ok || !data.success) throw new Error(data.error || 'Failed to start preview.');
      if (window.showToast) window.showToast('Preview watcher is running.', 'success');
    } catch (err) {
      if (window.showToast) window.showToast(err.message, 'error');
    } finally {
      startPreviewBtn.disabled = false;
      startPreviewBtn.innerHTML = '<i class="ti ti-refresh"></i> Start Preview';
    }
  }

  async function setPublicLive(shouldLive) {
    goLiveBtn.disabled = true;
    try {
      const endpoint = shouldLive ? 'golive' : 'stop';
      const res = await fetch(`/api/stream/${encodeURIComponent(streamKey)}/${endpoint}`, { method: 'POST' });
      const data = await res.json();
      if (!res.ok || !data.success) throw new Error(data.error || 'Failed to update live state.');
      if (window.showToast) window.showToast(data.message, 'success');
      await refreshStatus();
    } catch (err) {
      if (window.showToast) window.showToast(err.message, 'error');
    } finally {
      goLiveBtn.disabled = false;
    }
  }

  function withCacheBust(url) {
    const separator = url.includes('?') ? '&' : '?';
    return `${url}${separator}v=${Date.now()}`;
  }

  function seekPreviewToLiveEdge() {
    try {
      const ranges = previewVideo.seekable;
      if (ranges && ranges.length > 0) {
        previewVideo.currentTime = Math.max(ranges.end(ranges.length - 1) - 1.5, 0);
      }
    } catch (_) {}
  }

  function attachPreview(url) {
    const freshUrl = withCacheBust(url);
    if (previewAttached && previewUrl === url && hls) {
      hls.startLoad(-1);
      seekPreviewToLiveEdge();
      previewVideo.play().catch(() => {});
      return;
    }
    previewAttached = true;
    previewUrl = url;
    previewEmpty.style.display = 'none';

    if (hls) {
      hls.destroy();
      hls = null;
    }

    if (previewVideo.canPlayType('application/vnd.apple.mpegurl')) {
      previewVideo.src = freshUrl;
      previewVideo.addEventListener('loadedmetadata', seekPreviewToLiveEdge, { once: true });
      previewVideo.play().catch(() => {});
      return;
    }

    if (window.Hls && Hls.isSupported()) {
      hls = new Hls({
        lowLatencyMode: false,
        liveSyncDurationCount: 2,
        liveMaxLatencyDurationCount: 5,
        maxLiveSyncPlaybackRate: 1.5,
        maxBufferLength: 20,
        backBufferLength: 10,
        manifestLoadingMaxRetry: 6,
        levelLoadingMaxRetry: 6,
        fragLoadingMaxRetry: 6,
      });
      hls.loadSource(freshUrl);
      hls.attachMedia(previewVideo);
      hls.on(Hls.Events.MANIFEST_PARSED, () => {
        hls.startLoad(-1);
        seekPreviewToLiveEdge();
        previewVideo.play().catch(() => {});
      });
      hls.on(Hls.Events.LEVEL_UPDATED, seekPreviewToLiveEdge);
      hls.on(Hls.Events.ERROR, (_, data) => {
        if (!data) return;
        if (data.type === Hls.ErrorTypes.NETWORK_ERROR) {
          hls.startLoad(-1);
          return;
        }
        if (data.fatal) {
          previewAttached = false;
          previewUrl = null;
          previewEmpty.style.display = 'flex';
          previewMessage.textContent = 'Preview stalled. Waiting for fresh HLS segments.';
          hls.destroy();
          hls = null;
        }
      });
    }
  }

  function updateBadges(status) {
    speedEl.textContent = status.speed || 'N/A';
    errorEl.textContent = status.lastError || '';

    if (status.isReady) {
      obsBadge.className = 'badge badge-success';
      obsBadge.innerHTML = '<i class="ti ti-point-filled"></i> OBS Preview Ready';
      goLiveBtn.disabled = false;
      attachPreview(status.previewUrl);
    } else if (status.status === 'waiting_for_obs') {
      obsBadge.className = 'badge badge-primary';
      obsBadge.innerHTML = '<i class="ti ti-antenna-bars-off"></i> Waiting for OBS';
      goLiveBtn.disabled = true;
      previewMessage.textContent = 'Start streaming from OBS. The preview appears here before viewers can watch.';
    } else if (status.status === 'failed') {
      obsBadge.className = 'badge badge-danger';
      obsBadge.innerHTML = '<i class="ti ti-alert-triangle"></i> Pipeline Error';
      goLiveBtn.disabled = true;
    } else {
      obsBadge.className = 'badge badge-primary';
      obsBadge.innerHTML = '<i class="ti ti-loader-2"></i> Preview Starting';
      goLiveBtn.disabled = true;
    }

    if (status.isLive) {
      publicBadge.className = 'badge badge-success';
      publicBadge.innerHTML = '<i class="ti ti-world"></i> Public Live';
      goLiveBtn.innerHTML = '<i class="ti ti-player-stop"></i> End Public Live';
      goLiveBtn.disabled = false;
      goLiveBtn.onclick = () => setPublicLive(false);
    } else {
      publicBadge.className = 'badge badge-primary';
      publicBadge.textContent = 'Public Offline';
      goLiveBtn.innerHTML = '<i class="ti ti-player-play"></i> Go Live';
      goLiveBtn.disabled = !status.isReady;
      goLiveBtn.onclick = () => setPublicLive(true);
    }
  }

  async function refreshStatus() {
    const res = await fetch(`/api/stream/${encodeURIComponent(streamKey)}/transcoder/status`);
    const data = await res.json();
    if (!res.ok || !data.success) throw new Error(data.error || 'Failed to load preview status.');
    updateBadges(data.data);
  }

  startPreviewBtn.addEventListener('click', startPreviewPipeline);

  loadIngestDetails()
    .then(startPreviewPipeline)
    .then(refreshStatus)
    .catch((err) => {
      if (window.showToast) window.showToast(err.message, 'error');
    });

  setInterval(() => {
    refreshStatus().catch(() => {});
  }, 3000);
</script>

<%- include('footer') %>
