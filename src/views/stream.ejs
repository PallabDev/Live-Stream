<%- include('header') %>

    <style>
        .hidden-row {
            display: none !important;
        }

        .flex-row-layout {
            display: flex;
            justify-content: space-between;
        }

        @media (max-width: 768px) {
            #preview-placeholder {
                padding: 1rem !important;
            }

            #placeholder-icon {
                width: 50px !important;
                height: 50px !important;
                font-size: 1.5rem !important;
                margin-bottom: 0.75rem !important;
            }

            #placeholder-title {
                font-size: 1.1rem !important;
                margin-bottom: 0.25rem !important;
            }

            #placeholder-text {
                font-size: 0.8rem !important;
                line-height: 1.4 !important;
                max-width: 290px !important;
            }
        }

        /* Permanently hide volume/mute controls on the preview player to prevent accidental unmuting (echo) */
        #preview-player::-webkit-media-controls-mute-button,
        #preview-player::-webkit-media-controls-volume-slider {
            display: none !important;
        }
    </style>

    <!-- Server-passed variables for JS (prevents IDE template parsing warnings) -->
    <div id="studio-config" data-stream-key="<%= stream.streamKey %>" data-is-live="<%= stream.isLive %>"
        style="display: none;">
    </div>



    <div class="stream-grid">
        <!-- Left Side: Streaming Preview and Controls -->
        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
            <div class="glass-panel" style="padding: 1rem;">
                <div class="video-container"
                    style="position: relative; background: #000; border-radius: var(--radius); overflow: hidden; aspect-ratio: 16/9; display: flex; align-items: center; justify-content: center;">

                    <!-- Video Element for local preview and movie playback -->
                    <video id="preview-player" class="video-element" playsinline controls muted
                        style="display: none; width: 100%; height: 100%; object-fit: contain; image-rendering: -webkit-optimize-contrast; image-rendering: crisp-edges;"></video>

                    <!-- Hidden Audio Element for Chrome bug workaround -->
                    <audio id="audio-player" style="display: none;"></audio>

                    <!-- Offline/Ready State Placeholder -->
                    <div id="preview-placeholder"
                        style="display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 2rem; color: var(--text-muted);">
                        <div id="placeholder-icon" class="badge-danger"
                            style="width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2.5rem; margin-bottom: 1.5rem; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.3);">
                            <i class="ti ti-video-off" id="icon-element" style="color: var(--danger);"></i>
                        </div>
                        <h3 id="placeholder-title" style="margin-bottom: 0.5rem; font-size: 1.5rem; color: #fff;">No
                            Media Selected</h3>
                        <p id="placeholder-text" style="max-width: 450px; font-size: 0.95rem; line-height: 1.6;">
                            Select a local movie file using the media source panel, then click <strong>Go Live</strong>
                            to start.
                        </p>
                    </div>

                    <div class="video-overlay"
                        style="position: absolute; top: 1rem; left: 1rem; display: flex; gap: 0.5rem; z-index: 10;">
                        <span id="status-badge" class="badge badge-danger">
                            <i class="ti ti-point-filled"></i> Offline
                        </span>
                        <span id="viewers-badge" class="badge badge-secondary"
                            style="background: rgba(70, 83, 98, 0.85); color: #fff; border: 1px solid rgba(130, 163, 161, 0.3);">
                            <i class="ti ti-users"></i> <span id="viewers-count">0</span> / 5 Viewers
                        </span>
                        <span id="duration-badge" class="badge badge-primary" style="display: none;">
                            00:00:00
                        </span>
                    </div>
                </div>
            </div>

            <!-- Streaming Control Dock -->
            <div style="display: flex; justify-content: center; margin-top: 0.5rem;">
                <div class="control-dock"
                    style="display: flex; gap: 1rem; background: rgba(30, 41, 59, 0.6); border: 1px solid var(--panel-border); padding: 0.75rem 1.5rem; border-radius: 50px; backdrop-filter: blur(10px); align-items: center;">
                    <button id="btn-toggle-live" class="btn btn-primary" onclick="toggleLiveState()" disabled
                        style="border-radius: 30px; padding: 0.6rem 1.5rem; font-size: 0.9rem; font-weight: 600; opacity: 0.5; transition: all 0.2s ease;">
                        <i class="ti ti-player-play" id="toggle-live-icon"></i> <span id="toggle-live-text">Go
                            Live</span>
                    </button>

                    <button id="btn-share" class="btn btn-secondary" onclick="copyViewerLink()" title="Copy Viewer Link"
                        style="border-radius: 50%; width: 40px; height: 40px; padding: 0; display: flex; align-items: center; justify-content: center;">
                        <i class="ti ti-share" style="font-size: 1.2rem;"></i>
                    </button>
                </div>
            </div>
        </div>

        <!-- Right Side: Stream Configuration & Studio Controls -->
        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
            <!-- Media Source Selector -->
            <div class="glass-panel" style="padding: 1.5rem;">
                <div class="card-header"
                    style="margin-bottom: 1.25rem; padding-bottom: 0.5rem; display: flex; align-items: center; gap: 0.5rem; border-bottom: 1px solid rgba(255,255,255,0.05);">
                    <h4 style="font-size: 1.1rem; display: flex; align-items: center; gap: 0.5rem; margin: 0;">
                        <i class="ti ti-device-tv" style="color: var(--primary); font-size: 1.3rem;"></i> Studio Media
                        Source
                    </h4>
                </div>

                <div style="display: flex; flex-direction: column; gap: 1.25rem;">
                    <input type="file" id="movie-file-input"
                        accept="video/*,video/mp4,video/mkv,video/webm,video/x-matroska,video/quicktime"
                        style="display: none;">

                    <!-- Select Movie File Button -->
                    <button id="btn-select-file" class="btn btn-secondary"
                        onclick="document.getElementById('movie-file-input').click()"
                        style="justify-content: flex-start; border-radius: 12px; padding: 0.8rem 1.2rem; width: 100%;">
                        <i class="ti ti-movie" style="font-size: 1.2rem; color: var(--primary);"></i> Select Movie File
                    </button>

                    <!-- Share Screen Button -->
                    <button id="btn-select-screen" class="btn btn-secondary" onclick="startScreenShare()"
                        style="justify-content: flex-start; border-radius: 12px; padding: 0.8rem 1.2rem; width: 100%;">
                        <i class="ti ti-screen-share" style="font-size: 1.2rem; color: var(--secondary);"></i> Share
                        Desktop Screen
                    </button>



                    <!-- Active Source Info -->
                    <div
                        style="background: rgba(15, 23, 42, 0.4); border: 1px solid rgba(255, 255, 255, 0.05); padding: 1rem; border-radius: 12px; margin-top: 0.5rem;">
                        <span
                            style="font-size: 0.75rem; color: var(--text-muted); display: block; margin-bottom: 0.25rem; text-transform: uppercase; letter-spacing: 0.05em;">Current
                            Source</span>
                        <strong id="active-source-text" style="font-size: 0.9rem; color: #fff;">None Selected</strong>
                    </div>

                    <div class="screen-share-tip"
                        style="border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1rem;">
                        <p style="color: var(--text-muted); font-size: 0.8rem; line-height: 1.5; margin: 0;">
                            <i class="ti ti-info-circle" style="color: var(--primary);"></i>
                            <strong>Pro Tip:</strong> When sharing your screen, make sure to check the <strong>"Share
                                system audio"</strong> checkbox in the browser popup to stream the movie sound!
                        </p>
                    </div>
                </div>
            </div>

            <!-- Stream Telemetry & Network Quality Panel -->
            <div class="glass-panel" id="telemetry-panel"
                style="padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem;">
                <div class="card-header"
                    style="padding-bottom: 0.5rem; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid rgba(255,255,255,0.05);">
                    <h4
                        style="font-size: 1.05rem; display: flex; align-items: center; gap: 0.5rem; margin: 0; color: #fff;">
                        <i class="ti ti-activity" style="color: var(--primary); font-size: 1.2rem;"></i> Stream
                        Telemetry
                    </h4>
                </div>

                <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                    <!-- Upload Speed Stat Row -->
                    <div
                        style="display: flex; align-items: center; justify-content: space-between; background: rgba(15, 23, 42, 0.6); padding: 0.85rem 1rem; border-radius: 12px; border: 1px solid rgba(255, 255, 255, 0.05);">
                        <span
                            style="font-size: 0.85rem; color: var(--text-muted); display: flex; align-items: center; gap: 0.5rem;">
                            <i class="ti ti-arrow-up-circle" style="color: #10b981; font-size: 1.2rem;"></i> Host Upload
                            Speed
                        </span>
                        <strong style="font-size: 1.05rem; color: #10b981; font-family: monospace;">
                            <span id="upload-speed-val">0</span> Kbps
                        </strong>
                    </div>

                    <!-- Network Quality Indicator Row -->
                    <div
                        style="display: flex; align-items: center; justify-content: space-between; background: rgba(15, 23, 42, 0.6); padding: 0.85rem 1rem; border-radius: 12px; border: 1px solid rgba(255, 255, 255, 0.05);">
                        <span
                            style="font-size: 0.85rem; color: var(--text-muted); display: flex; align-items: center; gap: 0.5rem;">
                            <i class="ti ti-wifi" id="network-quality-icon"
                                style="color: #10b981; font-size: 1.2rem;"></i> Network Quality
                        </span>
                        <span id="network-quality-badge"
                            style="font-size: 0.85rem; font-weight: 600; padding: 0.2rem 0.6rem; border-radius: 6px; background: rgba(70, 83, 98, 0.2); border: 1px solid rgba(130, 163, 161, 0.3); color: #94a3b8;">
                            <span id="network-quality-text">Standby</span>
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>



    <script>
        // Read config properties initialized by server side (prevents IDE template syntax confusion)
        const studioConfig = document.getElementById("studio-config");
        const streamKey = studioConfig.dataset.streamKey;
        let isLive = false;

        let isStreaming = false; // WebRTC Peer Connection is actively sending data
        let streamStartTime = null;
        let durationInterval = null;

        let pc = null;
        let mediaRecorder = null;
        let mediaSocket = null;
        let captureStream = null;
        let currentSourceType = null; // 'file' or 'screen'
        let mediaStream = null; // Globally stored media track stream reference

        let reconnectTimeout = null;
        let isManuallyStopped = false;

        let audioCtx = null;
        let activeAudioSourceNode = null;
        let activeAudioDestNode = null;
        let mediaElementSource = null;

        const movieFileInput = document.getElementById("movie-file-input");
        const previewPlayer = document.getElementById("preview-player");
        const audioPlayer = document.getElementById("audio-player");
        const previewPlaceholder = document.getElementById("preview-placeholder");

        // Handle local video file selection
        movieFileInput.addEventListener("change", (e) => {
            const file = e.target.files[0];
            if (!file) return;

            // Reset current stream state if active
            if (isStreaming) {
                triggerStopLive();
            }

            // Stop active screen share tracks if any
            stopMediaTracks();

            const fileUrl = URL.createObjectURL(file);
            previewPlayer.srcObject = null;
            previewPlayer.src = fileUrl;
            previewPlayer.load();

            audioPlayer.srcObject = null;
            audioPlayer.src = fileUrl;
            audioPlayer.load();

            // Sync playback state between the two players
            previewPlayer.onplay = () => {
                audioPlayer.currentTime = previewPlayer.currentTime;
                audioPlayer.play().catch(e => console.warn("audioPlayer play error:", e));
            };
            previewPlayer.onpause = () => {
                audioPlayer.pause();
            };
            previewPlayer.onseeked = () => {
                audioPlayer.currentTime = previewPlayer.currentTime;
            };

            // Force previewPlayer to remain muted permanently to prevent broadcaster echo
            previewPlayer.onvolumechange = () => {
                if (!previewPlayer.muted || previewPlayer.volume > 0) {
                    previewPlayer.muted = true;
                    previewPlayer.volume = 0;
                }
            };

            currentSourceType = 'file';
            document.getElementById("active-source-text").textContent = `Movie File: ${file.name}`;

            // Show player preview, hide default state
            previewPlayer.style.display = "block";
            previewPlaceholder.style.display = "none";

            updateUI();
        });

        // Handle local screen sharing
        async function startScreenShare() {
            try {
                if (isStreaming) {
                    triggerStopLive();
                }

                stopMediaTracks();
                if (movieFileInput.value) {
                    movieFileInput.value = "";
                    previewPlayer.src = "";
                    audioPlayer.src = "";
                }

                // Prompt screen capture with native high-resolution video & system audio request
                let stream;
                try {
                    stream = await navigator.mediaDevices.getDisplayMedia({
                        video: {
                            width: { ideal: 1920 },
                            height: { ideal: 1080 },
                            frameRate: { ideal: 30, max: 30 },
                            displaySurface: "monitor"
                        },
                        audio: {
                            echoCancellation: false,
                            noiseSuppression: false,
                            autoGainControl: false,
                            suppressLocalAudioPlayback: false
                        }
                    });
                } catch (e) {
                    stream = await navigator.mediaDevices.getDisplayMedia({
                        video: {
                            width: { ideal: 1920 },
                            height: { ideal: 1080 },
                            frameRate: { ideal: 60, max: 60 }
                        },
                        audio: true
                    });
                }

                const screenVideoTrack = stream.getVideoTracks()[0];
                if (screenVideoTrack) {
                    if ('contentHint' in screenVideoTrack) {
                        screenVideoTrack.contentHint = 'detail';
                    }
                    if (typeof screenVideoTrack.applyConstraints === 'function') {
                        screenVideoTrack.applyConstraints({
                            width: { ideal: 1920 },
                            height: { ideal: 1080 },
                            frameRate: { ideal: 60, max: 60 }
                        }).catch(err => console.warn("[Studio Screen] applyConstraints error:", err));
                    }
                    // Re-enforce 1080p and unscaled parameters when track unmutes or resizes during YouTube video switches
                    screenVideoTrack.onunmute = () => {
                        console.log("[Studio Screen] Screen track unmuted/resized. Re-enforcing 1080p unscaled resolution.");
                        if (typeof screenVideoTrack.applyConstraints === 'function') {
                            screenVideoTrack.applyConstraints({
                                width: { ideal: 1920 },
                                height: { ideal: 1080 },
                                frameRate: { ideal: 60, max: 60 }
                            }).catch(() => { });
                        }
                    };
                    screenVideoTrack.onended = () => {
                        console.log("Screen share track ended by browser controls.");
                        triggerStopLive();
                    };
                }

                captureStream = stream;
                previewPlayer.src = null;
                previewPlayer.srcObject = stream;
                previewPlayer.play().catch(e => console.log("Local preview play error:", e));

                currentSourceType = 'screen';
                document.getElementById("active-source-text").textContent = "Screen Sharing (1080p @ 60 FPS)";

                previewPlayer.style.display = "block";
                previewPlaceholder.style.display = "none";

                updateUI();
            } catch (err) {
                if (window.showToast) window.showToast("Screen sharing cancelled or failed: " + err.message, "error");
            }
        }

        function stopMediaTracks() {
            if (captureStream) {
                captureStream.getTracks().forEach(track => track.stop());
                captureStream = null;
            }
        }

        function updateUI() {
            const btnToggleLive = document.getElementById("btn-toggle-live");
            const toggleLiveIcon = document.getElementById("toggle-live-icon");
            const toggleLiveText = document.getElementById("toggle-live-text");
            const statusBadge = document.getElementById("status-badge");

            if (currentSourceType === 'file' || currentSourceType === 'screen') {
                if (btnToggleLive) {
                    btnToggleLive.disabled = false;
                    btnToggleLive.style.opacity = "1";
                    btnToggleLive.style.cursor = "pointer";
                }
            } else {
                if (btnToggleLive) {
                    btnToggleLive.disabled = true;
                    btnToggleLive.style.opacity = "0.5";
                    btnToggleLive.style.cursor = "not-allowed";
                }
            }

            if (isLive || isStreaming) {
                if (btnToggleLive) {
                    btnToggleLive.className = "btn btn-danger";
                    btnToggleLive.style.background = "var(--danger)";
                    btnToggleLive.style.borderColor = "var(--danger)";
                }
                if (toggleLiveIcon) toggleLiveIcon.className = "ti ti-player-stop-filled";
                if (toggleLiveText) toggleLiveText.textContent = "End Stream";

                if (statusBadge) {
                    statusBadge.className = "badge badge-danger";
                    statusBadge.style.background = "";
                    statusBadge.style.borderColor = "";
                    statusBadge.innerHTML = '<i class="ti ti-point-filled"></i> LIVE';
                }
            } else {
                if (btnToggleLive) {
                    btnToggleLive.className = "btn btn-primary";
                    btnToggleLive.style.background = "";
                    btnToggleLive.style.borderColor = "";
                }
                if (toggleLiveIcon) toggleLiveIcon.className = "ti ti-player-play";
                if (toggleLiveText) toggleLiveText.textContent = "Go Live";

                if (statusBadge) {
                    statusBadge.className = "badge badge-danger";
                    statusBadge.style.background = "";
                    statusBadge.style.borderColor = "";
                    statusBadge.innerHTML = '<i class="ti ti-point-filled"></i> Offline';
                }
            }
        }

        function triggerStopLive() {
            isManuallyStopped = true;
            isLive = false;
            isStreaming = false;

            if (durationInterval) {
                clearInterval(durationInterval);
                durationInterval = null;
            }
            const durationBadge = document.getElementById("duration-badge");
            if (durationBadge) durationBadge.style.display = "none";

            if (reconnectTimeout) {
                clearTimeout(reconnectTimeout);
                reconnectTimeout = null;
            }

            if (mediaSocket) {
                try { mediaSocket.close(); } catch (e) { }
                mediaSocket = null;
            }

            for (const [viewerId, pcInstance] of peerConnections) {
                try { pcInstance.close(); } catch (e) { }
            }
            peerConnections.clear();
            candidateQueues.clear();

            updateUI();
        }

        function reorderVideoCodecs(sdp) {
            let lines = sdp.split('\r\n');
            let mVideoIndex = -1;
            let h264Pts = [];
            let vp9Pts = [];
            let otherPts = [];

            for (let i = 0; i < lines.length; i++) {
                let line = lines[i];
                if (line.startsWith('m=video ')) {
                    mVideoIndex = i;
                }
                if (line.startsWith('a=rtpmap:') && line.includes('video/')) {
                    let match = line.match(/a=rtpmap:(\d+)\s+([^\/]+)/);
                    if (match) {
                        let pt = match[1];
                        let codec = match[2].toUpperCase();

                        if (codec === 'H264') {
                            h264Pts.push(pt);
                        } else if (codec === 'VP9') {
                            vp9Pts.push(pt);
                        } else {
                            otherPts.push(pt);
                        }
                    }
                }
            }

            if (mVideoIndex !== -1) {
                let mLine = lines[mVideoIndex];
                let parts = mLine.split(' ');
                let header = parts.slice(0, 3);
                let payloads = parts.slice(3);

                let preferred = [...h264Pts, ...vp9Pts];
                let remaining = payloads.filter(pt => !preferred.includes(pt));
                let newPayloads = [...preferred, ...remaining];

                lines[mVideoIndex] = header.join(' ') + ' ' + newPayloads.join(' ');
            }

            return lines.join('\r\n');
        }

        function preferHighFidelityAudioAndVideo(sdp) {
            let lines = sdp.split('\r\n');
            let opusPt = null;

            // Dynamically locate the payload type integer for Opus (e.g. 111)
            for (let line of lines) {
                if (line.toLowerCase().includes('opus/48000')) {
                    const match = line.match(/a=rtpmap:(\d+)\s+opus\/48000/i);
                    if (match) {
                        opusPt = match[1];
                        break;
                    }
                }
            }

            let modifiedLines = [];
            let fmtpFound = false;

            for (let i = 0; i < lines.length; i++) {
                let line = lines[i];

                if (opusPt && line.startsWith(`a=fmtp:${opusPt}`)) {
                    fmtpFound = true;
                    line = `a=fmtp:${opusPt} stereo=1;sprop-stereo=1;maxaveragebitrate=256000;maxplaybackrate=48000;usedtx=0`;
                }

                if (line.startsWith('a=fmtp:')) {
                    if (!line.includes('x-google-start-bitrate') && !line.includes('opus')) {
                        line = line + ';x-google-start-bitrate=7500;x-google-min-bitrate=6000;x-google-max-bitrate=8000';
                    }
                }

                if (line.startsWith('m=video')) {
                    modifiedLines.push(line);
                    modifiedLines.push('b=AS:8000');
                    modifiedLines.push('b=TIAS:8000000');
                    modifiedLines.push('a=rtcp-fb:* nack pli');
                    modifiedLines.push('a=rtcp-fb:* nack fir');
                    continue;
                }

                modifiedLines.push(line);
            }

            if (opusPt && !fmtpFound) {
                for (let i = 0; i < modifiedLines.length; i++) {
                    if (modifiedLines[i].startsWith(`a=rtpmap:${opusPt}`)) {
                        modifiedLines.splice(i + 1, 0, `a=fmtp:${opusPt} stereo=1;sprop-stereo=1;maxaveragebitrate=256000;maxplaybackrate=48000;usedtx=0`);
                        break;
                    }
                }
            }

            // Prioritize higher efficiency codecs for good/bad internet performance
            return reorderVideoCodecs(modifiedLines.join('\r\n'));
        }



        function showReconnectingStatus() {
            isLive = false;
            isStreaming = false;

            const statusBadge = document.getElementById("status-badge");
            statusBadge.className = "badge badge-warning";
            statusBadge.style.background = "#eab308";
            statusBadge.style.borderColor = "#eab308";
            statusBadge.innerHTML = '<i class="ti ti-loader animate-spin"></i> Reconnecting...';
        }

        function scheduleBroadcasterReconnect() {
            if (reconnectTimeout) clearTimeout(reconnectTimeout);
            reconnectTimeout = setTimeout(() => {
                console.warn("[Studio] Attempting to reconnect signaling channel...");
                reconnectBroadcaster();
            }, 3000);
        }

        async function reconnectBroadcaster() {
            if (isManuallyStopped) return;
            try {
                const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
                const wsUrl = `${protocol}//${window.location.host}/api/stream/${streamKey}/ws`;

                console.log("[Studio] Reconnecting signaling WebSocket to:", wsUrl);
                mediaSocket = new WebSocket(wsUrl);

                mediaSocket.onopen = () => {
                    console.log("[Studio] Reconnected to signaling channel successfully.");
                    isLive = true;
                    isStreaming = true;
                    updateUI();
                };

                mediaSocket.onmessage = async (event) => {
                    try {
                        const msg = JSON.parse(event.data);
                        const { event: signalEvent, viewerId, sdp, candidate } = msg;

                        if (signalEvent === "viewer-connected" || signalEvent === "viewer-ready") {
                            await createPeerConnection(viewerId);
                        } else if (signalEvent === "viewer-disconnected") {
                            closePeerConnection(viewerId);
                        } else if (signalEvent === "answer") {
                            const pcInstance = peerConnections.get(viewerId);
                            if (pcInstance) {
                                await pcInstance.setRemoteDescription(new RTCSessionDescription(sdp));

                                const queue = candidateQueues.get(viewerId) || [];
                                while (queue.length > 0) {
                                    const cand = queue.shift();
                                    try {
                                        await pcInstance.addIceCandidate(new RTCIceCandidate(cand));
                                    } catch (e) {
                                        console.warn(`[Studio WebRTC] Error adding queued candidate for viewer ${viewerId}:`, e);
                                    }
                                }
                            }
                        } else if (signalEvent === "candidate") {
                            const pcInstance = peerConnections.get(viewerId);
                            if (pcInstance && candidate) {
                                if (!pcInstance.remoteDescription || !pcInstance.remoteDescription.type) {
                                    let queue = candidateQueues.get(viewerId);
                                    if (!queue) {
                                        queue = [];
                                        candidateQueues.set(viewerId, queue);
                                    }
                                    queue.push(candidate);
                                } else {
                                    try {
                                        await pcInstance.addIceCandidate(new RTCIceCandidate(candidate));
                                    } catch (e) {
                                        console.warn(`[Studio WebRTC] Error adding candidate for viewer ${viewerId}:`, e);
                                    }
                                }
                            }
                        }
                    } catch (err) {
                        console.error("[Studio WS Message Exception]:", err);
                    }
                };

                mediaSocket.onclose = (event) => {
                    if (!isManuallyStopped) {
                        showReconnectingStatus();
                        scheduleBroadcasterReconnect();
                    }
                };

                mediaSocket.onerror = (err) => {
                    console.error("[Studio] Reconnect socket error:", err);
                };

            } catch (err) {
                console.warn("[Studio] Reconnect attempt error:", err);
                scheduleBroadcasterReconnect();
            }
        }

        let sfuPeerConnection = null;

        async function publishToMediaMTXSFU() {
            if (sfuPeerConnection) {
                try { sfuPeerConnection.close(); } catch (_) { }
                sfuPeerConnection = null;
            }

            console.log(`[Studio SFU] Initializing WHIP MediaMTX publisher for stream key: ${streamKey}`);
            const turnHost = window.location.hostname;
            const config = {
                iceServers: [
                    { urls: "stun:stun.l.google.com:19302" },
                    { urls: "stun:stun1.l.google.com:19302" },
                    {
                        urls: [`turn:${turnHost}:3478`, `turn:${turnHost}:3478?transport=tcp`],
                        username: "guest",
                        credential: "somepassword"
                    }
                ]
            };

            sfuPeerConnection = new RTCPeerConnection(config);

            if (mediaStream) {
                mediaStream.getTracks().forEach(track => {
                    const sender = sfuPeerConnection.addTrack(track, mediaStream);
                    if (track.kind === 'video') {
                        try {
                            const parameters = sender.getParameters();
                            if (!parameters.encodings) parameters.encodings = [{}];
                            parameters.encodings[0].priority = 'high';
                            parameters.encodings[0].networkPriority = 'high';
                            parameters.encodings[0].maxBitrate = 8000000;
                            parameters.encodings[0].minBitrate = 6000000;
                            parameters.encodings[0].scaleResolutionDownBy = 1.0;
                            sender.setParameters(parameters).catch(() => { });

                            const transceiver = sfuPeerConnection.getTransceivers().find(t => t.sender === sender);
                            if (transceiver) {
                                try { transceiver.degradationPreference = 'maintain-resolution'; } catch (_) { }
                            }
                        } catch (err) {
                            console.warn("[Studio SFU] Transceiver setup error:", err);
                        }
                    }
                });
            }

            sfuPeerConnection.onconnectionstatechange = () => {
                console.log(`[Studio SFU] Connection state: ${sfuPeerConnection.connectionState}`);
                if (sfuPeerConnection.connectionState === 'connected') {
                    console.log("[Studio SFU] Broadcaster connected to MediaMTX SFU server successfully!");
                }
            };

            try {
                let offer = await sfuPeerConnection.createOffer();
                const modifiedSdp = preferHighFidelityAudioAndVideo(offer.sdp);
                offer = new RTCSessionDescription({
                    type: offer.type,
                    sdp: modifiedSdp
                });
                await sfuPeerConnection.setLocalDescription(offer);

                // Wait for STUN/TURN ICE candidate gathering to complete (max 800ms)
                if (sfuPeerConnection.iceGatheringState !== 'complete') {
                    await new Promise(resolve => {
                        const checkState = () => {
                            if (sfuPeerConnection && sfuPeerConnection.iceGatheringState === 'complete') {
                                sfuPeerConnection.removeEventListener('icegatheringstatechange', checkState);
                                resolve();
                            }
                        };
                        sfuPeerConnection.addEventListener('icegatheringstatechange', checkState);
                        setTimeout(resolve, 800);
                    });
                }

                console.log("[Studio SFU] Sending WHIP offer to MediaMTX SFU proxy...");
                const res = await fetch(`/api/sfu/whip/${streamKey}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/sdp' },
                    body: sfuPeerConnection.localDescription ? sfuPeerConnection.localDescription.sdp : offer.sdp
                });

                if (!res.ok) {
                    throw new Error(`MediaMTX SFU WHIP HTTP error ${res.status}`);
                }

                const answerSdp = await res.text();
                await sfuPeerConnection.setRemoteDescription(new RTCSessionDescription({
                    type: 'answer',
                    sdp: answerSdp
                }));

                console.log("[Studio SFU] Successfully established 6.0 Mbps WHIP stream to MediaMTX SFU!");
                startStatsMonitoring();
            } catch (err) {
                console.error("[Studio SFU] MediaMTX WHIP publish error:", err);
                if (window.showToast) window.showToast("Failed to connect to SFU server.", "error");
            }
        }

        let totalWebCodecsBytesSent = 0;
        let webCodecsVideoEncoder = null;
        let webCodecsAudioEncoder = null;
        let videoTrackReader = null;
        let audioTrackReader = null;

        async function startUnifiedWebCodecsBroadcaster() {
            if (!('VideoEncoder' in window) || !('AudioEncoder' in window) || !('MediaStreamTrackProcessor' in window)) {
                console.warn("[WebCodecs] WebCodecs Audio/Video encoders not fully supported in this browser, using WHIP fallback.");
                return false;
            }

            const videoTrack = mediaStream ? mediaStream.getVideoTracks()[0] : null;
            const audioTrack = mediaStream ? mediaStream.getAudioTracks()[0] : null;

            if (!videoTrack) return false;

            console.log("[WebCodecs] Initializing 7.5 Mbps Video CBR + 256 Kbps Audio CBR Encoders...");

            // 1. Configure VideoEncoder (7.5 Mbps High Profile H.264 60FPS CBR)
            try {
                webCodecsVideoEncoder = new VideoEncoder({
                    output: (chunk, metadata) => {
                        if (!mediaSocket || mediaSocket.readyState !== WebSocket.OPEN) return;

                        const chunkData = new Uint8Array(chunk.byteLength);
                        chunk.copyTo(chunkData);

                        const header = new ArrayBuffer(16);
                        const view = new DataView(header);
                        view.setUint32(0, 0x57434F44); // "WCOD" Magic Header
                        view.setUint8(4, chunk.type === 'key' ? 0 : 1); // 0 = Video Keyframe, 1 = Video Delta
                        view.setBigInt64(5, BigInt(chunk.timestamp), false);

                        const payload = new Uint8Array(16 + chunkData.byteLength);
                        payload.set(new Uint8Array(header), 0);
                        payload.set(chunkData, 16);

                        mediaSocket.send(payload.buffer);
                        totalWebCodecsBytesSent += payload.byteLength;
                    },
                    error: (err) => console.error("[WebCodecs VideoEncoder Error]:", err)
                });

                const settings = videoTrack.getSettings();
                const width = settings.width || 1920;
                const height = settings.height || 1080;

                let codecToUse = 'avc1.64002A';
                if (VideoEncoder.isConfigSupported) {
                    const support = await VideoEncoder.isConfigSupported({
                        codec: 'avc1.64002A',
                        width: width,
                        height: height,
                        bitrate: 7500000,
                        framerate: 60
                    });
                    if (!support.supported) codecToUse = 'avc1.4d002a';
                }

                await webCodecsVideoEncoder.configure({
                    codec: codecToUse,
                    width: width,
                    height: height,
                    bitrate: 7500000, // 7.5 Mbps CBR
                    bitrateMode: 'constant', // TRUE HARDWARE CBR
                    framerate: 60,
                    hardwareAcceleration: 'prefer-hardware',
                    latencyMode: 'realtime'
                });

                const videoProcessor = new MediaStreamTrackProcessor({ track: videoTrack });
                videoTrackReader = videoProcessor.readable.getReader();

                let frameCounter = 0;
                (async () => {
                    while (isStreaming && webCodecsVideoEncoder && webCodecsVideoEncoder.state === 'configured') {
                        try {
                            const { value: frame, done } = await videoTrackReader.read();
                            if (done) break;
                            if (frame) {
                                const insertKeyframe = (frameCounter % 60 === 0);
                                webCodecsVideoEncoder.encode(frame, { keyFrame: insertKeyframe });
                                frame.close();
                                frameCounter++;
                            }
                        } catch (e) {
                            console.warn("[WebCodecs Video Frame Read Exception]:", e);
                            break;
                        }
                    }
                })();
            } catch (err) {
                console.error("[WebCodecs Video Init Error]:", err);
            }

            // 2. Configure AudioEncoder (256 Kbps Opus Stereo 48kHz)
            if (audioTrack) {
                try {
                    webCodecsAudioEncoder = new AudioEncoder({
                        output: (chunk, metadata) => {
                            if (!mediaSocket || mediaSocket.readyState !== WebSocket.OPEN) return;

                            const chunkData = new Uint8Array(chunk.byteLength);
                            chunk.copyTo(chunkData);

                            const header = new ArrayBuffer(16);
                            const view = new DataView(header);
                            view.setUint32(0, 0x57434F44); // "WCOD"
                            view.setUint8(4, 2); // 2 = Audio Payload
                            view.setBigInt64(5, BigInt(chunk.timestamp), false);

                            const payload = new Uint8Array(16 + chunkData.byteLength);
                            payload.set(new Uint8Array(header), 0);
                            payload.set(chunkData, 16);

                            mediaSocket.send(payload.buffer);
                            totalWebCodecsBytesSent += payload.byteLength;
                        },
                        error: (err) => console.error("[WebCodecs AudioEncoder Error]:", err)
                    });

                    await webCodecsAudioEncoder.configure({
                        codec: 'opus',
                        sampleRate: 48000,
                        numberOfChannels: 2,
                        bitrate: 256000 // 256 Kbps Studio Stereo Audio
                    });

                    const audioProcessor = new MediaStreamTrackProcessor({ track: audioTrack });
                    audioTrackReader = audioProcessor.readable.getReader();

                    (async () => {
                        while (isStreaming && webCodecsAudioEncoder && webCodecsAudioEncoder.state === 'configured') {
                            try {
                                const { value: audioData, done } = await audioTrackReader.read();
                                if (done) break;
                                if (audioData) {
                                    webCodecsAudioEncoder.encode(audioData);
                                    audioData.close();
                                }
                            } catch (e) {
                                console.warn("[WebCodecs Audio Frame Read Exception]:", e);
                                break;
                            }
                        }
                    })();
                } catch (err) {
                    console.error("[WebCodecs Audio Init Error]:", err);
                }
            }

            console.log("[WebCodecs] Active Unified 7.75 Mbps Hardware CBR Stream Running!");
            return true;
        }

        let statsInterval = null;

        function startStatsMonitoring() {
            if (statsInterval) clearInterval(statsInterval);
            let lastBytesSent = 0;
            let lastTime = Date.now();

            const qualityBadge = document.getElementById("network-quality-badge");

            statsInterval = setInterval(async () => {
                try {
                    let bytesSent = totalWebCodecsBytesSent;

                    if (sfuPeerConnection) {
                        try {
                            const stats = await sfuPeerConnection.getStats();
                            stats.forEach(report => {
                                if (report.type === 'outbound-rtp') {
                                    bytesSent += (report.bytesSent || 0);
                                }
                            });
                        } catch (_) { }
                    }

                    const now = Date.now();
                    const elapsedSec = (now - lastTime) / 1000;
                    if (elapsedSec > 0 && lastBytesSent > 0 && bytesSent >= lastBytesSent) {
                        const txDelta = bytesSent - lastBytesSent;
                        const uploadKbps = Math.round((txDelta * 8) / 1024 / elapsedSec);
                        const uploadMbps = (((txDelta * 8) / 1024 / 1024) / elapsedSec).toFixed(2);

                        const speedVal = document.getElementById("upload-speed-val");
                        if (speedVal) speedVal.textContent = uploadKbps;

                        // Network Quality Indicator
                        const qualityText = document.getElementById("network-quality-text");
                        const qualityIcon = document.getElementById("network-quality-icon");

                        if (qualityBadge) {
                            if (uploadKbps >= 5000) {
                                qualityBadge.style.background = "rgba(16, 185, 129, 0.15)";
                                qualityBadge.style.borderColor = "rgba(16, 185, 129, 0.35)";
                                qualityBadge.style.color = "#10b981";
                                if (qualityIcon) qualityIcon.className = "ti ti-wifi";
                                if (qualityText) qualityText.textContent = "Excellent (1080p 60fps)";
                            } else if (uploadKbps >= 4000) {
                                qualityBadge.style.background = "rgba(245, 158, 11, 0.15)";
                                qualityBadge.style.borderColor = "rgba(245, 158, 11, 0.35)";
                                qualityBadge.style.color = "#f59e0b";
                                if (qualityIcon) qualityIcon.className = "ti ti-wifi-2";
                                if (qualityText) qualityText.textContent = "Good Quality";
                            } else {
                                qualityBadge.style.background = "rgba(239, 68, 68, 0.15)";
                                qualityBadge.style.borderColor = "rgba(239, 68, 68, 0.35)";
                                qualityBadge.style.color = "#ef4444";
                                if (qualityIcon) qualityIcon.className = "ti ti-wifi-0";
                                if (qualityText) qualityText.textContent = "Poor Connection";
                            }
                        }
                    }
                    lastBytesSent = bytesSent;
                    lastTime = now;
                } catch (e) {
                    console.warn("[Studio Stats Error]:", e);
                }
            }, 1000);
        }

        function toggleLiveState() {
            if (audioCtx && audioCtx.state === 'suspended') {
                audioCtx.resume().catch(e => console.warn("AudioContext resume failed:", e));
            }
            if (isStreaming || isLive) {
                triggerStopLive();
            } else {
                triggerGoLive();
            }
        }

        // Clean Studio Control Functions



        async function triggerGoLive() {
            if (isStreaming) return;
            isManuallyStopped = false;

            mediaStream = null;

            // Obtain the media tracks based on selected source type
            if (currentSourceType === 'file') {
                // Keep preview player muted to prevent broadcaster echo. audioPlayer handles the sound.
                previewPlayer.muted = true;
                if (previewPlayer.paused) {
                    try { await previewPlayer.play(); } catch (e) { console.warn("Player play error:", e); }
                }

                let capturedStream;
                if (previewPlayer.captureStream) {
                    capturedStream = previewPlayer.captureStream(30);
                } else if (previewPlayer.mozCaptureStream) {
                    capturedStream = previewPlayer.mozCaptureStream(30);
                } else {
                    console.warn("[Mobile Studio] captureStream not available on video element, using Canvas capture fallback.");
                    const canvas = document.createElement("canvas");
                    canvas.width = previewPlayer.videoWidth || 1280;
                    canvas.height = previewPlayer.videoHeight || 720;
                    const ctx = canvas.getContext("2d");

                    function renderCanvasFrame() {
                        if (isManuallyStopped || currentSourceType !== 'file') return;
                        if (!previewPlayer.paused && !previewPlayer.ended) {
                            if (previewPlayer.videoWidth && canvas.width !== previewPlayer.videoWidth) {
                                canvas.width = previewPlayer.videoWidth;
                                canvas.height = previewPlayer.videoHeight;
                            }
                            ctx.drawImage(previewPlayer, 0, 0, canvas.width, canvas.height);
                        }
                        requestAnimationFrame(renderCanvasFrame);
                    }
                    renderCanvasFrame();
                    capturedStream = canvas.captureStream(30);
                }

                // Keep preview player muted to prevent double-audio echo on the broadcaster side
                previewPlayer.muted = true;

                try {
                    if (!audioCtx) {
                        audioCtx = new (window.AudioContext || window.webkitAudioContext)({ sampleRate: 48000, latencyHint: 'playback' });
                    }
                    if (audioCtx.state === 'suspended') {
                        await audioCtx.resume();
                    }

                    // Native audio extraction: JITTER FREE, perfectly stable!
                    // Extract from the hidden audioPlayer to bypass Chrome's captureStream audio muting bug!
                    if (!mediaElementSource) {
                        mediaElementSource = audioCtx.createMediaElementSource(audioPlayer);
                        // Connect to local destination so broadcaster can still hear the video
                        mediaElementSource.connect(audioCtx.destination);
                    }

                    // Create a FRESH destination node for every new stream.
                    activeAudioDestNode = audioCtx.createMediaStreamDestination();
                    mediaElementSource.connect(activeAudioDestNode);

                    const syncedAudioTrack = activeAudioDestNode.stream.getAudioTracks()[0];
                    const videoTrack = capturedStream.getVideoTracks()[0];

                    mediaStream = new MediaStream();
                    if (videoTrack) mediaStream.addTrack(videoTrack);
                    if (syncedAudioTrack) mediaStream.addTrack(syncedAudioTrack);

                    console.log(`[Studio Audio] Successfully extracted jitter-free native audio and delayed by 250ms for A/V sync.`);
                } catch (e) {
                    console.error("[Studio Audio] Native audio extraction failed:", e);
                    mediaStream = capturedStream;
                }

                if (previewPlayer.paused) {
                    previewPlayer.play().catch(e => console.warn("Player play error:", e));
                }
            } else if (currentSourceType === 'screen') {
                mediaStream = captureStream;
            }

            // Optimize audio and video track configurations
            if (mediaStream) {
                mediaStream.getAudioTracks().forEach(track => {
                    if ('contentHint' in track) {
                        track.contentHint = 'music';
                        console.log("[WebRTC] Set audio track contentHint to 'music' for studio quality audio");
                    }
                    if (typeof track.applyConstraints === 'function') {
                        track.applyConstraints({
                            echoCancellation: false,
                            noiseSuppression: false,
                            autoGainControl: false,
                            channelCount: 2
                        }).catch(err => console.warn("Failed to apply audio constraints:", err));
                    }
                });

                mediaStream.getVideoTracks().forEach(track => {
                    if ('contentHint' in track) {
                        track.contentHint = 'detail';
                        console.log("[WebRTC] Set video track contentHint to 'detail' for maximum 1080p sharpness");
                    }
                    if (typeof track.applyConstraints === 'function') {
                        track.applyConstraints({
                            width: { ideal: 1920 },
                            height: { ideal: 1080 },
                            frameRate: { min: 30, ideal: 30, max: 30 }
                        }).catch(err => console.warn("Failed to apply 1080p constraints:", err));
                    }
                });
            }

            if (!mediaStream || mediaStream.getTracks().length === 0) {
                if (window.showToast) window.showToast("No active media tracks found. Please play the video or start screen sharing first.", "error");
                return;
            }

            try {
                const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
                const wsUrl = `${protocol}//${window.location.host}/api/stream/${streamKey}/ws`;

                console.log("[Studio] Connecting signaling WebSocket to:", wsUrl);
                mediaSocket = new WebSocket(wsUrl);

                mediaSocket.onopen = async () => {
                    console.log("[Studio] Channel established. Publishing stream to MediaMTX SFU...");
                    isLive = true;
                    isStreaming = true;
                    updateUI();

                    streamStartTime = Date.now();
                    document.getElementById("duration-badge").style.display = "inline-flex";
                    if (durationInterval) clearInterval(durationInterval);
                    durationInterval = setInterval(updateDuration, 1000);

                    await publishToMediaMTXSFU();
                };


                mediaSocket.onmessage = async (event) => {
                    try {
                        const msg = JSON.parse(event.data);
                        if (msg.event === "viewer-count") {
                            const countEl = document.getElementById("viewers-count");
                            if (countEl) countEl.textContent = msg.count;
                        } else if (msg.event === "error") {
                            if (window.showToast) window.showToast(msg.error || "Streaming error occurred", "error");
                        }
                    } catch (_) { }
                };

                mediaSocket.onclose = (event) => {
                    console.log("[Studio] Signaling channel closed:", event);
                    if (!isManuallyStopped) {
                        showReconnectingStatus();
                        scheduleBroadcasterReconnect();
                    }
                };

                mediaSocket.onerror = (err) => {
                    console.error("[Studio] Signaling WebSocket error:", err);
                };
            } catch (err) {
                console.error("[Studio] Failed to initialize live stream signaling:", err);
                if (window.showToast) window.showToast("Failed to start live stream session.", "error");
            }
        }

        function updateDuration() {
            if (!streamStartTime) return;
            const totalSecs = Math.floor((Date.now() - streamStartTime) / 1000);
            const hrs = Math.floor(totalSecs / 3600).toString().padStart(2, '0');
            const mins = Math.floor((totalSecs % 3600) / 60).toString().padStart(2, '0');
            const secs = (totalSecs % 60).toString().padStart(2, '0');
            document.getElementById('duration-badge').textContent = `${hrs}:${mins}:${secs}`;
        }

        function copyViewerLink() {
            const link = window.location.origin + "/live/" + streamKey;
            navigator.clipboard.writeText(link).then(() => {
                if (window.showToast) window.showToast("Viewer link copied to clipboard!", "success");
            }).catch(() => {
                if (window.showToast) window.showToast("Failed to copy link.", "error");
            });
        }
    </script>

