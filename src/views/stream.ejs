<%- include('header') %>

    <style>
        .hidden-row {
            display: none !important;
        }

        .flex-row-layout {
            display: flex;
            justify-content: space-between;
        }

        @media (max-width: 768px) {
            #preview-placeholder {
                padding: 1rem !important;
            }
            #placeholder-icon {
                width: 50px !important;
                height: 50px !important;
                font-size: 1.5rem !important;
                margin-bottom: 0.75rem !important;
            }
            #placeholder-title {
                font-size: 1.1rem !important;
                margin-bottom: 0.25rem !important;
            }
            #placeholder-text {
                font-size: 0.8rem !important;
                line-height: 1.4 !important;
                max-width: 290px !important;
            }
        }
    </style>

    <!-- Server-passed variables for JS (prevents IDE template parsing warnings) -->
    <div id="studio-config" data-stream-key="<%= stream.streamKey %>" data-is-live="<%= stream.isLive %>"
        style="display: none;">
    </div>



    <div class="stream-grid">
        <!-- Left Side: Streaming Preview and Controls -->
        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
            <div class="glass-panel" style="padding: 1rem;">
                <div class="video-container"
                    style="position: relative; background: #000; border-radius: var(--radius); overflow: hidden; aspect-ratio: 16/9; display: flex; align-items: center; justify-content: center;">

                    <!-- Video Element for local preview and movie playback -->
                    <video id="preview-player" class="video-element" playsinline controls
                        style="display: none; width: 100%; height: 100%; object-fit: contain;"></video>

                    <!-- Offline/Ready State Placeholder -->
                    <div id="preview-placeholder"
                        style="display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 2rem; color: var(--text-muted);">
                        <div id="placeholder-icon" class="badge-danger"
                            style="width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2.5rem; margin-bottom: 1.5rem; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.3);">
                            <i class="ti ti-video-off" id="icon-element" style="color: var(--danger);"></i>
                        </div>
                        <h3 id="placeholder-title" style="margin-bottom: 0.5rem; font-size: 1.5rem; color: #fff;">No
                            Media Selected</h3>
                        <p id="placeholder-text" style="max-width: 450px; font-size: 0.95rem; line-height: 1.6;">
                            Select a local movie file using the media source panel, then click <strong>Go Live</strong> to start.
                        </p>
                    </div>

                    <div class="video-overlay"
                        style="position: absolute; top: 1rem; left: 1rem; display: flex; gap: 0.5rem; z-index: 10;">
                        <span id="status-badge" class="badge badge-danger">
                            <i class="ti ti-point-filled"></i> Offline
                        </span>
                        <span id="duration-badge" class="badge badge-primary" style="display: none;">
                            00:00:00
                        </span>
                    </div>
                </div>
            </div>

            <!-- Streaming Control Dock -->
            <div style="display: flex; justify-content: center; margin-top: 0.5rem;">
                <div class="control-dock"
                    style="display: flex; gap: 1rem; background: rgba(30, 41, 59, 0.6); border: 1px solid var(--panel-border); padding: 0.75rem 1.5rem; border-radius: 50px; backdrop-filter: blur(10px); align-items: center;">
                    <button id="btn-toggle-live" class="btn btn-primary" onclick="toggleLiveState()" disabled
                        style="border-radius: 30px; padding: 0.6rem 1.5rem; font-size: 0.9rem; font-weight: 600; opacity: 0.5; transition: all 0.2s ease;">
                        <i class="ti ti-player-play" id="toggle-live-icon"></i> <span id="toggle-live-text">Go Live</span>
                    </button>

                    <button id="btn-share" class="btn btn-secondary" onclick="copyViewerLink()" title="Copy Viewer Link"
                        style="border-radius: 50%; width: 40px; height: 40px; padding: 0; display: flex; align-items: center; justify-content: center;">
                        <i class="ti ti-share" style="font-size: 1.2rem;"></i>
                    </button>
                </div>
            </div>
        </div>

        <!-- Right Side: Stream Configuration & Studio Controls -->
        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
            <!-- Media Source Selector -->
            <div class="glass-panel" style="padding: 1.5rem;">
                <div class="card-header"
                    style="margin-bottom: 1.25rem; padding-bottom: 0.5rem; display: flex; align-items: center; gap: 0.5rem; border-bottom: 1px solid rgba(255,255,255,0.05);">
                    <h4 style="font-size: 1.1rem; display: flex; align-items: center; gap: 0.5rem; margin: 0;">
                        <i class="ti ti-device-tv" style="color: var(--primary); font-size: 1.3rem;"></i> Studio Media
                        Source
                    </h4>
                </div>

                <div style="display: flex; flex-direction: column; gap: 1.25rem;">
                    <input type="file" id="movie-file-input" accept="video/*,video/mp4,video/mkv,video/webm,video/x-matroska,video/quicktime" style="display: none;">

                    <!-- Select Movie File Button -->
                    <button id="btn-select-file" class="btn btn-secondary"
                        onclick="document.getElementById('movie-file-input').click()"
                        style="justify-content: flex-start; border-radius: 12px; padding: 0.8rem 1.2rem; width: 100%;">
                        <i class="ti ti-movie" style="font-size: 1.2rem; color: var(--primary);"></i> Select Movie File
                    </button>

                    <!-- Share Screen Button -->
                    <button id="btn-select-screen" class="btn btn-secondary" onclick="startScreenShare()"
                        style="justify-content: flex-start; border-radius: 12px; padding: 0.8rem 1.2rem; width: 100%;">
                        <i class="ti ti-screen-share" style="font-size: 1.2rem; color: var(--secondary);"></i> Share
                        Desktop Screen
                    </button>



                    <!-- Active Source Info -->
                    <div
                        style="background: rgba(15, 23, 42, 0.4); border: 1px solid rgba(255, 255, 255, 0.05); padding: 1rem; border-radius: 12px; margin-top: 0.5rem;">
                        <span
                            style="font-size: 0.75rem; color: var(--text-muted); display: block; margin-bottom: 0.25rem; text-transform: uppercase; letter-spacing: 0.05em;">Current
                            Source</span>
                        <strong id="active-source-text" style="font-size: 0.9rem; color: #fff;">None Selected</strong>
                    </div>

                    <div class="screen-share-tip" style="border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1rem;">
                        <p style="color: var(--text-muted); font-size: 0.8rem; line-height: 1.5; margin: 0;">
                            <i class="ti ti-info-circle" style="color: var(--primary);"></i>
                            <strong>Pro Tip:</strong> When sharing your screen, make sure to check the <strong>"Share
                                system audio"</strong> checkbox in the browser popup to stream the movie sound!
                        </p>
                    </div>
                </div>
            </div>


        </div>
    </div>



    <script>
        // Read config properties initialized by server side (prevents IDE template syntax confusion)
        const studioConfig = document.getElementById("studio-config");
        const streamKey = studioConfig.dataset.streamKey;
        let isLive = false;

        let isStreaming = false; // WebRTC Peer Connection is actively sending data
        let streamStartTime = null;
        let durationInterval = null;

        let pc = null;
        let mediaRecorder = null;
        let mediaSocket = null;
        let captureStream = null;
        let currentSourceType = null; // 'file' or 'screen'
        let mediaStream = null; // Globally stored media track stream reference

        let reconnectTimeout = null;
        let isManuallyStopped = false;

        let audioCtx = null;
        let activeAudioSourceNode = null;
        let activeAudioDestNode = null;

        const peerConnections = new Map(); // viewerId -> RTCPeerConnection
        const candidateQueues = new Map(); // viewerId -> Array of candidate objects

        const movieFileInput = document.getElementById("movie-file-input");
        const previewPlayer = document.getElementById("preview-player");
        const previewPlaceholder = document.getElementById("preview-placeholder");

        // Handle local video file selection
        movieFileInput.addEventListener("change", (e) => {
            const file = e.target.files[0];
            if (!file) return;

            // Reset current stream state if active
            if (isStreaming) {
                triggerStopLive();
            }

            // Stop active screen share tracks if any
            stopMediaTracks();

            const fileUrl = URL.createObjectURL(file);
            previewPlayer.srcObject = null;
            previewPlayer.src = fileUrl;
            previewPlayer.load();

            currentSourceType = 'file';
            document.getElementById("active-source-text").textContent = `Movie File: ${file.name}`;

            // Show player preview, hide default state
            previewPlayer.style.display = "block";
            previewPlaceholder.style.display = "none";

            updateUI();
        });

        // Handle local screen sharing
        async function startScreenShare() {
            try {
                if (isStreaming) {
                    triggerStopLive();
                }

                stopMediaTracks();
                if (movieFileInput.value) {
                    movieFileInput.value = "";
                    previewPlayer.src = "";
                }

                // Prompt screen capture with system audio request
                const stream = await navigator.mediaDevices.getDisplayMedia({
                    video: {
                        width: { ideal: 1280, max: 1280 },
                        height: { ideal: 720, max: 720 },
                        frameRate: { ideal: 30, max: 30 }
                    },
                    audio: {
                        echoCancellation: false,
                        noiseSuppression: false,
                        autoGainControl: false,
                        channelCount: 2
                    }
                });

                captureStream = stream;
                previewPlayer.src = null;
                previewPlayer.srcObject = stream;
                previewPlayer.play().catch(e => console.log("Local preview play error:", e));

                currentSourceType = 'screen';
                document.getElementById("active-source-text").textContent = "Screen Sharing (with system audio)";

                previewPlayer.style.display = "block";
                previewPlaceholder.style.display = "none";

                // Listen for the browser's native "Stop Sharing" button click
                const videoTrack = stream.getVideoTracks()[0];
                if (videoTrack) {
                    videoTrack.onended = () => {
                        console.log("Screen share track ended by browser controls.");
                        triggerStopLive();
                    };
                }

                updateUI();
            } catch (err) {
                alert("Screen sharing cancelled or failed: " + err.message);
            }
        }

        function stopMediaTracks() {
            if (captureStream) {
                captureStream.getTracks().forEach(track => track.stop());
                captureStream = null;
            }
        }

        function reorderVideoCodecs(sdp) {
            let lines = sdp.split('\r\n');
            let mVideoIndex = -1;
            let h264HighPts = [];
            let vp9Pts = [];
            let otherPts = [];

            for (let i = 0; i < lines.length; i++) {
                let line = lines[i];
                if (line.startsWith('m=video ')) {
                    mVideoIndex = i;
                }
                if (line.startsWith('a=rtpmap:') && line.includes('video/')) {
                    let match = line.match(/a=rtpmap:(\d+)\s+([^\/]+)/);
                    if (match) {
                        let pt = match[1];
                        let codec = match[2].toUpperCase();
                        
                        let isHighProfile = false;
                        for (let j = 0; j < lines.length; j++) {
                            if (lines[j].startsWith(`a=fmtp:${pt} `) && lines[j].includes('profile-level-id=6400')) {
                                isHighProfile = true;
                                break;
                            }
                        }

                        if (codec === 'VP9') {
                            vp9Pts.push(pt);
                        } else if (codec === 'H264' && isHighProfile) {
                            h264HighPts.push(pt);
                        } else {
                            otherPts.push(pt);
                        }
                    }
                }
            }

            if (mVideoIndex !== -1) {
                let mLine = lines[mVideoIndex];
                let parts = mLine.split(' ');
                let header = parts.slice(0, 3);
                let payloads = parts.slice(3);

                let preferred = [...vp9Pts, ...h264HighPts];
                let remaining = payloads.filter(pt => !preferred.includes(pt));
                let newPayloads = [...preferred, ...remaining];

                lines[mVideoIndex] = header.join(' ') + ' ' + newPayloads.join(' ');
            }

            return lines.join('\r\n');
        }

        function preferHighFidelityAudioAndVideo(sdp) {
            let lines = sdp.split('\r\n');
            let modifiedLines = [];
            let inVideoSection = false;

            for (let i = 0; i < lines.length; i++) {
                let line = lines[i];

                if (line.startsWith('a=fmtp:') && line.includes('stereo=1')) {
                    line = line + ';maxaveragebitrate=256000;sprop-stereo=1';
                }

                if (line.startsWith('m=video')) {
                    inVideoSection = true;
                    modifiedLines.push(line);
                    modifiedLines.push('b=AS:15000');
                    modifiedLines.push('b=TIAS:15000000');
                    continue;
                } else if (line.startsWith('m=audio')) {
                    inVideoSection = false;
                }

                modifiedLines.push(line);
            }
            
            // Prioritize higher efficiency codecs for good/bad internet performance
            return reorderVideoCodecs(modifiedLines.join('\r\n'));
        }

        function getDownmixedAudioStream(rawAudioStream) {
            try {
                if (!audioCtx || audioCtx.state === 'closed') {
                    const AudioContextClass = window.AudioContext || window.webkitAudioContext;
                    // Use 'playback' latency hint to buffer media decoding clock drift and eliminate audio jitter
                    audioCtx = new AudioContextClass({ latencyHint: 'playback', sampleRate: 48000 });
                }
                if (audioCtx.state === 'suspended') {
                    audioCtx.resume().catch(() => {});
                }

                if (activeAudioSourceNode) {
                    try { activeAudioSourceNode.disconnect(); } catch (_) {}
                    activeAudioSourceNode = null;
                }

                const destNode = audioCtx.createMediaStreamDestination();
                destNode.channelCount = 2;
                destNode.channelCountMode = "explicit";
                destNode.channelInterpretation = "speakers";

                const sourceNode = audioCtx.createMediaStreamSource(rawAudioStream);
                sourceNode.connect(destNode);

                activeAudioSourceNode = sourceNode;
                activeAudioDestNode = destNode;

                return destNode.stream;
            } catch (err) {
                console.error("[Studio Audio] Error downmixing audio stream, falling back to raw track:", err);
                return rawAudioStream;
            }
        }

        function showReconnectingStatus() {
            isLive = false;
            isStreaming = false;

            const statusBadge = document.getElementById("status-badge");
            statusBadge.className = "badge badge-warning";
            statusBadge.style.background = "#eab308";
            statusBadge.style.borderColor = "#eab308";
            statusBadge.innerHTML = '<i class="ti ti-loader animate-spin"></i> Reconnecting...';
        }

        function scheduleBroadcasterReconnect() {
            if (reconnectTimeout) clearTimeout(reconnectTimeout);
            reconnectTimeout = setTimeout(() => {
                console.warn("[Studio] Attempting to reconnect signaling channel...");
                reconnectBroadcaster();
            }, 3000);
        }

        async function reconnectBroadcaster() {
            if (isManuallyStopped) return;
            try {
                const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
                const wsUrl = `${protocol}//${window.location.host}/api/stream/${streamKey}/ws`;

                console.log("[Studio] Reconnecting signaling WebSocket to:", wsUrl);
                mediaSocket = new WebSocket(wsUrl);

                mediaSocket.onopen = () => {
                    console.log("[Studio] Reconnected to signaling channel successfully.");
                    isLive = true;
                    isStreaming = true;
                    updateUI();
                };

                mediaSocket.onmessage = async (event) => {
                    try {
                        const msg = JSON.parse(event.data);
                        const { event: signalEvent, viewerId, sdp, candidate } = msg;

                        if (signalEvent === "viewer-connected" || signalEvent === "viewer-ready") {
                            await createPeerConnection(viewerId);
                        } else if (signalEvent === "viewer-disconnected") {
                            closePeerConnection(viewerId);
                        } else if (signalEvent === "answer") {
                            const pcInstance = peerConnections.get(viewerId);
                            if (pcInstance) {
                                await pcInstance.setRemoteDescription(new RTCSessionDescription(sdp));

                                const queue = candidateQueues.get(viewerId) || [];
                                while (queue.length > 0) {
                                    const cand = queue.shift();
                                    try {
                                        await pcInstance.addIceCandidate(new RTCIceCandidate(cand));
                                    } catch (e) {
                                        console.warn(`[Studio WebRTC] Error adding queued candidate for viewer ${viewerId}:`, e);
                                    }
                                }
                            }
                        } else if (signalEvent === "candidate") {
                            const pcInstance = peerConnections.get(viewerId);
                            if (pcInstance && candidate) {
                                if (!pcInstance.remoteDescription || !pcInstance.remoteDescription.type) {
                                    let queue = candidateQueues.get(viewerId);
                                    if (!queue) {
                                        queue = [];
                                        candidateQueues.set(viewerId, queue);
                                    }
                                    queue.push(candidate);
                                } else {
                                    try {
                                        await pcInstance.addIceCandidate(new RTCIceCandidate(candidate));
                                    } catch (e) {
                                        console.warn(`[Studio WebRTC] Error adding candidate for viewer ${viewerId}:`, e);
                                    }
                                }
                            }
                        }
                    } catch (err) {
                        console.error("[Studio WS Message Exception]:", err);
                    }
                };

                mediaSocket.onclose = (event) => {
                    if (!isManuallyStopped) {
                        showReconnectingStatus();
                        scheduleBroadcasterReconnect();
                    }
                };

                mediaSocket.onerror = (err) => {
                    console.error("[Studio] Reconnect socket error:", err);
                };

            } catch (err) {
                console.warn("[Studio] Reconnect attempt error:", err);
                scheduleBroadcasterReconnect();
            }
        }

        async function createPeerConnection(viewerId) {
            if (peerConnections.has(viewerId)) {
                closePeerConnection(viewerId);
            }
            candidateQueues.set(viewerId, []);

            console.log(`[Studio WebRTC] Initializing connection for viewer: ${viewerId}`);
            const config = {
                iceServers: [
                    { urls: "stun:stun.l.google.com:19302" },
                    { urls: "stun:stun1.l.google.com:19302" }
                ]
            };

            const pcInstance = new RTCPeerConnection(config);
            peerConnections.set(viewerId, pcInstance);

            // Add local stream tracks to WebRTC and optimize video settings
            if (mediaStream) {
                mediaStream.getTracks().forEach(track => {
                    const sender = pcInstance.addTrack(track, mediaStream);
                    if (track.kind === 'video') {
                        try {
                            const parameters = sender.getParameters();
                            if (!parameters.encodings) {
                                parameters.encodings = [{}];
                            }
                            parameters.encodings[0].maxBitrate = 8000000;
                            parameters.encodings[0].minBitrate = 1200000; // 1.2 Mbps min floor (prevents extreme blur)
                            sender.setParameters(parameters).catch(err => {
                                console.warn("[Studio WebRTC] Failed to set video encoding parameters:", err);
                            });

                            // Adaptive degradation: scale resolution down during congestion, recover when stable
                            const transceiver = pcInstance.getTransceivers().find(t => t.sender === sender);
                            if (transceiver) {
                                transceiver.degradationPreference = 'balanced';
                            }
                        } catch (err) {
                            console.warn("[Studio WebRTC] Failed to modify transceiver parameters:", err);
                        }
                    }
                });
            }

            // Recalculate host upload bandwidth allocation across all viewers
            updateAdaptiveBitrates();

            // Handle candidate negotiation
            pcInstance.onicecandidate = (e) => {
                if (e.candidate && mediaSocket && mediaSocket.readyState === WebSocket.OPEN) {
                    mediaSocket.send(JSON.stringify({
                        event: "candidate",
                        viewerId: viewerId,
                        candidate: e.candidate
                    }));
                }
            };

            let disconnectTimer = null;
            pcInstance.onconnectionstatechange = () => {
                const state = pcInstance.connectionState;
                console.log(`[Studio WebRTC] Connection state for viewer ${viewerId}: ${state}`);
                if (state === "connected") {
                    if (disconnectTimer) {
                        clearTimeout(disconnectTimer);
                        disconnectTimer = null;
                    }
                } else if (state === "disconnected") {
                    if (!disconnectTimer) {
                        disconnectTimer = setTimeout(() => {
                            if (pcInstance.connectionState === "disconnected") {
                                closePeerConnection(viewerId);
                            }
                        }, 5000);
                    }
                } else if (state === "failed" || state === "closed") {
                    if (disconnectTimer) {
                        clearTimeout(disconnectTimer);
                        disconnectTimer = null;
                    }
                    closePeerConnection(viewerId);
                }
            };

            // Create Offer SDP
            try {
                let offer = await pcInstance.createOffer();
                
                // Optimize SDP for high-fidelity stereo audio and video quality
                const modifiedSdp = preferHighFidelityAudioAndVideo(offer.sdp);
                offer = new RTCSessionDescription({
                    type: offer.type,
                    sdp: modifiedSdp
                });

                await pcInstance.setLocalDescription(offer);

                mediaSocket.send(JSON.stringify({
                    event: "offer",
                    viewerId: viewerId,
                    sdp: offer
                }));
            } catch (err) {
                console.error(`[Studio WebRTC] Failed to create offer for viewer ${viewerId}:`, err);
            }
        }

        function toggleLiveState() {
            if (audioCtx && audioCtx.state === 'suspended') {
                audioCtx.resume().catch(e => console.warn("AudioContext resume failed:", e));
            }
            if (isStreaming || isLive) {
                triggerStopLive();
            } else {
                triggerGoLive();
            }
        }

        function closePeerConnection(viewerId) {
            const pcInstance = peerConnections.get(viewerId);
            if (pcInstance) {
                console.log(`[Studio WebRTC] Closing peer connection for viewer: ${viewerId}`);
                pcInstance.close();
                peerConnections.delete(viewerId);
                candidateQueues.delete(viewerId);
                updateAdaptiveBitrates();
            }
        }

        function updateAdaptiveBitrates() {
            const count = Math.max(1, peerConnections.size);
            let targetMaxBitrate;
            
            if (count === 1) {
                targetMaxBitrate = 4500000; // 4.5 Mbps max for 1 viewer (Zero-lag 720p HD)
            } else if (count <= 3) {
                targetMaxBitrate = 3500000; // 3.5 Mbps max per viewer
            } else if (count <= 6) {
                targetMaxBitrate = 2500000; // 2.5 Mbps max per viewer
            } else {
                targetMaxBitrate = 1800000; // 1.8 Mbps max per viewer
            }

            console.log(`[Studio WebRTC] Balancing host upload bandwidth across ${count} connected viewer(s) (${Math.round(targetMaxBitrate / 1000)} Kbps per peer)`);

            for (const [viewerId, pcInstance] of peerConnections) {
                try {
                    const senders = pcInstance.getSenders();
                    for (const sender of senders) {
                        if (sender.track && sender.track.kind === 'video') {
                            const parameters = sender.getParameters();
                            if (!parameters.encodings) parameters.encodings = [{}];
                            parameters.encodings[0].maxBitrate = targetMaxBitrate;
                            parameters.encodings[0].minBitrate = 1200000; // 1.2 Mbps min floor (prevents extreme blur)
                            sender.setParameters(parameters).catch(err => {
                                console.warn(`[Studio WebRTC] Error setting bitrate for viewer ${viewerId}:`, err);
                            });
                        }
                    }
                } catch (err) {
                    console.warn(`[Studio WebRTC] Error updating bitrate parameters for viewer ${viewerId}:`, err);
                }
            }
        }

        async function triggerGoLive() {
            if (isStreaming) return;
            isManuallyStopped = false;

            mediaStream = null;

            // Obtain the media tracks based on selected source type
            if (currentSourceType === 'file') {
                let capturedStream;
                if (previewPlayer.captureStream) {
                    capturedStream = previewPlayer.captureStream(30);
                } else if (previewPlayer.mozCaptureStream) {
                    capturedStream = previewPlayer.mozCaptureStream(30);
                } else {
                    console.warn("[Mobile Studio] captureStream not available on video element, using Canvas capture fallback.");
                    const canvas = document.createElement("canvas");
                    canvas.width = previewPlayer.videoWidth || 1280;
                    canvas.height = previewPlayer.videoHeight || 720;
                    const ctx = canvas.getContext("2d");
                    
                    function renderCanvasFrame() {
                        if (!previewPlayer.paused && !previewPlayer.ended) {
                            ctx.drawImage(previewPlayer, 0, 0, canvas.width, canvas.height);
                            requestAnimationFrame(renderCanvasFrame);
                        }
                    }
                    previewPlayer.addEventListener("play", renderCanvasFrame);
                    renderCanvasFrame();

                    capturedStream = canvas.captureStream(30);
                }

                // Ensure preview player is unmuted so captured audio track is active
                previewPlayer.muted = false;
                if (previewPlayer.volume === 0) previewPlayer.volume = 1.0;

                const videoTrack = capturedStream.getVideoTracks()[0];
                const rawAudioTrack = capturedStream.getAudioTracks()[0];

                if (rawAudioTrack) {
                    rawAudioTrack.enabled = true;
                    const rawAudioStream = new MediaStream([rawAudioTrack]);
                    const downmixedStream = getDownmixedAudioStream(rawAudioStream);
                    const stereoAudioTrack = (downmixedStream && downmixedStream.getAudioTracks().length > 0) 
                        ? downmixedStream.getAudioTracks()[0] 
                        : rawAudioTrack;

                    mediaStream = new MediaStream();
                    if (videoTrack) mediaStream.addTrack(videoTrack);
                    if (stereoAudioTrack) mediaStream.addTrack(stereoAudioTrack);
                } else {
                    mediaStream = new MediaStream();
                    if (videoTrack) mediaStream.addTrack(videoTrack);
                }

                if (previewPlayer.paused) {
                    previewPlayer.play().catch(e => console.warn("Player play error:", e));
                }
            } else if (currentSourceType === 'screen') {
                mediaStream = captureStream;
            }

            // Optimize audio and video track configurations
            if (mediaStream) {
                mediaStream.getAudioTracks().forEach(track => {
                    if (typeof track.applyConstraints === 'function') {
                        track.applyConstraints({
                            echoCancellation: false,
                            noiseSuppression: false,
                            autoGainControl: false
                        }).catch(err => console.warn("Failed to apply audio constraints:", err));
                    }
                });

                mediaStream.getVideoTracks().forEach(track => {
                    if ('contentHint' in track) {
                        track.contentHint = 'motion';
                        console.log("[WebRTC] Set video track contentHint to 'motion'");
                    }
                    if (typeof track.applyConstraints === 'function') {
                        track.applyConstraints({
                            width: { ideal: 1280, max: 1280 },
                            height: { ideal: 720, max: 720 },
                            frameRate: { ideal: 30, max: 30 }
                        }).catch(err => console.warn("Failed to apply 720p constraints:", err));
                    }
                });
            }

            if (!mediaStream || mediaStream.getTracks().length === 0) {
                alert("No active media tracks found. Please play the video or start screen sharing first.");
                return;
            }

            try {
                const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
                const wsUrl = `${protocol}//${window.location.host}/api/stream/${streamKey}/ws`;
                
                console.log("[Studio] Connecting signaling WebSocket to:", wsUrl);
                mediaSocket = new WebSocket(wsUrl);

                mediaSocket.onopen = () => {
                    console.log("[Studio] Signaling channel established.");
                    isLive = true;
                    isStreaming = true; // WebRTC mesh stands ready
                    updateUI();

                    streamStartTime = Date.now();
                    document.getElementById("duration-badge").style.display = "inline-flex";
                    if (durationInterval) clearInterval(durationInterval);
                    durationInterval = setInterval(updateDuration, 1000);
                };

                mediaSocket.onmessage = async (event) => {
                    try {
                        const msg = JSON.parse(event.data);
                        const { event: signalEvent, viewerId, sdp, candidate } = msg;

                        if (signalEvent === "viewer-connected" || signalEvent === "viewer-ready") {
                            await createPeerConnection(viewerId);
                        } else if (signalEvent === "viewer-disconnected") {
                            closePeerConnection(viewerId);
                        } else if (signalEvent === "answer") {
                            const pcInstance = peerConnections.get(viewerId);
                            if (pcInstance) {
                                await pcInstance.setRemoteDescription(new RTCSessionDescription(sdp));

                                const queue = candidateQueues.get(viewerId) || [];
                                while (queue.length > 0) {
                                    const cand = queue.shift();
                                    try {
                                        await pcInstance.addIceCandidate(new RTCIceCandidate(cand));
                                    } catch (e) {
                                        console.warn(`[Studio WebRTC] Error adding queued candidate for viewer ${viewerId}:`, e);
                                    }
                                }
                            }
                        } else if (signalEvent === "candidate") {
                            const pcInstance = peerConnections.get(viewerId);
                            if (pcInstance && candidate) {
                                if (!pcInstance.remoteDescription || !pcInstance.remoteDescription.type) {
                                    let queue = candidateQueues.get(viewerId);
                                    if (!queue) {
                                        queue = [];
                                        candidateQueues.set(viewerId, queue);
                                    }
                                    queue.push(candidate);
                                } else {
                                    try {
                                        await pcInstance.addIceCandidate(new RTCIceCandidate(candidate));
                                    } catch (e) {
                                        console.warn(`[Studio WebRTC] Error adding candidate for viewer ${viewerId}:`, e);
                                    }
                                }
                            }
                        }
                    } catch (err) {
                        console.error("[Studio WS Message Exception]:", err);
                    }
                };

                mediaSocket.onclose = (event) => {
                    console.warn("[Studio] Signaling socket closed:", event.code, event.reason);
                    if (!isManuallyStopped) {
                        showReconnectingStatus();
                        scheduleBroadcasterReconnect();
                    } else {
                        triggerStopLive();
                    }
                };

                mediaSocket.onerror = (err) => {
                    console.error("[Studio] Signaling socket error:", err);
                };

            } catch (err) {
                alert("Failed to establish signaling socket connection: " + err.message);
                triggerStopLive();
            }
        }

        function triggerStopLive() {
            isManuallyStopped = true;
            if (reconnectTimeout) {
                clearTimeout(reconnectTimeout);
                reconnectTimeout = null;
            }

            if (mediaSocket) {
                mediaSocket.onclose = null;
                mediaSocket.onerror = null;
                mediaSocket.close();
                mediaSocket = null;
            }

            console.log("[Studio] Stopping stream...");

            // Close all active WebRTC peers
            for (const [viewerId, pcInstance] of peerConnections) {
                pcInstance.close();
            }
            peerConnections.clear();

            if (mediaStream) {
                if (currentSourceType === 'file') {
                    mediaStream.getTracks().forEach(track => track.stop());
                }
                mediaStream = null;
            }

            // Stop duration timers
            if (durationInterval) {
                clearInterval(durationInterval);
                durationInterval = null;
            }
            document.getElementById("duration-badge").style.display = "none";

            isStreaming = false;
            isLive = false;
            updateUI();
        }

        function updateUI() {
            const statusBadge = document.getElementById("status-badge");
            const btnToggleLive = document.getElementById("btn-toggle-live");
            const playerEl = document.getElementById("preview-player");
            const placeholderEl = document.getElementById("preview-placeholder");

            const iconElement = document.getElementById("icon-element");
            const placeholderTitle = document.getElementById("placeholder-title");
            const placeholderText = document.getElementById("placeholder-text");

            const toggleLiveIcon = document.getElementById("toggle-live-icon");
            const toggleLiveText = document.getElementById("toggle-live-text");

            const hasMediaSelected = (currentSourceType !== null);

            if (isStreaming) {
                statusBadge.className = "badge badge-success";
                statusBadge.innerHTML = '<i class="ti ti-point-filled"></i> LIVE';

                btnToggleLive.disabled = false;
                btnToggleLive.style.opacity = "1";
                btnToggleLive.className = "btn btn-danger";
                btnToggleLive.style.background = "var(--danger)";
                btnToggleLive.style.borderColor = "var(--danger)";
                toggleLiveIcon.className = "ti ti-player-stop";
                toggleLiveText.textContent = "Stop Live";
            } else if (isLive) {
                statusBadge.className = "badge badge-primary";
                statusBadge.innerHTML = '<i class="ti ti-loader animate-spin"></i> Connecting';

                btnToggleLive.disabled = false;
                btnToggleLive.style.opacity = "1";
                btnToggleLive.className = "btn btn-danger";
                btnToggleLive.style.background = "var(--danger)";
                btnToggleLive.style.borderColor = "var(--danger)";
                toggleLiveIcon.className = "ti ti-player-stop";
                toggleLiveText.textContent = "Stop Live";
            } else {
                statusBadge.className = "badge badge-danger";
                statusBadge.innerHTML = '<i class="ti ti-point-filled"></i> Offline';

                btnToggleLive.className = "btn btn-primary";
                btnToggleLive.style.background = "var(--primary)";
                btnToggleLive.style.borderColor = "var(--primary)";
                toggleLiveIcon.className = "ti ti-player-play";
                toggleLiveText.textContent = "Go Live";

                if (hasMediaSelected) {
                    btnToggleLive.disabled = false;
                    btnToggleLive.style.opacity = "1";
                } else {
                    btnToggleLive.disabled = true;
                    btnToggleLive.style.opacity = "0.5";
                }
            }

            // Update placeholder text if media selection changes
            if (!hasMediaSelected) {
                playerEl.style.display = "none";
                placeholderEl.style.display = "flex";
                iconElement.className = "ti ti-video-off";
                iconElement.style.color = "var(--danger)";
                placeholderTitle.textContent = "No Media Selected";
                placeholderText.innerHTML = 'Select a local movie file using the media source panel, then click <strong>Go Live</strong> to start.';
            }
        }

        function updateDuration() {
            if (!streamStartTime) return;
            const elapsedMs = Date.now() - streamStartTime;
            const totalSecs = Math.floor(elapsedMs / 1000);
            const hrs = Math.floor(totalSecs / 3600).toString().padStart(2, '0');
            const mins = Math.floor((totalSecs % 3600) / 60).toString().padStart(2, '0');
            const secs = (totalSecs % 60).toString().padStart(2, '0');
            document.getElementById('duration-badge').textContent = `${hrs}:${mins}:${secs}`;
        }

        function copyViewerLink() {
            const link = window.location.origin + "/live/" + streamKey;
            navigator.clipboard.writeText(link).then(() => {
                alert("Viewer link copied to clipboard!");
            }).catch(err => {
                console.error("Copy failed:", err);
            });
        }
    </script>

