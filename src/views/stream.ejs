<%- include('header') %>

<!-- Import Mediasoup Client JS Library for WebRTC SFU Streaming -->
<script src="https://cdn.jsdelivr.net/npm/mediasoup-client@3/dist/mediasoup-client.min.js"></script>

<style>
    .hidden-row {
        display: none !important;
    }

    .flex-row-layout {
        display: flex;
        justify-content: space-between;
    }

    #preview-player::-webkit-media-controls-mute-button,
    #preview-player::-webkit-media-controls-volume-slider {
        display: none !important;
    }
</style>

<!-- Server-passed variables for JS -->
<div id="studio-config" data-stream-key="<%= stream.streamKey %>" data-is-live="<%= stream.isLive %>" style="display: none;"></div>

<div class="app-body">
    <div class="row g-4">
        <!-- Left Section: Main Live Video Player & Controls -->
        <div class="col-lg-8">
            <div class="card bg-dark border-secondary shadow-lg">
                <div class="card-header border-secondary d-flex justify-content-between align-items-center bg-black bg-opacity-40 py-3">
                    <div class="d-flex align-items-center gap-2">
                        <span id="live-badge" class="badge bg-secondary text-uppercase px-3 py-2 fw-bold" style="letter-spacing: 1px;">Offline</span>
                        <span id="duration-badge" class="badge bg-dark border border-secondary text-light px-3 py-2 font-monospace" style="display: none;">00:00:00</span>
                    </div>
                    <div id="network-quality-badge" class="badge bg-secondary bg-opacity-20 border border-secondary text-secondary px-3 py-2 d-flex align-items-center gap-2">
                        <i id="network-quality-icon" class="ti ti-wifi-off"></i>
                        <span id="network-quality-text">Standby</span>
                    </div>
                </div>

                <div class="card-body p-0 position-relative bg-black d-flex align-items-center justify-content-center" style="min-height: 480px; max-height: 600px;">
                    <!-- Placeholder graphic when no media is selected -->
                    <div id="preview-placeholder" class="text-center p-5">
                        <div id="placeholder-icon" class="avatar avatar-xl bg-primary bg-opacity-10 text-primary rounded-circle mb-3 mx-auto d-flex align-items-center justify-content-center">
                            <i class="ti ti-video-plus fs-1"></i>
                        </div>
                        <h4 id="placeholder-title" class="text-light fw-bold mb-2">No Active Media Selected</h4>
                        <p id="placeholder-text" class="text-secondary mb-4 mx-auto" style="max-width: 400px;">
                            Select a local video file or share your screen to begin streaming via WebRTC SFU.
                        </p>
                        <div class="d-flex justify-content-center gap-3">
                            <label class="btn btn-primary px-4 py-2 d-flex align-items-center gap-2 cursor-pointer shadow-sm">
                                <i class="ti ti-movie fs-5"></i> Choose Video File
                                <input type="file" id="movie-file-input" accept="video/*" class="d-none">
                            </label>
                            <button id="screenshare-btn" onclick="startScreenShare()" class="btn btn-outline-light px-4 py-2 d-flex align-items-center gap-2">
                                <i class="ti ti-screen-share fs-5"></i> Share Screen
                            </button>
                        </div>
                    </div>

                    <!-- Broadcaster Preview Video Player -->
                    <video id="preview-player" class="w-100 h-100 object-fit-contain" style="display: none;" playsinline muted></video>

                    <!-- Hidden Audio Player to ensure clean un-muted sound for file playback -->
                    <audio id="audio-player" style="display: none;"></audio>
                </div>

                <!-- Footer Control Bar -->
                <div class="card-footer border-secondary bg-black bg-opacity-40 p-3">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                        <div class="d-flex align-items-center gap-3">
                            <button id="go-live-btn" onclick="toggleLiveState()" class="btn btn-success btn-lg px-4 d-flex align-items-center gap-2 fw-bold shadow">
                                <i class="ti ti-broadcast fs-4"></i>
                                <span>Go Live (WebRTC SFU)</span>
                            </button>
                            <div class="vr bg-secondary opacity-25" style="height: 30px;"></div>
                            <span id="active-source-text" class="text-secondary small font-monospace">Source: None</span>
                        </div>

                        <div class="d-flex align-items-center gap-4 text-secondary small">
                            <div>
                                <i class="ti ti-users text-primary me-1"></i>
                                Viewers: <strong id="viewers-count" class="text-light font-monospace">0 / 5 Max</strong>
                            </div>
                            <div>
                                <i class="ti ti-activity text-info me-1"></i>
                                Bitrate: <strong id="upload-speed-val" class="text-light font-monospace">0</strong> Kbps
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Section: Stream Details & Information -->
        <div class="col-lg-4">
            <div class="card bg-dark border-secondary shadow-lg mb-4">
                <div class="card-header border-secondary bg-black bg-opacity-40 py-3">
                    <h5 class="card-title text-light m-0 d-flex align-items-center gap-2">
                        <i class="ti ti-settings text-primary"></i> Stream Information
                    </h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label text-secondary small text-uppercase">Stream Key</label>
                        <div class="input-group">
                            <input type="text" class="form-control bg-black text-light border-secondary font-monospace" value="<%= stream.streamKey %>" readonly>
                            <button class="btn btn-outline-secondary" onclick="navigator.clipboard.writeText('<%= stream.streamKey %>')">
                                <i class="ti ti-copy"></i>
                            </button>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-secondary small text-uppercase">Direct Viewer Link</label>
                        <div class="input-group">
                            <input type="text" class="form-control bg-black text-light border-secondary font-monospace" value="<%= process.env.APP_URL || 'http://localhost:3000' %>/live/<%= stream.streamKey %>" readonly>
                            <button class="btn btn-outline-secondary" onclick="navigator.clipboard.writeText('<%= process.env.APP_URL || 'http://localhost:3000' %>/live/<%= stream.streamKey %>')">
                                <i class="ti ti-copy"></i>
                            </button>
                        </div>
                    </div>

                    <div class="p-3 bg-black bg-opacity-50 rounded border border-secondary">
                        <div class="d-flex align-items-center gap-2 text-warning mb-2">
                            <i class="ti ti-info-circle fs-5"></i>
                            <strong class="small">Room Limit Notice</strong>
                        </div>
                        <p class="text-secondary small m-0">
                            Mediasoup SFU limits this stream to a maximum of <strong>5 concurrent viewers</strong> for ultra-high quality, sub-second WebRTC delivery.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        // Read configuration from server-rendered dataset
        const studioConfig = document.getElementById("studio-config");
        const streamKey = studioConfig.dataset.streamKey;

        // UI State Variables
        let isLive = false;
        let isStreaming = false;
        let isManuallyStopped = false;
        let currentSourceType = null; // 'file' or 'screen'

        // Media Stream & Player References
        let mediaStream = null;
        let durationInterval = null;
        let statsInterval = null;
        let streamStartTime = null;

        // Mediasoup SFU WebRTC Client Variables
        let sfuSocket = null;
        let device = null;
        let sendTransport = null;
        let videoProducer = null;
        let audioProducer = null;

        const movieFileInput = document.getElementById("movie-file-input");
        const previewPlayer = document.getElementById("preview-player");
        const audioPlayer = document.getElementById("audio-player");
        const previewPlaceholder = document.getElementById("preview-placeholder");

        /**
         * Handle Video File Selection
         */
        movieFileInput.addEventListener("change", (e) => {
            const file = e.target.files[0];
            if (!file) return;

            if (isLive) stopMediasoupBroadcaster();
            stopMediaTracks();

            const fileUrl = URL.createObjectURL(file);
            previewPlayer.srcObject = null;
            previewPlayer.src = fileUrl;
            previewPlayer.load();

            audioPlayer.src = fileUrl;
            audioPlayer.load();

            previewPlayer.onplay = () => {
                audioPlayer.currentTime = previewPlayer.currentTime;
                audioPlayer.play().catch(() => {});
            };
            previewPlayer.onpause = () => audioPlayer.pause();
            previewPlayer.onseeked = () => audioPlayer.currentTime = previewPlayer.currentTime;

            currentSourceType = 'file';
            document.getElementById("active-source-text").textContent = `Movie File: ${file.name}`;
            previewPlayer.style.display = "block";
            previewPlaceholder.style.display = "none";
            updateUI();
        });

        /**
         * Handle Screen Sharing Capture
         */
        window.startScreenShare = async function() {
            try {
                if (isLive) stopMediasoupBroadcaster();
                stopMediaTracks();

                const stream = await navigator.mediaDevices.getDisplayMedia({
                    video: { width: { ideal: 1920 }, height: { ideal: 1080 }, frameRate: { ideal: 60 } },
                    audio: true
                });

                mediaStream = stream;
                previewPlayer.src = "";
                previewPlayer.srcObject = stream;
                previewPlayer.play().catch(() => {});

                currentSourceType = 'screen';
                document.getElementById("active-source-text").textContent = "Source: Screen Share";
                previewPlayer.style.display = "block";
                previewPlaceholder.style.display = "none";
                updateUI();
            } catch (err) {
                console.error("[Screen Share Error]:", err);
            }
        };

        /**
         * Stop all active media tracks
         */
        function stopMediaTracks() {
            if (mediaStream) {
                mediaStream.getTracks().forEach(track => track.stop());
                mediaStream = null;
            }
        }

        /**
         * Toggle Live State (Go Live / Stop Live)
         */
        window.toggleLiveState = function() {
            if (isLive) {
                stopMediasoupBroadcaster();
            } else {
                startMediasoupBroadcaster();
            }
        };

        /**
         * Start Mediasoup SFU WebRTC Broadcaster
         */
        async function startMediasoupBroadcaster() {
            if (isLive) return;

            // Prepare MediaStream from active player or screen capture
            if (currentSourceType === 'file') {
                if (previewPlayer.captureStream) {
                    mediaStream = previewPlayer.captureStream();
                } else if (previewPlayer.mozCaptureStream) {
                    mediaStream = previewPlayer.mozCaptureStream();
                }
                previewPlayer.play().catch(() => {});
            }

            if (!mediaStream || mediaStream.getTracks().length === 0) {
                alert("Please select a video file or share your screen first!");
                return;
            }

            console.log(`[Mediasoup Broadcaster] Connecting to SFU WebSocket for stream: ${streamKey}`);

            const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
            const wsUrl = `${protocol}//${window.location.host}/api/sfu/ws?streamKey=${encodeURIComponent(streamKey)}&role=broadcaster`;

            sfuSocket = new WebSocket(wsUrl);

            sfuSocket.onopen = () => {
                console.log("[Mediasoup Broadcaster] WebSocket connected! Requesting Router Capabilities...");
                sfuSocket.send(JSON.stringify({ action: "getRouterRtpCapabilities" }));
            };

            sfuSocket.onmessage = async (event) => {
                try {
                    const msg = JSON.parse(event.data);

                    switch (msg.action) {
                        case "routerRtpCapabilities": {
                            // 1. Load Mediasoup Device with Router Capabilities
                            device = new mediasoupClient.Device();
                            await device.load({ routerRtpCapabilities: msg.rtpCapabilities });

                            // 2. Request WebRTC Producer Transport
                            sfuSocket.send(JSON.stringify({ action: "createWebRtcTransport", isBroadcaster: true }));
                            break;
                        }

                        case "webRtcTransportCreated": {
                            // 3. Create Send Transport on Mediasoup Device
                            const { id, iceParameters, iceCandidates, dtlsParameters } = msg.data;
                            sendTransport = device.createSendTransport({ id, iceParameters, iceCandidates, dtlsParameters });

                            sendTransport.on("connect", ({ dtlsParameters }, callback, errback) => {
                                sfuSocket.send(JSON.stringify({
                                    action: "connectTransport",
                                    transportId: sendTransport.id,
                                    dtlsParameters
                                }));
                                callback();
                            });

                            sendTransport.on("produce", ({ kind, rtpParameters }, callback, errback) => {
                                sfuSocket.send(JSON.stringify({
                                    action: "produce",
                                    transportId: sendTransport.id,
                                    kind,
                                    rtpParameters
                                }));

                                const onProduced = (ev) => {
                                    const res = JSON.parse(ev.data);
                                    if (res.action === "produced" && res.kind === kind) {
                                        sfuSocket.removeEventListener("message", onProduced);
                                        callback({ id: res.id });
                                    }
                                };
                                sfuSocket.addEventListener("message", onProduced);
                            });

                            // 4. Produce Video & Audio Tracks to Mediasoup SFU
                            const videoTrack = mediaStream.getVideoTracks()[0];
                            const audioTrack = mediaStream.getAudioTracks()[0];

                            if (videoTrack) {
                                videoProducer = await sendTransport.produce({
                                    track: videoTrack,
                                    encodings: [{ maxBitrate: 6000000 }], // 6.0 Mbps High Bitrate
                                    codecOptions: { videoGoogleStartBitrate: 5000 }
                                });
                            }

                            if (audioTrack) {
                                audioProducer = await sendTransport.produce({ track: audioTrack });
                            }

                            isLive = true;
                            isStreaming = true;
                            streamStartTime = Date.now();
                            startDurationTimer();
                            startStatsMonitoring();
                            updateUI();
                            console.log("[Mediasoup Broadcaster] Successfully producing WebRTC SFU stream!");
                            break;
                        }

                        case "error": {
                            alert("SFU Error: " + msg.message);
                            stopMediasoupBroadcaster();
                            break;
                        }
                    }
                } catch (err) {
                    console.error("[Mediasoup Broadcaster Message Exception]:", err);
                }
            };

            sfuSocket.onclose = () => {
                console.log("[Mediasoup Broadcaster] WebSocket closed.");
                stopMediasoupBroadcaster();
            };
        }

        /**
         * Stop Mediasoup SFU Broadcaster Session
         */
        function stopMediasoupBroadcaster() {
            isLive = false;
            isStreaming = false;

            if (videoProducer) { try { videoProducer.close(); } catch (_) {} videoProducer = null; }
            if (audioProducer) { try { audioProducer.close(); } catch (_) {} audioProducer = null; }
            if (sendTransport) { try { sendTransport.close(); } catch (_) {} sendTransport = null; }
            if (sfuSocket) { try { sfuSocket.close(); } catch (_) {} sfuSocket = null; }

            if (durationInterval) { clearInterval(durationInterval); durationInterval = null; }
            if (statsInterval) { clearInterval(statsInterval); statsInterval = null; }

            updateUI();
        }

        /**
         * Start Duration Timer
         */
        function startDurationTimer() {
            const badge = document.getElementById("duration-badge");
            badge.style.display = "inline-flex";

            durationInterval = setInterval(() => {
                const elapsedSec = Math.floor((Date.now() - streamStartTime) / 1000);
                const hrs = String(Math.floor(elapsedSec / 3600)).padStart(2, '0');
                const mins = String(Math.floor((elapsedSec % 3600) / 60)).padStart(2, '0');
                const secs = String(elapsedSec % 60).padStart(2, '0');
                badge.textContent = `${hrs}:${mins}:${secs}`;
            }, 1000);
        }

        /**
         * Monitor Bitrate Stats
         */
        function startStatsMonitoring() {
            let lastBytes = 0;
            let lastTime = Date.now();

            statsInterval = setInterval(async () => {
                if (!sendTransport) return;
                try {
                    const stats = await sendTransport.getStats();
                    let currentBytes = 0;
                    stats.forEach(report => {
                        if (report.type === 'outbound-rtp') {
                            currentBytes += (report.bytesSent || 0);
                        }
                    });

                    const now = Date.now();
                    const deltaSec = (now - lastTime) / 1000;
                    if (deltaSec > 0 && currentBytes >= lastBytes) {
                        const kbps = Math.round(((currentBytes - lastBytes) * 8) / 1024 / deltaSec);
                        document.getElementById("upload-speed-val").textContent = kbps;
                    }
                    lastBytes = currentBytes;
                    lastTime = now;
                } catch (_) {}
            }, 1000);
        }

        /**
         * Update UI Elements
         */
        function updateUI() {
            const liveBadge = document.getElementById("live-badge");
            const goLiveBtn = document.getElementById("go-live-btn");
            const qualityBadge = document.getElementById("network-quality-badge");
            const qualityIcon = document.getElementById("network-quality-icon");
            const qualityText = document.getElementById("network-quality-text");

            if (isLive) {
                liveBadge.className = "badge bg-danger text-uppercase px-3 py-2 fw-bold animate-pulse";
                liveBadge.textContent = "● LIVE (SFU)";

                goLiveBtn.className = "btn btn-danger btn-lg px-4 d-flex align-items-center gap-2 fw-bold shadow";
                goLiveBtn.querySelector("span").textContent = "Stop Stream";

                qualityBadge.className = "badge bg-success bg-opacity-20 border border-success text-success px-3 py-2 d-flex align-items-center gap-2";
                qualityIcon.className = "ti ti-wifi";
                qualityText.textContent = "WebRTC SFU Active";
            } else {
                liveBadge.className = "badge bg-secondary text-uppercase px-3 py-2 fw-bold";
                liveBadge.textContent = "Offline";

                goLiveBtn.className = "btn btn-success btn-lg px-4 d-flex align-items-center gap-2 fw-bold shadow";
                goLiveBtn.querySelector("span").textContent = "Go Live (WebRTC SFU)";

                qualityBadge.className = "badge bg-secondary bg-opacity-20 border border-secondary text-secondary px-3 py-2 d-flex align-items-center gap-2";
                qualityIcon.className = "ti ti-wifi-off";
                qualityText.textContent = "Standby";

                document.getElementById("duration-badge").style.display = "none";
                document.getElementById("upload-speed-val").textContent = "0";
            }
        }
    });
</script>

<%- include('footer') %>
