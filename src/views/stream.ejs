<%- include('header') %>

<script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div id="studio-config" data-stream-key="<%= stream.streamKey %>" style="display: none;"></div>

<style>
  .sh-player-studio {
    width: 100%;
    aspect-ratio: 16/9;
    background: #000;
    position: relative;
    overflow: hidden;
    border-radius: var(--radius);
    box-shadow: 0 4px 20px rgba(0,0,0,0.8);
  }
  .sh-progress-bar {
    background: linear-gradient(90deg, #6366f1, #4f46e5);
  }
  .obs-ladder-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    color: var(--text-muted);
  }
  .obs-ladder-row:last-child {
    border-bottom: 0;
  }
  .obs-ladder-row strong {
    color: #fff;
    font-family: monospace;
    font-size: 0.9rem;
  }
</style>

<div class="stream-grid">
  <section class="glass-panel" style="padding: 0; overflow: hidden; display: flex; flex-direction: column;">
    <div style="padding: 1rem 1.25rem; border-bottom: 1px solid var(--panel-border); display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap;">
      <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
        <span id="obs-status-badge" class="badge badge-primary">
          <i class="ti ti-antenna-bars-off"></i> Waiting for OBS
        </span>
        <span id="public-status-badge" class="badge badge-primary">
          Public Offline
        </span>
      </div>
      <div style="display: flex; align-items: center; gap: 0.75rem; color: var(--text-muted); font-size: 0.9rem;">
        <i class="ti ti-activity"></i>
        <span>FFmpeg speed: <strong id="pipeline-speed" style="color: #fff; font-family: monospace;">N/A</strong></span>
      </div>
    </div>

    <!-- Commit 94733b7 Custom Player UI for Studio Preview -->
    <div class="sh-player-studio" id="sh-player">
      <video id="preview-video" class="w-full h-full object-contain bg-black block cursor-pointer" playsinline muted style="image-rendering: -webkit-optimize-contrast; image-rendering: crisp-edges;"></video>

      <!-- Empty State / Placeholder -->
      <div id="preview-empty" style="position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 2rem; background: #050505; z-index: 4;">
        <i class="ti ti-broadcast" style="font-size: 4rem; color: var(--primary); margin-bottom: 1rem;"></i>
        <h2 style="font-size: 1.5rem; margin-bottom: 0.5rem; color: #fff;">OBS Preview</h2>
        <p id="preview-message" style="color: var(--text-muted); max-width: 520px;">Start streaming from OBS. The preview appears here before viewers can watch.</p>
      </div>

      <!-- Loading Spinner -->
      <div class="absolute inset-0 flex items-center justify-center z-[5] pointer-events-none" id="sh-loading-wrap" style="display: none;">
        <div class="w-10 h-10 sm:w-[50px] sm:h-[50px] border-4 border-solid border-white/10 border-t-indigo-500 rounded-full animate-spin pointer-events-auto"></div>
      </div>

      <!-- Controls Overlay (Commit 94733b7 Style) -->
      <div class="absolute left-0 right-0 bottom-0 p-4 bg-gradient-to-t from-black/95 via-black/70 to-transparent flex flex-col gap-2.5 transition-opacity duration-200 z-10" id="sh-controls">
        <!-- Row 1: Progress & Time -->
        <div class="flex items-center w-full gap-3 min-w-0">
          <span class="text-xs font-medium text-[#aaaaaa] min-w-[42px] font-mono tabular-nums" id="sh-current-time">00:00</span>
          <div class="sh-progress relative flex-1 h-1.5 rounded-full bg-[#3a3a3a] cursor-pointer overflow-hidden transition-all duration-150 hover:h-2" id="sh-progress">
            <div class="sh-progress-buffer absolute top-0 left-0 bottom-0 w-0 rounded-full bg-white/20" id="sh-progress-buffer"></div>
            <div class="sh-progress-bar absolute top-0 left-0 bottom-0 w-0 rounded-full" id="sh-progress-bar"></div>
          </div>
          <span class="text-xs font-medium text-[#aaaaaa] min-w-[42px] font-mono tabular-nums" id="sh-duration">LIVE</span>
        </div>

        <!-- Row 2: Control Buttons -->
        <div class="flex items-center justify-between w-full">
          <button class="sh-play-btn w-9 h-9 rounded-full bg-indigo-600 text-white flex items-center justify-center text-sm transition-all duration-150 shadow-md hover:bg-indigo-500 hover:scale-105" id="sh-play-btn" type="button" aria-label="Play/Pause">
            <i class="fas fa-play" id="sh-play-icon"></i>
          </button>

          <div class="flex items-center gap-2">
            <button class="w-8 h-8 bg-transparent text-[#aaaaaa] flex items-center justify-center text-sm rounded-lg hover:text-white hover:bg-white/10" id="sh-volume-btn" type="button" title="Mute/Unmute">
              <i class="fas fa-volume-mute" id="sh-volume-icon"></i>
            </button>
            <button class="w-8 h-8 rounded-lg bg-white/10 text-white flex items-center justify-center text-sm hover:bg-white/20 hover:scale-105" id="sh-full-btn" type="button" title="Fullscreen">
              <i class="fas fa-expand" id="sh-fullscreen-icon"></i>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Control Dock -->
    <div style="padding: 1.25rem; display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap; background: rgba(0,0,0,0.22);">
      <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
        <button id="start-preview-btn" class="btn btn-secondary" type="button">
          <i class="ti ti-refresh"></i> Start Preview
        </button>
        <button id="go-live-btn" class="btn btn-primary" type="button" disabled>
          <i class="ti ti-player-play"></i> Go Live
        </button>
        <a id="viewer-link-btn" class="btn btn-secondary" href="/live/<%= stream.streamKey %>" target="_blank" rel="noreferrer">
          <i class="ti ti-external-link"></i> Viewer Link
        </a>
      </div>
      <span id="last-error" style="color: var(--warning); font-size: 0.9rem;"></span>
    </div>
  </section>

  <!-- Sidebar -->
  <aside style="display: flex; flex-direction: column; gap: 1rem;">
    <section class="glass-panel">
      <div class="card-header">
        <h3 class="card-title"><i class="ti ti-router" style="color: var(--primary);"></i> OBS Ingest</h3>
      </div>

      <div class="form-group">
        <label class="form-label">RTMP Server</label>
        <div style="display: flex; gap: 0.5rem;">
          <input id="rtmp-server" class="form-input" readonly value="Loading...">
          <button class="btn btn-secondary btn-sm" type="button" onclick="copyField('rtmp-server')" title="Copy RTMP server">
            <i class="ti ti-copy"></i>
          </button>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Stream Key</label>
        <div style="display: flex; gap: 0.5rem;">
          <input id="stream-key" class="form-input" readonly value="<%= stream.streamKey %>">
          <button class="btn btn-secondary btn-sm" type="button" onclick="copyField('stream-key')" title="Copy stream key">
            <i class="ti ti-copy"></i>
          </button>
        </div>
      </div>

      <div style="display: grid; gap: 0.65rem; color: var(--text-muted); font-size: 0.9rem;">
        <div style="display: flex; justify-content: space-between; gap: 1rem;">
          <span>Encoder</span>
          <strong style="color: #fff;">H.264</strong>
        </div>
        <div style="display: flex; justify-content: space-between; gap: 1rem;">
          <span>Audio</span>
          <strong style="color: #fff;">AAC 48 kHz</strong>
        </div>
        <div style="display: flex; justify-content: space-between; gap: 1rem;">
          <span>Keyframe</span>
          <strong style="color: #fff;">2 seconds</strong>
        </div>
        <div style="display: flex; justify-content: space-between; gap: 1rem;">
          <span>Bitrate</span>
          <strong style="color: #fff;">800 Kbps</strong>
        </div>
      </div>
    </section>

    <section class="glass-panel">
      <div class="card-header">
        <h3 class="card-title"><i class="ti ti-stack-2" style="color: var(--secondary);"></i> Active Stream Format</h3>
      </div>
      <div style="display: grid; gap: 0.75rem;">
        <div class="obs-ladder-row">
          <span>480p Superfast</span>
          <strong>800 Kbps (Zero-Buffer)</strong>
        </div>
      </div>
    </section>
  </aside>
</div>

<script>
  const configEl = document.getElementById('studio-config');
  const streamKey = configEl ? configEl.dataset.streamKey : '';
  const previewVideo = document.getElementById('preview-video');
  const previewPlayer = document.getElementById('sh-player');
  const previewEmpty = document.getElementById('preview-empty');
  const previewMessage = document.getElementById('preview-message');
  const obsBadge = document.getElementById('obs-status-badge');
  const publicBadge = document.getElementById('public-status-badge');
  const speedEl = document.getElementById('pipeline-speed');
  const errorEl = document.getElementById('last-error');
  const goLiveBtn = document.getElementById('go-live-btn');
  const startPreviewBtn = document.getElementById('start-preview-btn');
  const rtmpServerInput = document.getElementById('rtmp-server');

  // Player elements
  const playBtn = document.getElementById('sh-play-btn');
  const playIcon = document.getElementById('sh-play-icon');
  const currentTimeEl = document.getElementById('sh-current-time');
  const durationEl = document.getElementById('sh-duration');
  const progress = document.getElementById('sh-progress');
  const progressBar = document.getElementById('sh-progress-bar');
  const progressBuffer = document.getElementById('sh-progress-buffer');
  const volumeBtn = document.getElementById('sh-volume-btn');
  const volumeIcon = document.getElementById('sh-volume-icon');
  const fullBtn = document.getElementById('sh-full-btn');
  const fullscreenIcon = document.getElementById('sh-fullscreen-icon');
  const loadingWrap = document.getElementById('sh-loading-wrap');
  const controls = document.getElementById('sh-controls');

  let hls = null;
  let previewAttached = false;
  let previewUrl = null;
  let scrubbing = false;
  let controlsTimeout = null;

  window.copyField = function(id) {
    const el = document.getElementById(id);
    if (!el) return;
    navigator.clipboard.writeText(el.value).then(() => {
      if (window.showToast) window.showToast('Copied to clipboard.', 'success');
    }).catch(() => {
      if (window.showToast) window.showToast('Copy failed.', 'error');
    });
  };

  async function loadIngestDetails() {
    const res = await fetch(`/api/stream/${encodeURIComponent(streamKey)}/ingest`);
    const data = await res.json();
    if (!res.ok || !data.success) throw new Error(data.error || 'Failed to load ingest details.');
    rtmpServerInput.value = data.data.ingest.rtmpServer;
  }

  async function startPreviewPipeline() {
    startPreviewBtn.disabled = true;
    startPreviewBtn.innerHTML = '<i class="ti ti-loader-2"></i> Starting';
    try {
      const res = await fetch(`/api/stream/${encodeURIComponent(streamKey)}/transcoder/start`, { method: 'POST' });
      const data = await res.json();
      if (!res.ok || !data.success) throw new Error(data.error || 'Failed to start preview.');
      if (window.showToast) window.showToast('Preview watcher is running.', 'success');
    } catch (err) {
      if (window.showToast) window.showToast(err.message, 'error');
    } finally {
      startPreviewBtn.disabled = false;
      startPreviewBtn.innerHTML = '<i class="ti ti-refresh"></i> Start Preview';
    }
  }

  async function setPublicLive(shouldLive) {
    goLiveBtn.disabled = true;
    try {
      const endpoint = shouldLive ? 'golive' : 'stop';
      const res = await fetch(`/api/stream/${encodeURIComponent(streamKey)}/${endpoint}`, { method: 'POST' });
      const data = await res.json();
      if (!res.ok || !data.success) throw new Error(data.error || 'Failed to update live state.');
      if (window.showToast) window.showToast(data.message, 'success');
      await refreshStatus();
    } catch (err) {
      if (window.showToast) window.showToast(err.message, 'error');
    } finally {
      goLiveBtn.disabled = false;
    }
  }

  function jumpToLiveEdge() {
    try {
      if (hls && hls.liveSyncPosition) {
        previewVideo.currentTime = hls.liveSyncPosition;
        return;
      }
      const b = previewVideo.buffered;
      if (b && b.length > 0) {
        const start = b.start(0);
        const end = b.end(b.length - 1);
        if (previewVideo.currentTime < start || previewVideo.currentTime === 0) {
          previewVideo.currentTime = Math.max(end - 1.5, start);
        }
      }
    } catch (_) {}
  }

  function formatTime(seconds) {
    if (isNaN(seconds) || seconds < 0) return '00:00';
    const m = Math.floor(seconds / 60);
    const s = Math.floor(seconds % 60);
    return `${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
  }

  function playAndUnmute() {
    previewVideo.muted = false;
    volumeIcon.className = 'fas fa-volume-up';
    jumpToLiveEdge();
    previewVideo.play().then(() => {
      playIcon.className = 'fas fa-pause';
    }).catch(() => {});
  }

  function togglePlay() {
    if (previewVideo.paused) {
      playAndUnmute();
    } else {
      previewVideo.pause();
    }
  }

  playBtn.addEventListener('click', togglePlay);
  previewVideo.addEventListener('click', togglePlay);

  previewVideo.addEventListener('play', () => {
    playIcon.className = 'fas fa-pause';
  });

  previewVideo.addEventListener('pause', () => {
    playIcon.className = 'fas fa-play';
  });

  previewVideo.addEventListener('timeupdate', () => {
    if (!previewVideo.duration || !isFinite(previewVideo.duration)) {
      currentTimeEl.textContent = formatTime(previewVideo.currentTime);
      durationEl.textContent = 'LIVE';
      progressBar.style.width = '100%';
      return;
    }
    currentTimeEl.textContent = formatTime(previewVideo.currentTime);
    durationEl.textContent = formatTime(previewVideo.duration);
    const percent = (previewVideo.currentTime / previewVideo.duration) * 100;
    progressBar.style.width = percent + '%';
  });

  previewVideo.addEventListener('progress', () => {
    if (previewVideo.buffered && previewVideo.buffered.length > 0) {
      const bufferedEnd = previewVideo.buffered.end(previewVideo.buffered.length - 1);
      if (previewVideo.duration && isFinite(previewVideo.duration)) {
        const percent = (bufferedEnd / previewVideo.duration) * 100;
        progressBuffer.style.width = percent + '%';
      } else {
        progressBuffer.style.width = '100%';
      }
    }
  });

  previewVideo.addEventListener('waiting', () => {
    if (loadingWrap) loadingWrap.style.display = 'flex';
  });

  previewVideo.addEventListener('playing', () => {
    if (loadingWrap) loadingWrap.style.display = 'none';
  });

  volumeBtn.addEventListener('click', () => {
    previewVideo.muted = !previewVideo.muted;
    volumeIcon.className = previewVideo.muted ? 'fas fa-volume-mute' : 'fas fa-volume-up';
  });

  function toggleFullscreen() {
    if (document.fullscreenElement || document.webkitFullscreenElement) {
      if (document.exitFullscreen) document.exitFullscreen();
      else if (document.webkitExitFullscreen) document.webkitExitFullscreen();
      fullscreenIcon.className = 'fas fa-expand';
    } else {
      if (previewPlayer.requestFullscreen) previewPlayer.requestFullscreen();
      else if (previewPlayer.webkitRequestFullscreen) previewPlayer.webkitRequestFullscreen();
      fullscreenIcon.className = 'fas fa-compress';
    }
  }

  fullBtn.addEventListener('click', toggleFullscreen);

  function attachPreview(url) {
    if (previewAttached && previewUrl === url && hls) {
      return;
    }
    previewAttached = true;
    previewUrl = url;
    previewEmpty.style.display = 'none';

    if (hls) {
      hls.destroy();
      hls = null;
    }

    if (previewVideo.canPlayType('application/vnd.apple.mpegurl')) {
      previewVideo.src = url;
      previewVideo.addEventListener('loadedmetadata', jumpToLiveEdge, { once: true });
      return;
    }

    if (window.Hls && Hls.isSupported()) {
      hls = new Hls({
        lowLatencyMode: false,
        liveSyncDurationCount: 2,
        liveMaxLatencyDurationCount: 5,
        maxLiveSyncPlaybackRate: 1.5,
        maxBufferLength: 20,
        backBufferLength: 10,
        manifestLoadingMaxRetry: 10,
        levelLoadingMaxRetry: 10,
        fragLoadingMaxRetry: 10,
      });
      hls.loadSource(url);
      hls.attachMedia(previewVideo);

      hls.on(Hls.Events.FRAG_BUFFERED, () => {
        if (previewVideo.currentTime === 0 && previewVideo.buffered.length > 0) {
          jumpToLiveEdge();
        }
      });

      hls.on(Hls.Events.ERROR, (_, data) => {
        if (!data) return;
        if (data.fatal) {
          switch (data.type) {
            case Hls.ErrorTypes.NETWORK_ERROR:
              hls.startLoad(-1);
              break;
            case Hls.ErrorTypes.MEDIA_ERROR:
              hls.recoverMediaError();
              break;
            default:
              previewAttached = false;
              previewUrl = null;
              previewEmpty.style.display = 'flex';
              previewMessage.textContent = 'Preview stalled. Waiting for fresh HLS segments.';
              hls.destroy();
              hls = null;
              break;
          }
        }
      });
    }
  }

  function updateBadges(status) {
    speedEl.textContent = status.speed || 'N/A';
    errorEl.textContent = status.lastError || '';

    if (status.isReady) {
      obsBadge.className = 'badge badge-success';
      obsBadge.innerHTML = '<i class="ti ti-point-filled"></i> OBS Preview Ready';
      goLiveBtn.disabled = false;
      attachPreview(status.previewUrl);
    } else if (status.status === 'waiting_for_obs') {
      obsBadge.className = 'badge badge-primary';
      obsBadge.innerHTML = '<i class="ti ti-antenna-bars-off"></i> Waiting for OBS';
      goLiveBtn.disabled = true;
      previewMessage.textContent = 'Start streaming from OBS. The preview appears here before viewers can watch.';
    } else if (status.status === 'failed') {
      obsBadge.className = 'badge badge-danger';
      obsBadge.innerHTML = '<i class="ti ti-alert-triangle"></i> Pipeline Error';
      goLiveBtn.disabled = true;
    } else {
      obsBadge.className = 'badge badge-primary';
      obsBadge.innerHTML = '<i class="ti ti-loader-2"></i> Preview Starting';
      goLiveBtn.disabled = true;
    }

    if (status.isLive) {
      publicBadge.className = 'badge badge-success';
      publicBadge.innerHTML = '<i class="ti ti-world"></i> Public Live';
      goLiveBtn.innerHTML = '<i class="ti ti-player-stop"></i> End Public Live';
      goLiveBtn.disabled = false;
      goLiveBtn.onclick = () => setPublicLive(false);
    } else {
      publicBadge.className = 'badge badge-primary';
      publicBadge.textContent = 'Public Offline';
      goLiveBtn.innerHTML = '<i class="ti ti-player-play"></i> Go Live';
      goLiveBtn.disabled = !status.isReady;
      goLiveBtn.onclick = () => setPublicLive(true);
    }
  }

  async function refreshStatus() {
    const res = await fetch(`/api/stream/${encodeURIComponent(streamKey)}/transcoder/status`);
    const data = await res.json();
    if (!res.ok || !data.success) throw new Error(data.error || 'Failed to load preview status.');
    updateBadges(data.data);
  }

  startPreviewBtn.addEventListener('click', startPreviewPipeline);

  loadIngestDetails()
    .then(startPreviewPipeline)
    .then(refreshStatus)
    .catch((err) => {
      if (window.showToast) window.showToast(err.message, 'error');
    });

  setInterval(() => {
    refreshStatus().catch(() => {});
  }, 3000);
</script>

<%- include('footer') %>
