<%- include('header') %>

<div style="max-width: 1100px; margin: 1.5rem auto; display: flex; flex-direction: column; gap: 1.5rem;">
  <!-- Admin Access & Quota Control Panel -->
  <div class="glass-panel">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
      <h3 class="card-title" style="display: flex; align-items: center; gap: 0.5rem; margin: 0;">
        <i class="ti ti-shield-lock" style="color: var(--secondary);"></i> Admin Stream & Quota Management
      </h3>
      <span class="badge badge-danger">Administrator Access</span>
    </div>
    <p style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 1.5rem;">
      Manage user access, stream quotas (only live sessions &ge; 1.5h count towards quota), reset usage counters, or block broadcasting.
    </p>

    <div style="overflow-x: auto;">
      <table class="premium-table" id="users-table">
        <thead>
          <tr>
            <th>User</th>
            <th>Email</th>
            <th>Role</th>
            <th>Access</th>
            <th>Stream Quota Used (&ge;1.5h)</th>
            <th>Max Quota Limit</th>
            <th>Status / Block</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="users-list">
          <tr>
            <td colspan="8" style="text-align: center; color: var(--text-muted);">Loading users & telemetry...</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Telemetry Session Logs Inspector -->
  <div class="glass-panel">
    <div class="card-header" style="margin-bottom: 1rem;">
      <h3 class="card-title" style="display: flex; align-items: center; gap: 0.5rem; margin: 0;">
        <i class="ti ti-history" style="color: var(--primary);"></i> Broadcast Telemetry Logs
      </h3>
    </div>
    <p style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 1.5rem;">
      Detailed logs of past stream sessions. Sessions &ge; 90 minutes (1.5h) increment user quota usage.
    </p>
    <div style="overflow-x: auto;">
      <table class="premium-table">
        <thead>
          <tr>
            <th>User</th>
            <th>Stream Key</th>
            <th>Start Time</th>
            <th>Duration</th>
            <th>Quota Status</th>
          </tr>
        </thead>
        <tbody id="telemetry-list">
          <tr>
            <td colspan="5" style="text-align: center; color: var(--text-muted);">Loading telemetry logs...</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    fetchUsers();
    fetchTelemetry();
  });

  async function fetchUsers() {
    try {
      const res = await fetch('/api/users');
      const users = await res.json();
      const list = document.getElementById('users-list');
      list.innerHTML = '';
      
      users.forEach(u => {
        const isSelf = u.id === '<%= user.id %>';
        const isBlocked = !!u.isBlockedFromStreaming;
        
        list.innerHTML += `
          <tr>
            <td data-label="User">
              <div style="display:flex; align-items:center; gap:0.5rem;">
                <div class="avatar" style="width:28px; height:28px; font-size:0.75rem;">${u.name.charAt(0).toUpperCase()}</div>
                <span style="font-weight:600;">${u.name} ${isSelf ? '(You)' : ''}</span>
              </div>
            </td>
            <td data-label="Email" style="color:var(--text-muted); font-size:0.85rem;">${u.email}</td>
            <td data-label="Role">
              <select class="form-input" style="padding:0.25rem 0.5rem; font-size:0.85rem; width:auto;" ${isSelf ? 'disabled' : ''} onchange="changeRole('${u.id}', this.value)">
                <option value="user" ${u.role === 'user' ? 'selected' : ''}>User</option>
                <option value="admin" ${u.role === 'admin' ? 'selected' : ''}>Admin</option>
              </select>
            </td>
            <td data-label="Access">
              <label class="switch">
                <input type="checkbox" ${u.hasAccess || u.role === 'admin' ? 'checked' : ''} ${isSelf || u.role === 'admin' ? 'disabled' : ''} onchange="toggleAccess('${u.id}', this.checked)">
                <span class="slider"></span>
              </label>
            </td>
            <td data-label="Used">
              <span class="badge ${u.usedCount >= u.maxAllowedStreams ? 'badge-danger' : 'badge-primary'}">
                ${u.usedCount} / ${u.maxAllowedStreams} Counted
              </span>
            </td>
            <td data-label="Limit">
              <input type="number" class="form-input" style="width: 70px; padding: 0.25rem; font-size: 0.85rem;" value="${u.maxAllowedStreams}" min="0" onchange="updateQuota('${u.id}', this.value)" />
            </td>
            <td data-label="Status">
              <button class="btn ${isBlocked ? 'btn-danger' : 'btn-secondary'}" style="padding: 0.35rem 0.75rem; font-size: 0.8rem;" ${isSelf ? 'disabled' : ''} onclick="toggleBlock('${u.id}', ${!isBlocked})">
                <i class="ti ${isBlocked ? 'ti-user-x' : 'ti-user-check'}"></i> ${isBlocked ? 'Blocked' : 'Active'}
              </button>
            </td>
            <td data-label="Actions">
              <button class="btn btn-secondary" style="padding: 0.35rem 0.75rem; font-size: 0.8rem;" onclick="resetQuota('${u.id}')" title="Reset counted stream usage">
                <i class="ti ti-rotate-clockwise"></i> Reset
              </button>
            </td>
          </tr>
        `;
      });
    } catch (err) {
      if (window.showToast) window.showToast(err.message, 'error');
    }
  }

  async function fetchTelemetry() {
    try {
      const res = await fetch('/api/admin/telemetry');
      const data = await res.json();
      const list = document.getElementById('telemetry-list');
      list.innerHTML = '';

      if (!data.logs || data.logs.length === 0) {
        list.innerHTML = '<tr><td colspan="5" style="text-align: center; color: var(--text-muted);">No telemetry sessions recorded yet.</td></tr>';
        return;
      }

      data.logs.slice(-20).reverse().forEach(log => {
        const startStr = new Date(log.startTime).toLocaleString();
        const mins = log.durationSeconds ? Math.floor(log.durationSeconds / 60) : 0;
        const counted = log.countedTowardsQuota;

        list.innerHTML += `
          <tr>
            <td><strong>${log.userName}</strong> (${log.userEmail})</td>
            <td style="font-family: monospace; font-size: 0.85rem;">${log.streamKey}</td>
            <td style="font-size: 0.85rem;">${startStr}</td>
            <td>${mins} mins (${log.durationSeconds || 0}s)</td>
            <td>
              <span class="badge ${counted ? 'badge-danger' : 'badge-primary'}">
                ${counted ? 'Counted (&ge;1.5h)' : 'Ignored (<1.5h)'}
              </span>
            </td>
          </tr>
        `;
      });
    } catch (err) {
      console.error("Telemetry fetch error:", err);
    }
  }

  async function toggleAccess(userId, hasAccess) {
    try {
      const res = await fetch('/api/users/toggle-access', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId, hasAccess })
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Failed to update access.');
      if (window.showToast) window.showToast(data.message, 'success');
      fetchUsers();
    } catch (err) {
      if (window.showToast) window.showToast(err.message, 'error');
    }
  }

  async function changeRole(userId, role) {
    try {
      const res = await fetch('/api/users/change-role', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId, role })
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Failed to update role.');
      if (window.showToast) window.showToast(data.message, 'success');
      fetchUsers();
    } catch (err) {
      if (window.showToast) window.showToast(err.message, 'error');
    }
  }

  async function updateQuota(userId, maxAllowedStreams) {
    try {
      const res = await fetch('/api/users/update-quota', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId, maxAllowedStreams: parseInt(maxAllowedStreams, 10) })
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Failed to update quota.');
      if (window.showToast) window.showToast(data.message, 'success');
      fetchUsers();
    } catch (err) {
      if (window.showToast) window.showToast(err.message, 'error');
    }
  }

  async function toggleBlock(userId, isBlockedFromStreaming) {
    try {
      const res = await fetch('/api/users/toggle-block', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId, isBlockedFromStreaming })
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Failed to toggle block status.');
      if (window.showToast) window.showToast(data.message, 'success');
      fetchUsers();
    } catch (err) {
      if (window.showToast) window.showToast(err.message, 'error');
    }
  }

  async function resetQuota(userId) {
    try {
      const res = await fetch('/api/users/reset-quota', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId })
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Failed to reset quota.');
      if (window.showToast) window.showToast(data.message, 'success');
      fetchUsers();
    } catch (err) {
      if (window.showToast) window.showToast(err.message, 'error');
    }
  }
</script>

<%- include('footer') %>
