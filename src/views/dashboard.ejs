<%- include('header') %>

<div class="dashboard-grid">
  <!-- Left Side: Streams and Management + SFU Console -->
  <div style="display: flex; flex-direction: column; gap: 2rem;">
    
    <!-- Streams List -->
    <div class="glass-panel">
      <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
        <h3 class="card-title" style="display: flex; align-items: center; gap: 0.5rem; margin: 0;">
          <i class="ti ti-broadcast" style="color: var(--primary);"></i> Your Stream Keys
        </h3>
        <div style="display: flex; gap: 0.5rem; align-items: center;">
          <span class="badge badge-success"><i class="ti ti-server-2"></i> SFU Implemented</span>
          <span class="badge badge-primary"><%= streams.length %> Total</span>
        </div>
      </div>

      <% if (streams.length === 0) { %>
        <div style="text-align: center; padding: 3rem 0; color: var(--text-muted);">
          <i class="ti ti-movie" style="font-size: 3rem; display: block; margin-bottom: 1rem; opacity: 0.5;"></i>
          <p>You haven't created any streams yet. Create one on the right to start broadcasting.</p>
        </div>
      <% } else { %>
        <div style="overflow-x: auto;">
          <table class="premium-table">
            <thead>
              <tr>
                <th>Title</th>
                <th>Stream Key</th>
                <th>Status</th>
                <th style="text-align: right;">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% streams.forEach(stream => { %>
                <tr id="stream-row-<%= stream.id %>">
                  <td data-label="Title" style="font-weight: 600;"><%= stream.title %></td>
                  <td data-label="Stream Key">
                    <div style="display: flex; align-items: center; gap: 0.35rem;">
                      <code class="stream-key-code" title="<%= stream.streamKey %>"><%= stream.streamKey %></code>
                      <button class="btn btn-secondary btn-sm" style="padding: 0.2rem 0.4rem;" onclick="copyToClipboard('<%= stream.streamKey %>')" title="Copy Stream Key">
                        <i class="ti ti-copy"></i>
                      </button>
                    </div>
                  </td>
                  <td data-label="Status">
                    <% if (stream.isActive) { %>
                      <span class="badge badge-success"><i class="ti ti-point-filled"></i> Live Now</span>
                    <% } else { %>
                      <span class="badge badge-primary">Offline</span>
                    <% } %>
                  </td>
                  <td data-label="Actions" class="dashboard-actions-cell" style="text-align: right; display: flex; justify-content: flex-end; gap: 0.35rem; white-space: nowrap;">
                    <a href="/stream/<%= stream.streamKey %>" class="btn btn-primary btn-sm" title="Broadcast">
                      <i class="ti ti-video"></i><span class="btn-text-mobile"> Broadcast</span>
                    </a>
                    <a href="/live/<%= stream.streamKey %>" class="btn btn-secondary btn-sm" title="Watch">
                      <i class="ti ti-player-play"></i><span class="btn-text-mobile"> Watch</span>
                    </a>
                    <button class="btn btn-danger btn-sm" onclick="deleteStream('<%= stream.id %>')" title="Delete">
                      <i class="ti ti-trash"></i>
                    </button>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <!-- SFU Telemetry Console Box -->
    <div class="glass-panel">
      <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
        <h3 class="card-title" style="display: flex; align-items: center; gap: 0.5rem; margin: 0;">
          <i class="ti ti-terminal-2" style="color: var(--primary);"></i> SFU WebRTC Relay Diagnostics
        </h3>
        <span class="badge badge-success" style="font-family: monospace;">SFU Active &amp; Ready</span>
      </div>
      <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 1rem;">
        Real-time server media relay logs showing WebSocket signaling, client SDP handshakes, and outbound bandwidth distribution.
      </p>

      <div style="background: #0c0e10; border: 1px solid var(--panel-border); border-radius: 10px; padding: 1rem; height: 220px; overflow-y: auto; font-family: 'Fira Code', monospace; font-size: 0.8rem; line-height: 1.5; color: #82A3A1;" id="dash-console">
        <div style="color: #64748b;">Initializing SFU telemetry connection...</div>
      </div>
    </div>

  </div>

  <!-- Right Side: Stream Creation & Info -->
  <div style="display: flex; flex-direction: column; gap: 2rem;">
    
    <!-- Create Stream -->
    <div class="glass-panel">
      <div class="card-header">
        <h3 class="card-title">
          <i class="ti ti-plus" style="color: var(--accent);"></i> New Stream Setup
        </h3>
      </div>
      
      <% if (user.role === 'admin' || user.hasAccess) { %>
        <form onsubmit="createStream(event)">
          <div class="form-group">
            <label class="form-label">Stream Title</label>
            <input type="text" id="stream-title" class="form-input" placeholder="e.g. CoWatch Movie Night 🍿" required>
          </div>
          <button type="submit" class="btn btn-primary" style="width: 100%;">
            <i class="ti ti-circle-plus"></i> Generate Stream Key
          </button>
        </form>
      <% } else { %>
        <div style="text-align: center; padding: 1.5rem 0;">
          <div style="color: var(--warning); font-size: 2.5rem; margin-bottom: 1rem;">
            <i class="ti ti-lock-off"></i>
          </div>
          <p style="font-weight: 500; margin-bottom: 0.5rem;">Stream Creation Locked</p>
          <p style="color: var(--text-muted); font-size: 0.85rem;">
            Your account does not currently have access to stream. Please request streaming access from an administrator.
          </p>
        </div>
      <% } %>
    </div>

    <!-- How it works info -->
    <div class="glass-panel">
      <div class="card-header">
        <h3 class="card-title"><i class="ti ti-help-circle" style="color: var(--warning);"></i> Quick Guide</h3>
      </div>
      <ul style="list-style: none; display: flex; flex-direction: column; gap: 1rem; font-size: 0.9rem; color: var(--text-muted);">
        <li style="display: flex; gap: 0.5rem; align-items: flex-start;">
          <i class="ti ti-circle-number-1" style="color: var(--primary); font-size: 1.25rem;"></i>
          <span>Create a stream key using the panel above.</span>
        </li>
        <li style="display: flex; gap: 0.5rem; align-items: flex-start;">
          <i class="ti ti-circle-number-2" style="color: var(--primary); font-size: 1.25rem;"></i>
          <span>Click **Broadcast** to enter the studio streaming cockpit.</span>
        </li>
        <li style="display: flex; gap: 0.5rem; align-items: flex-start;">
          <i class="ti ti-circle-number-3" style="color: var(--primary); font-size: 1.25rem;"></i>
          <span>Toggle resolutions/FPS, select movie or screen share, and stream buffer-free via SFU.</span>
        </li>
        <li style="display: flex; gap: 0.5rem; align-items: flex-start;">
          <i class="ti ti-circle-number-4" style="color: var(--primary); font-size: 1.25rem;"></i>
          <span>Share the **Watch** link with up to 5 viewers for high-quality synchronized playout.</span>
        </li>
      </ul>
    </div>

  </div>
</div>

<script>
  function copyToClipboard(text) {
    navigator.clipboard.writeText(text).then(() => {
      if (window.showToast) window.showToast('Stream key copied to clipboard!', 'success');
    }).catch(() => {
      if (window.showToast) window.showToast('Failed to copy stream key.', 'error');
    });
  }

  async function createStream(e) {
    e.preventDefault();
    const title = document.getElementById('stream-title').value;
    
    try {
      const res = await fetch('/api/stream', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title })
      });
      const data = await res.json();
      
      if (!res.ok) {
        throw new Error(data.error || 'Failed to create stream.');
      }
      
      if (window.showToast) window.showToast('Stream key generated successfully!', 'success');
      setTimeout(() => window.location.reload(), 500);
    } catch (err) {
      if (window.showToast) window.showToast(err.message, 'error');
    }
  }

  async function deleteStream(id) {
    if (!confirm('Are you sure you want to delete this stream key? This will permanently delete the stream.')) {
      return;
    }
    
    try {
      const res = await fetch(`/api/stream/${id}`, {
        method: 'DELETE'
      });
      const data = await res.json();
      
      if (!res.ok) {
        throw new Error(data.error || 'Failed to delete stream.');
      }
      
      const row = document.getElementById(`stream-row-${id}`);
      if (row) row.remove();
      if (window.showToast) window.showToast('Stream key deleted.', 'success');
    } catch (err) {
      if (window.showToast) window.showToast(err.message, 'error');
    }
  }

  // Connect live SFU telemetry console on dashboard
  (function() {
    const consoleBody = document.getElementById('dash-console');
    if (!consoleBody) return;

    const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
    const wsUrl = `${protocol}//${window.location.host}/api/monitor/ws`;
    let socket = null;

    function connect() {
      socket = new WebSocket(wsUrl);
      socket.onmessage = (event) => {
        try {
          const data = JSON.parse(event.data);
          if (data.ffmpegLogs && data.ffmpegLogs.length > 0) {
            consoleBody.innerHTML = data.ffmpegLogs.slice(-15).map(line => {
              let color = '#82A3A1';
              if (line.includes('warning') || line.includes('WARN')) color = '#f59e0b';
              if (line.includes('error') || line.includes('ERR')) color = '#ef4444';
              if (line.includes('[Signaling]')) color = '#9FC490';
              return `<div style="color: ${color}; margin-bottom: 0.2rem;">${escapeHtml(line)}</div>`;
            }).join('');
            consoleBody.scrollTop = consoleBody.scrollHeight;
          } else {
            consoleBody.innerHTML = `<div style="color: #64748b;">[SFU Telemetry] Waiting for live stream events...</div>`;
          }
        } catch (_) {}
      };
      socket.onclose = () => setTimeout(connect, 4000);
    }

    function escapeHtml(unsafe) {
      return unsafe
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }

    connect();
  })();
</script>

<%- include('footer') %>
