<%- include('header') %>

<div class="dashboard-grid">
  <!-- Left Side: Streams and Management -->
  <div style="display: flex; flex-direction: column; gap: 2rem;">
    
    <!-- Streams List -->
    <div class="glass-panel">
      <div class="card-header">
        <h3 class="card-title">
          <i class="ti ti-broadcast" style="color: var(--primary);"></i> Your Stream Keys
        </h3>
        <span class="badge badge-primary"><%= streams.length %> Total</span>
      </div>

      <% if (streams.length === 0) { %>
        <div style="text-align: center; padding: 3rem 0; color: var(--text-muted);">
          <i class="ti ti-movie" style="font-size: 3rem; display: block; margin-bottom: 1rem; opacity: 0.5;"></i>
          <p>You haven't created any streams yet. Create one on the right to start broadcasting.</p>
        </div>
      <% } else { %>
        <div style="overflow-x: auto;">
          <table class="premium-table">
            <thead>
              <tr>
                <th>Title</th>
                <th>Stream Key</th>
                <th>Status</th>
                <th style="text-align: right;">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% streams.forEach(stream => { %>
                <tr id="stream-row-<%= stream.id %>">
                  <td style="font-weight: 600;"><%= stream.title %></td>
                  <td>
                    <code style="background: rgba(0, 0, 0, 0.3); padding: 0.25rem 0.5rem; border-radius: 4px; font-family: monospace; font-size: 0.9rem;">
                      <%= stream.streamKey %>
                    </code>
                    <button class="btn btn-secondary" style="padding: 0.2rem 0.4rem; font-size: 0.75rem; border-radius: 4px; margin-left: 0.5rem;" onclick="copyToClipboard('<%= stream.streamKey %>')">
                      <i class="ti ti-copy"></i>
                    </button>
                  </td>
                  <td>
                    <% if (stream.isActive) { %>
                      <span class="badge badge-success"><i class="ti ti-point-filled"></i> Live Now</span>
                    <% } else { %>
                      <span class="badge badge-primary">Offline</span>
                    <% } %>
                  </td>
                  <td style="text-align: right; display: flex; justify-content: flex-end; gap: 0.5rem;">
                    <a href="/stream/<%= stream.streamKey %>" class="btn btn-primary" style="padding: 0.4rem 0.8rem; font-size: 0.85rem; border-radius: 6px;">
                      <i class="ti ti-video"></i> Broadcast
                    </a>
                    <a href="/live/<%= stream.streamKey %>" class="btn btn-secondary" style="padding: 0.4rem 0.8rem; font-size: 0.85rem; border-radius: 6px;">
                      <i class="ti ti-player-play"></i> Watch
                    </a>
                    <button class="btn btn-danger" style="padding: 0.4rem 0.8rem; font-size: 0.85rem; border-radius: 6px;" onclick="deleteStream('<%= stream.id %>')">
                      <i class="ti ti-trash"></i>
                    </button>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <!-- Admin Panel (Only visible to Admin role) -->
    <% if (user.role === 'admin') { %>
      <div class="glass-panel">
        <div class="card-header">
          <h3 class="card-title">
            <i class="ti ti-shield-lock" style="color: var(--secondary);"></i> Admin Access Panel
          </h3>
          <span class="badge badge-danger">Administrator Privilege</span>
        </div>
        <p style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 1.5rem;">
          As an admin, you have master access. You can promote users to Admins or grant them access to create streams.
        </p>

        <div style="overflow-x: auto;">
          <table class="premium-table" id="users-table">
            <thead>
              <tr>
                <th>User</th>
                <th>Email</th>
                <th>Role</th>
                <th>Streaming Access</th>
              </tr>
            </thead>
            <tbody id="users-list">
              <tr>
                <td colspan="4" style="text-align: center; color: var(--text-muted);">Loading users list...</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>

  </div>

  <!-- Right Side: Stream Creation & Info -->
  <div style="display: flex; flex-direction: column; gap: 2rem;">
    
    <!-- Create Stream -->
    <div class="glass-panel">
      <div class="card-header">
        <h3 class="card-title">
          <i class="ti ti-plus" style="color: var(--accent);"></i> New Stream Setup
        </h3>
      </div>
      
      <% if (user.role === 'admin' || user.hasAccess) { %>
        <form onsubmit="createStream(event)">
          <div class="form-group">
            <label class="form-label">Stream Title</label>
            <input type="text" id="stream-title" class="form-input" placeholder="e.g. CoWatch Movie Night 🍿" required>
          </div>
          <button type="submit" class="btn btn-primary" style="width: 100%;">
            <i class="ti ti-circle-plus"></i> Generate Stream Key
          </button>
        </form>
      <% } else { %>
        <div style="text-align: center; padding: 1.5rem 0;">
          <div style="color: var(--warning); font-size: 2.5rem; margin-bottom: 1rem;">
            <i class="ti ti-lock-off"></i>
          </div>
          <p style="font-weight: 500; margin-bottom: 0.5rem;">Stream Creation Locked</p>
          <p style="color: var(--text-muted); font-size: 0.85rem;">
            Your account does not currently have access to stream. Please request streaming access from an administrator.
          </p>
        </div>
      <% } %>
    </div>

    <!-- How it works info -->
    <div class="glass-panel">
      <div class="card-header">
        <h3 class="card-title"><i class="ti ti-help-circle" style="color: var(--warning);"></i> Quick Guide</h3>
      </div>
      <ul style="list-style: none; display: flex; flex-direction: column; gap: 1rem; font-size: 0.9rem; color: var(--text-muted);">
        <li style="display: flex; gap: 0.5rem; align-items: flex-start;">
          <i class="ti ti-circle-number-1" style="color: var(--primary); font-size: 1.25rem;"></i>
          <span>Create a stream key using the panel above.</span>
        </li>
        <li style="display: flex; gap: 0.5rem; align-items: flex-start;">
          <i class="ti ti-circle-number-2" style="color: var(--primary); font-size: 1.25rem;"></i>
          <span>Click the **Broadcast** button to enter the streaming cockpit.</span>
        </li>
        <li style="display: flex; gap: 0.5rem; align-items: flex-start;">
          <i class="ti ti-circle-number-3" style="color: var(--primary); font-size: 1.25rem;"></i>
          <span>Toggle resolutions/FPS, test bandwidth, and start streaming!</span>
        </li>
        <li style="display: flex; gap: 0.5rem; align-items: flex-start;">
          <i class="ti ti-circle-number-4" style="color: var(--primary); font-size: 1.25rem;"></i>
          <span>Share the **Watch** link with friends so they can view the live feed with ultra-low latency.</span>
        </li>
      </ul>
    </div>

  </div>
</div>

<script>
  function copyToClipboard(text) {
    navigator.clipboard.writeText(text);
    alert('Stream key copied to clipboard!');
  }

  async function createStream(e) {
    e.preventDefault();
    const title = document.getElementById('stream-title').value;
    
    try {
      const res = await fetch('/api/stream', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title })
      });
      const data = await res.json();
      
      if (!res.ok) {
        throw new Error(data.error || 'Failed to create stream.');
      }
      
      window.location.reload();
    } catch (err) {
      alert(err.message);
    }
  }

  async function deleteStream(id) {
    if (!confirm('Are you sure you want to delete this stream key? This will permanently delete the stream.')) {
      return;
    }
    
    try {
      const res = await fetch(`/api/stream/${id}`, {
        method: 'DELETE'
      });
      const data = await res.json();
      
      if (!res.ok) {
        throw new Error(data.error || 'Failed to delete stream.');
      }
      
      const row = document.getElementById(`stream-row-${id}`);
      if (row) row.remove();
      window.location.reload();
    } catch (err) {
      alert(err.message);
    }
  }
</script>

<% if (user.role === 'admin') { %>
<script>
  // Admin Panel Functions
  document.addEventListener('DOMContentLoaded', fetchUsers);

    async function fetchUsers() {
      try {
        const res = await fetch('/api/users');
        const users = await res.json();
        const list = document.getElementById('users-list');
        list.innerHTML = '';
        
        users.forEach(u => {
          // Skip self to prevent self lockouts
          const isSelf = u.id === '<%= user.id %>';
          
          list.innerHTML += `
            <tr>
              <td>
                <div style="display:flex; align-items:center; gap:0.5rem;">
                  <div class="avatar" style="width:24px; height:24px; font-size:0.75rem;">${u.name.charAt(0).toUpperCase()}</div>
                  <span style="font-weight:600;">${u.name} ${isSelf ? '(You)' : ''}</span>
                </div>
              </td>
              <td style="color:var(--text-muted); font-size:0.9rem;">${u.email}</td>
              <td>
                <select class="form-input" style="padding:0.25rem 0.5rem; font-size:0.85rem; width:auto;" ${isSelf ? 'disabled' : ''} onchange="changeRole('${u.id}', this.value)">
                  <option value="user" ${u.role === 'user' ? 'selected' : ''}>User</option>
                  <option value="admin" ${u.role === 'admin' ? 'selected' : ''}>Admin</option>
                </select>
              </td>
              <td>
                <div class="toggle-wrapper" style="border:none; padding:0; justify-content:flex-start; gap:0.5rem;">
                  <label class="switch">
                    <input type="checkbox" ${u.hasAccess || u.role === 'admin' ? 'checked' : ''} ${isSelf || u.role === 'admin' ? 'disabled' : ''} onchange="toggleAccess('${u.id}', this.checked)">
                    <span class="slider"></span>
                  </label>
                  <span style="font-size:0.85rem; color:${u.hasAccess || u.role === 'admin' ? 'var(--accent)' : 'var(--text-muted)'}">
                    ${u.role === 'admin' ? 'Always Allowed' : (u.hasAccess ? 'Allowed' : 'Denied')}
                  </span>
                </div>
              </td>
            </tr>
          `;
        });
      } catch (err) {
        console.error(err);
      }
    }

    async function toggleAccess(userId, hasAccess) {
      try {
        const res = await fetch('/api/users/toggle-access', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ userId, hasAccess })
        });
        if (!res.ok) throw new Error('Failed to update access.');
        fetchUsers();
      } catch (err) {
        alert(err.message);
      }
    }

    async function changeRole(userId, role) {
      try {
        const res = await fetch('/api/users/change-role', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ userId, role })
        });
        if (!res.ok) throw new Error('Failed to update role.');
        fetchUsers();
      } catch (err) {
        alert(err.message);
      }
    }
</script>
<% } %>

<%- include('footer') %>
